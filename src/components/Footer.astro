---
import { t } from "@i18n/t";
import TwitterX from "@assets/icons/twitter-x.svg";
import Telegram from "@assets/icons/telegram.svg";
import Discussion from "@assets/icons/discussion.svg";
import Github from "@assets/icons/github.svg";
import Docs from "@assets/icons/docs.svg";

const tt = t(Astro.url);
const path = Astro.url.pathname;

/** Map current page to the most relevant Frankencoin docs section. */
function docsLink(p: string): string {
  const base = "https://docs.frankencoin.com";
  if (p.includes("/mypositions")) return `${base}/positions/adjust`;
  if (p.includes("/mint")) return `${base}/positions/clone`;
  if (p.includes("/borrow")) return `${base}/positions`;
  if (p.includes("/earn") || p.includes("/savings")) return `${base}/savings`;
  if (p.includes("/transfer")) return `${base}/transfer`;
  return base;
}

const links = [
  { href: "https://x.com/frankencoinzchf", label: tt("footer_twitter"), icon: TwitterX },
  { href: "https://t.me/frankencoinzchf", label: tt("footer_telegram"), icon: Telegram },
  { href: "https://github.com/Frankencoin-ZCHF/Frankencoin/discussions", label: tt("footer_forum"), icon: Discussion },
  { href: "https://github.com/DiumPay/zchf-app", label: tt("footer_github"), icon: Github },
  { href: docsLink(path), label: tt("footer_docs"), icon: Docs },
];
---

<footer class="mt-40 border-t border-foreground/10">
  <div class="mx-auto max-w-6xl px-8 py-16 md:px-12 md:py-20">
    <div class="flex flex-col gap-12 md:flex-row md:items-center md:justify-between">
      <p class="max-w-md text-[13px] leading-relaxed opacity-80">
        {tt("footer_attribution_pre")}{" "}
        <a
          href="https://github.com/DiumPay/zchf-app"
          target="_blank"
          rel="noreferrer"
          class="font-semibold text-primary hover:underline"
        >
          DiumPay
        </a>
        {" "}{tt("footer_attribution_post")}
      </p>
      <ul class="flex items-center gap-10 md:gap-12">
        {links.map(({ href, label, icon: Icon }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noreferrer"
              aria-label={label}
              title={label}
              class="block opacity-70 transition-opacity hover:opacity-100 hover:text-primary"
            >
              <Icon class="h-5 w-5 fill-current" aria-hidden="true" />
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</footer>