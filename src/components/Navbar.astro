---
import chFlag from "@assets/flags/ch.svg?url";
import menuIcon from "@assets/icons/menu.svg?url";
import closeIcon from "@assets/icons/close.svg?url";
import Wallet from "@assets/icons/wallet.svg";
import LanguageSelector from "@components/LanguageSelector.astro";

const navItems = [
	{ label: "Borrow", href: "/" },
	{ label: "Earn", href: "#" },
	{ label: "Dashboard", href: "#" },
	{ label: "Bridge", href: "#" },
];

const currentPath = Astro.url.pathname;
---

<nav class="border-b border-ink/10 bg-offwhite">
	<div class="mx-auto flex h-16 max-w-7xl items-center gap-6 px-4 md:gap-10 md:px-6">
		<a href="/" class="flex items-center gap-2.5 text-ink">
			<img src={chFlag} alt="" class="h-5 w-5 rounded-sm" aria-hidden="true" />
			<span class="text-[20px] font-bold tracking-tight">Frankencoin</span>
		</a>

		<ul class="hidden items-center gap-8 md:flex">
			{
				navItems.map((item) => {
					const isActive = currentPath === item.href;
					return (
						<li>
							<a
								href={item.href}
								class:list={[
									"text-[16px] hover:text-crimson",
									isActive ? "font-semibold text-crimson" : "font-medium text-ink",
								]}
								aria-current={isActive ? "page" : undefined}
							>
								{item.label}
							</a>
						</li>
					);
				})
			}
		</ul>

		<div class="ml-auto flex items-center gap-2">
			<LanguageSelector />

			<button
				type="button"
				class="hidden items-center gap-2 rounded-md border border-transparent bg-crimson px-5 py-2.5 text-[15px] font-semibold text-offwhite hover:bg-crimson-600 md:inline-flex"
			>
				<span>Connect</span>
				<Wallet class="h-4 w-4 text-offwhite" aria-hidden="true" />
			</button>

			<button
				id="menu-toggle"
				type="button"
				class="inline-flex items-center justify-center md:hidden"
				aria-label="Toggle menu"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<img id="menu-icon" src={menuIcon} alt="" class="h-6 w-6" aria-hidden="true" />
				<img id="close-icon" src={closeIcon} alt="" class="hidden h-6 w-6" aria-hidden="true" />
			</button>
		</div>
	</div>

	<div id="mobile-menu" class="hidden border-t border-ink/10 md:hidden">
		<ul class="flex flex-col">
			{
				navItems.map((item) => {
					const isActive = currentPath === item.href;
					return (
						<li>
							<a
								href={item.href}
								class:list={[
									"block px-4 py-4 text-[16px] hover:bg-offwhite-200",
									isActive ? "font-semibold text-crimson" : "font-medium text-ink",
								]}
								aria-current={isActive ? "page" : undefined}
							>
								{item.label}
							</a>
						</li>
					);
				})
			}
		</ul>
		<div class="border-t border-ink/10 px-4 py-4">
			<button
				type="button"
				class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-transparent bg-crimson px-5 py-2.5 text-[15px] font-semibold text-offwhite hover:bg-crimson-600"
			>
				<span>Connect</span>
				<Wallet class="h-4 w-4 text-offwhite" aria-hidden="true" />
			</button>
		</div>
	</div>
</nav>

<script>
	const toggle = document.getElementById("menu-toggle");
	const menu = document.getElementById("mobile-menu");
	const menuIcon = document.getElementById("menu-icon");
	const closeIcon = document.getElementById("close-icon");

	toggle?.addEventListener("click", () => {
		const isOpen = menu?.classList.toggle("hidden") === false;
		menuIcon?.classList.toggle("hidden");
		closeIcon?.classList.toggle("hidden");
		toggle.setAttribute("aria-expanded", String(isOpen));
	});
</script>