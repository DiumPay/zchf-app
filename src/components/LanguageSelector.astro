---
import Tulip from "@assets/icons/tulip.svg";
import { SUPPORTED_LOCALES, getLocale, switchLocaleUrl } from "@i18n/t";
const currentLocale = getLocale(Astro.url);
---
<div class="relative">
    <button
        id="lang-toggle"
        type="button"
        class="group inline-flex items-center gap-1.5 rounded-md border border-foreground/20 px-3 py-2.5 text-[15px] font-medium text-foreground hover:border-foreground/40 hover:bg-muted aria-expanded:border-foreground/40 aria-expanded:bg-muted"
        aria-haspopup="listbox"
        aria-expanded="false"
    >
        <span>{currentLocale.toUpperCase()}</span>
        <svg
            viewBox="0 0 12 12"
            class="h-3 w-3 transition-transform duration-150 group-aria-expanded:rotate-180"
            aria-hidden="true"
        >
            <path
                d="M3 4.5 L6 7.5 L9 4.5"
                stroke="currentColor"
                stroke-width="1.5"
                fill="none"
                stroke-linecap="round"
                stroke-linejoin="round"
            />
        </svg>
    </button>
    <ul
        id="lang-menu"
        class="absolute right-0 top-full z-10 mt-1 hidden min-w-20 overflow-hidden rounded-md border border-foreground/10 bg-background shadow-md"
        role="listbox"
    >
        {
            SUPPORTED_LOCALES.map((lang) => {
                const isCurrent = lang === currentLocale;
                const href = switchLocaleUrl(Astro.url, lang);
                return (
                    <li>
                        <a
                            href={href}
                            data-lang={lang}
                            role="option"
                            aria-selected={isCurrent}
                            class:list={[
                                "flex w-full items-center justify-between gap-3 px-4 py-2 text-left text-[14px] hover:bg-muted",
                                isCurrent ? "font-semibold text-primary" : "text-foreground",
                            ]}
                        >
                            <span>{lang.toUpperCase()}</span>
                            {isCurrent && <Tulip class="h-3.5 w-3.5 text-primary" aria-hidden="true" />}
                        </a>
                    </li>
                );
            })
        }
    </ul>
</div>

<script>
    import { switchLocaleUrl } from "@i18n/t";
    import type { Locale } from "@i18n/messages";

    const toggle = document.getElementById("lang-toggle");
    const menu = document.getElementById("lang-menu");

    /**
     * Rewrites the href of each language link based on the CURRENT browser URL.
     * This is needed because Astro renders the links at SSG/server time with the
     * page's initial URL — so query strings added later via history.pushState
     * (e.g. ?address=0x... in mypositions) wouldn't be preserved on language switch.
     */
    function updateLangLinks() {
        const links = menu?.querySelectorAll<HTMLAnchorElement>("a[data-lang]");
        links?.forEach((link) => {
            const lang = link.dataset.lang as Locale;
            link.href = switchLocaleUrl(new URL(window.location.href), lang);
        });
    }

    // Run on initial load
    updateLangLinks();

    // Run on browser back/forward
    window.addEventListener("popstate", updateLangLinks);

    // Patch pushState/replaceState so SPA-style URL changes also trigger updates
    const origPush = history.pushState;
    history.pushState = function (...args) {
        origPush.apply(this, args);
        updateLangLinks();
    };
    const origReplace = history.replaceState;
    history.replaceState = function (...args) {
        origReplace.apply(this, args);
        updateLangLinks();
    };

    toggle?.addEventListener("click", (e) => {
        e.stopPropagation();
        const isOpen = menu?.classList.toggle("hidden") === false;
        toggle.setAttribute("aria-expanded", String(isOpen));
    });

    document.addEventListener("click", (e) => {
        if (!menu?.contains(e.target as Node)) {
            menu?.classList.add("hidden");
            toggle?.setAttribute("aria-expanded", "false");
        }
    });
</script>