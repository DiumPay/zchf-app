---
import LinkIcon from "@assets/icons/square-arrow-out-up-right.svg";

interface Props {
    href: string;
    title?: string;
    class?: string;
    id?: string;
}

const { href, title, class: className = "", id } = Astro.props;
---

<a
    href={href}
    target="_blank"
    rel="noopener"
    id={id}
    title={title}
    class:list={["inline-flex items-center gap-1.5 text-primary hover:underline", className]}
>
    <slot />
    <LinkIcon class="h-3.5 w-3.5 opacity-70" aria-hidden="true" />
</a>