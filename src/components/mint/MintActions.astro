---
import Button from "@components/Button.astro";

interface Props {
    mintLabel: string;
    connectLabel: string;
}

const { mintLabel, connectLabel } = Astro.props;
---

<div>
    <div id="actions-connected" class="hidden">
        <Button id="btn-action" fullWidth>
            <span class="btn-action-label">{mintLabel}</span>
        </Button>
    </div>
    <div id="actions-disconnected">
        <Button id="btn-connect" fullWidth>{connectLabel}</Button>
    </div>
</div>

<p id="banner" class="mt-4 hidden rounded-md border border-amber-500/30 bg-amber-500/10 p-3 text-[13px] text-amber-700 dark:text-amber-400"></p>
<p id="action-error" class="mt-2 hidden text-[13px] text-primary"></p>