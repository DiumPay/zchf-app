---
import Button from "@components/Button.astro";

interface Props {
    approveLabel: string;
    mintLabel: string;
    connectLabel: string;
}

const { approveLabel, mintLabel, connectLabel } = Astro.props;
---

<div>
    <div id="actions-connected" class="hidden">
        <div id="approve-row" class="hidden mb-3">
            <Button id="btn-approve" fullWidth>{approveLabel}</Button>
        </div>
        <Button id="btn-borrow" fullWidth>{mintLabel}</Button>
    </div>
    <div id="actions-disconnected">
        <Button id="btn-connect" fullWidth>{connectLabel}</Button>
    </div>
</div>

<p id="banner" class="mt-4 hidden rounded-md border border-amber-500/30 bg-amber-500/10 p-3 text-[13px] text-amber-700 dark:text-amber-400"></p>