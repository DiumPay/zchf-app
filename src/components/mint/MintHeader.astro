---
import ExternalLink from "@components/ExternalLink.astro";

interface Props {
    name: string;
    symbol: string;
    iconUrl: string | null;
    address: string;
    collateral: string;
    isClone: boolean;
}

const { name, symbol, iconUrl, address, collateral, isClone } = Astro.props;
---

<header class="mb-8 flex flex-col gap-5 md:flex-row md:items-center md:justify-between">
    <div class="flex items-center gap-4">
        {iconUrl
            ? <img src={iconUrl} alt={`${symbol} icon`} class="h-14 w-14 rounded-full" />
            : <div class="flex h-14 w-14 items-center justify-center rounded-full bg-foreground/10 text-[14px] font-bold">{symbol.slice(0, 3)}</div>
        }
        <div>
            <h1 class="flex flex-wrap items-center gap-x-3 gap-y-1 text-[26px] font-bold leading-tight tracking-tight">
                <span>{name}</span>
                <span class="text-[16px] font-medium text-muted-foreground">{symbol}</span>
            </h1>
            <div class="mt-1.5 flex flex-wrap gap-1.5">
                <span id="badge-status" class="inline-block rounded px-2 py-0.5 text-[11px] font-bold uppercase tracking-wide bg-foreground/10">Active</span>
                <span class="inline-block rounded px-2 py-0.5 text-[11px] font-bold uppercase tracking-wide bg-foreground/10">V2</span>
                {isClone && <span class="inline-block rounded px-2 py-0.5 text-[11px] font-bold uppercase tracking-wide bg-primary/15 text-primary">Clone</span>}
            </div>
        </div>
    </div>
    <div class="flex gap-4 text-[13px]">
        <ExternalLink href={`https://etherscan.io/address/${address}`} title={`View position contract on Etherscan`}>Position contract</ExternalLink>
        <ExternalLink href={`https://etherscan.io/address/${collateral}`} title={`View ${symbol} token on Etherscan`}>{symbol} token</ExternalLink>
    </div>
</header>