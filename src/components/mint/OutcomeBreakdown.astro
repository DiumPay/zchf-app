---
interface Props {
    mintedLabel: string;
    reserveLabel: string;
    repaidLabel: string;
    interestLabel: string;
    sentLabel: string;
    cooldownMintableLabel: string;
    cooldownAvailableLabel: string;
}

const {
    mintedLabel, reserveLabel, repaidLabel, interestLabel, sentLabel,
    cooldownMintableLabel, cooldownAvailableLabel,
} = Astro.props;
---

<div class="rounded-md bg-muted/40 p-5">
    <div class="space-y-2.5 text-[14px]">
        <div class="flex items-center justify-between">
            <span class="text-foreground/75">{mintedLabel} <span class="text-[12px] text-muted-foreground">(100%)</span></span>
            <span id="out-minted" class="font-mono font-medium tabular-nums">0 ZCHF</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-foreground/75">{reserveLabel} <span id="out-reserve-pct" class="text-[12px] text-muted-foreground">(0%)</span></span>
            <span id="out-reserve" class="font-mono font-medium tabular-nums">0 ZCHF</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-foreground/75">{repaidLabel} <span id="out-repaid-pct" class="text-[12px] text-muted-foreground">(0%)</span></span>
            <span id="out-repaid" class="font-mono font-medium tabular-nums">0 ZCHF</span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-foreground/75">{interestLabel} <span id="out-rate" class="text-[12px] text-muted-foreground">(0% per year)</span></span>
            <span id="out-fee" class="font-mono font-medium tabular-nums">0 ZCHF</span>
        </div>
        <div class="flex items-center justify-between border-t border-foreground/10 pt-3 text-[16px] font-bold">
            <span>{sentLabel}</span>
            <span id="out-net" class="font-mono tabular-nums">0 ZCHF</span>
        </div>
    </div>
</div>

<div id="cooldown-breakdown" class="hidden rounded-md border border-amber-500/30 bg-amber-500/5 p-5 mt-3">
    <div class="space-y-2.5 text-[14px] text-amber-700 dark:text-amber-400">
        <div class="flex items-center justify-between">
            <span>{cooldownMintableLabel}</span>
            <span id="out-cooldown-mintable" class="font-mono font-medium tabular-nums">0 ZCHF</span>
        </div>
        <div class="flex items-center justify-between">
            <span>{cooldownAvailableLabel}</span>
            <span id="out-cooldown-additional" class="font-mono font-medium tabular-nums">0 ZCHF</span>
        </div>
    </div>
</div>