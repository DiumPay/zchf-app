---
interface Props {
    title: string;
    class?: string;
}
const { title, class: className = "" } = Astro.props;
---

<div class:list={["rounded-md border border-foreground/10 bg-background p-6", className]}>
    <div class="mb-4 flex items-center justify-between gap-3">
        <h2 class="text-[20px] font-bold tracking-tight">{title}</h2>
        <slot name="actions" />
    </div>
    <div class="text-[16px] font-medium">
        <slot />
    </div>
</div>