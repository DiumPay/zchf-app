---
import Wallet from "@assets/icons/wallet.svg";

interface Props {
    fullWidth?: boolean;
}

const { fullWidth = false } = Astro.props;

const baseClasses =
    "items-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2.5 text-[15px] font-semibold text-[#FAF7F2] dark:text-[#030303] hover:bg-primary-hover";

const layoutClasses = fullWidth ? "inline-flex w-full justify-center" : "inline-flex";
---

<button
    type="button"
    class:list={["wallet-connect-btn", baseClasses, layoutClasses]}
>
    <span class="wallet-connect-label">Connect</span>
    <Wallet class="h-4 w-4 text-background dark:text-[#030303]" aria-hidden="true" />
</button>

<script>
    import { getOnboard } from "@lib/onboard";

    const SHORT = (addr: string) => `${addr.slice(0, 6)}...${addr.slice(-4)}`;

    let connectedLabel: string | null = null;

    function setAllLabels(text: string) {
        document
            .querySelectorAll<HTMLSpanElement>(".wallet-connect-btn .wallet-connect-label")
            .forEach((span) => (span.textContent = text));
    }

    function applyState(wallets: ReturnType<typeof getOnboard>["state"] extends { get: () => infer S } ? (S extends { wallets: infer W } ? W : never) : never) {
        if (wallets.length > 0) {
            const w = wallets[0];
            connectedLabel = w.label;
            const address = w.accounts[0]?.address ?? "";
            setAllLabels(address ? SHORT(address) : connectedLabel);
        } else {
            connectedLabel = null;
            setAllLabels("Connect");
        }
    }

    async function handleClick() {
        const onboard = getOnboard();

        if (connectedLabel) {
            const confirmed = window.confirm("Are you sure you want to disconnect your wallet?");
            if (!confirmed) return;
            await onboard.disconnectWallet({ label: connectedLabel });
            return;
        }

        await onboard.connectWallet();
    }

    document
        .querySelectorAll<HTMLButtonElement>(".wallet-connect-btn")
        .forEach((btn) => btn.addEventListener("click", handleClick));

    // Subscribe to wallet state - fires on initial autoConnect AND on connect/disconnect
    const onboard = getOnboard();
    const wallets$ = onboard.state.select("wallets");
    wallets$.subscribe((wallets) => applyState(wallets));

    // Apply current state immediately in case subscription missed initial value
    applyState(onboard.state.get().wallets);
</script>