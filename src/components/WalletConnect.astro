---
import Wallet from "@assets/icons/wallet.svg";
import { t } from "@i18n/t";

interface Props {
    fullWidth?: boolean;
}

const { fullWidth = false } = Astro.props;
const tt = t(Astro.url);

const baseClasses =
    "items-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2.5 text-[15px] font-semibold text-[#FAF7F2] dark:text-[#030303] hover:bg-primary-hover disabled:opacity-60 disabled:cursor-not-allowed";
const layoutClasses = fullWidth ? "inline-flex w-full justify-center" : "inline-flex";
---

<button type="button" class:list={["wallet-connect-btn", baseClasses, layoutClasses]}>
    <span class="wallet-connect-label">{tt("wallet_connect")}</span>
    <Wallet class="h-4 w-4 text-background dark:text-[#030303]" aria-hidden="true" />
</button>

<script>
    import { t } from "@i18n/t";

    const tt = t(window.location.pathname);
    const SHORT = (addr: string) => `${addr.slice(0, 6)}...${addr.slice(-4)}`;

    let connectedLabel: string | null = null;
    let onboardModule: typeof import("@lib/onboard") | null = null;
    let loading = false;

    function setAllLabels(text: string) {
        document
            .querySelectorAll<HTMLSpanElement>(".wallet-connect-btn .wallet-connect-label")
            .forEach((span) => (span.textContent = text));
    }

    async function loadOnboard() {
        if (!onboardModule) {
            onboardModule = await import("@lib/onboard");
        }
        return onboardModule.getOnboard();
    }

    function applyState(wallets: any[]) {
        if (wallets.length > 0) {
            const w = wallets[0];
            connectedLabel = w.label;
            const address = w.accounts[0]?.address ?? "";
            setAllLabels(address ? SHORT(address) : connectedLabel ?? tt("wallet_connect"));
        } else {
            connectedLabel = null;
            setAllLabels(tt("wallet_connect"));
        }
    }

    let subscribedToState = false;
    async function ensureStateSubscription() {
        if (subscribedToState) return;
        const onboard = await loadOnboard();
        onboard.state.select("wallets").subscribe(applyState);
        applyState(onboard.state.get().wallets);
        subscribedToState = true;
    }

    async function handleClick() {
        if (loading) return;
        loading = true;

        const buttons = document.querySelectorAll<HTMLButtonElement>(".wallet-connect-btn");
        buttons.forEach((b) => (b.disabled = true));

        try {
            const onboard = await loadOnboard();
            await ensureStateSubscription();

            if (connectedLabel) {
                const confirmed = window.confirm(tt("wallet_disconnect_confirm"));
                if (!confirmed) return;
                await onboard.disconnectWallet({ label: connectedLabel });
                return;
            }

            await onboard.connectWallet();
        } catch (e) {
            console.error("Wallet connect failed:", e);
        } finally {
            buttons.forEach((b) => (b.disabled = false));
            loading = false;
        }
    }

    // Wire up click handlers immediately (lightweight — no onboard import)
    document
        .querySelectorAll<HTMLButtonElement>(".wallet-connect-btn")
        .forEach((btn) => btn.addEventListener("click", handleClick));

    // For returning users: load onboard during browser idle so autoConnect fires.
    // First-time visitors (Lighthouse cold loads): onboard.js never downloads
    // until they actually click Connect.
    function hasPreviousConnection(): boolean {
        try {
            for (let i = 0; i < localStorage.length; i++) {
                const k = localStorage.key(i);
                if (k && k.startsWith("onboard.js:")) return true;
            }
        } catch {}
        return false;
    }

    if (hasPreviousConnection()) {
        const idle = (cb: () => void) =>
            "requestIdleCallback" in window
                ? (window as any).requestIdleCallback(cb, { timeout: 2000 })
                : setTimeout(cb, 200);

        idle(() => {
            ensureStateSubscription().catch(console.error);
        });
    }
</script>