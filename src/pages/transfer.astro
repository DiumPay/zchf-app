---
import Layout from "@layouts/Layout.astro";
import Card from "@components/Card.astro";
import Button from "@components/Button.astro";
import ChainSelector from "@components/ChainSelector.astro";
import ExternalLink from "@components/ExternalLink.astro";
import TransferIcon from "@assets/icons/transfer.svg";
import { t, getLocale, safeJsonForScript } from "@i18n/t";

const tt = t(Astro.url);
const locale = getLocale(Astro.url);

const clientStrings = {
    err_amount: tt("transfer_err_amount"),
    err_balance: tt("transfer_err_balance"),
    err_recipient: tt("transfer_err_recipient"),
    err_no_contract: tt("transfer_err_no_contract"),
    err_not_connected: tt("wallet_not_connected"),
    cancelled: tt("common_cancelled"),
    btn_transferring: tt("transfer_btn_transferring"),
    btn_approving: tt("transfer_btn_approving"),
    toast_done: tt("transfer_toast_done"),
    bridging_yes: tt("bridging_yes"),
    bridging_no: tt("bridging_no"),
    history_empty: tt("transfer_history_empty"),
    history_pending: tt("transfer_history_pending"),
    history_view_tx: tt("transfer_history_view_tx"),
    history_view_msg: tt("transfer_history_view_msg"),
};
---

<Layout title={`${tt("transfer_title")} | Frankencoin dApp`} description="Transfer ZCHF.">
    <main class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-12">
    <header class="mb-8">
    <h1 class="flex items-center gap-3 text-[28px] font-bold tracking-tight">
        <TransferIcon class="h-7 w-7" aria-hidden="true" />
        {tt("transfer_title")}
    </h1>
    <p class="mt-2 text-[14px] opacity-80">
        {tt("transfer_subtitle_prefix")}<a
            href="https://app.transporter.io/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-primary hover:underline"
        >{tt("transfer_subtitle_link")}</a>{tt("transfer_subtitle_suffix")}
    </p>
    </header>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-2">

            <Card title={tt("transfer_params_title")}>
                <div class="flex flex-col gap-5">

                    <div>
                        <div class="mb-2 flex items-center justify-between text-[14px]">
                            <span class="font-bold opacity-70">{tt("transfer_sender_label")}</span>
                            <ChainSelector />
                        </div>
                        <div id="sender-display" class="rounded-md border border-foreground/20 bg-background px-3 py-2.5 font-mono text-[13px] opacity-80">
                            {tt("transfer_sender_disconnected")}
                        </div>
                    </div>

                    <div>
                        <div class="mb-2 flex items-center justify-between text-[14px]">
                            <label for="amount" class="font-bold opacity-70">{tt("transfer_amount_label")}</label>
                            <button id="btn-max" type="button" class="text-primary hover:underline disabled:opacity-50">{tt("transfer_max")}</button>
                        </div>
                        <div class="relative">
                            <input
                                id="amount"
                                type="text"
                                placeholder="0.00"
                                class="w-full rounded-md border border-foreground/20 bg-background px-3 py-2.5 pr-16 text-[15px] font-medium focus:border-foreground/40 focus:outline-none disabled:opacity-50"
                            />
                            <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-[14px] opacity-60">ZCHF</span>
                        </div>
                        <div class="mt-1.5 flex items-center justify-between text-[12px] opacity-70">
                            <span>{tt("transfer_balance")}</span>
                            <span id="balance">—</span>
                        </div>
                    </div>

                    <div>
                        <div class="mb-2 flex items-center justify-between text-[14px]">
                            <span class="font-bold opacity-70">{tt("transfer_recipient_label")}</span>
                            <button id="btn-own" type="button" class="text-primary hover:underline disabled:opacity-50">{tt("transfer_own")}</button>
                        </div>
                        <div class="flex gap-2">
                            <input
                                id="recipient"
                                type="text"
                                placeholder="0x…"
                                class="flex-1 rounded-md border border-foreground/20 bg-background px-3 py-2.5 font-mono text-[13px] focus:border-foreground/40 focus:outline-none"
                            />
                            <select
                                id="target-chain"
                                class="rounded-md border border-foreground/20 bg-background px-3 py-2.5 text-[14px] font-medium focus:border-foreground/40 focus:outline-none"
                            ></select>
                        </div>
                    </div>

                    <div>
                        <label for="reference" class="mb-2 block text-[14px] font-bold opacity-70">{tt("transfer_reference_label")}</label>
                        <input
                            id="reference"
                            type="text"
                            placeholder={tt("transfer_reference_placeholder")}
                            class="w-full rounded-md border border-foreground/20 bg-background px-3 py-2.5 text-[14px] font-medium focus:border-foreground/40 focus:outline-none"
                        />
                    </div>

                    <div id="amount-error" class="hidden text-[13px] text-primary">—</div>

                    <div id="actions-connected" class="hidden">
                        <Button id="btn-transfer" fullWidth>{tt("transfer_btn_transfer")}</Button>
                    </div>
                    <div id="actions-disconnected">
                        <Button id="btn-connect" fullWidth>{tt("wallet_connect")}</Button>
                    </div>
                </div>
            </Card>

            <Card title={tt("transfer_outcome_title")}>
                <div class="flex flex-col gap-5">
                    <div>
                        <div class="mb-3 text-[14px] font-bold opacity-70">{tt("transfer_outcome_section_parties")}</div>
                        <div class="space-y-3">
                            <div class="flex justify-between"><span>{tt("transfer_sender_label")}</span>
                                <ExternalLink id="out-sender" href="#" class="font-mono text-[13px]">—</ExternalLink>
                            </div>
                            <div class="flex justify-between"><span>{tt("transfer_outcome_from")}</span><span id="out-from">—</span></div>
                            <div class="flex justify-between pt-2"><span>{tt("transfer_recipient_label")}</span>
                                <ExternalLink id="out-recipient" href="#" class="font-mono text-[13px]">—</ExternalLink>
                            </div>
                            <div class="flex justify-between"><span>{tt("transfer_outcome_to")}</span><span id="out-to">—</span></div>
                        </div>
                    </div>

                    <div class="border-t border-foreground/10 pt-5">
                        <div class="mb-3 text-[14px] font-bold opacity-70">{tt("transfer_outcome_section_ccip")}</div>
                        <div class="space-y-3">
                            <div class="flex justify-between"><span>{tt("transfer_outcome_bridging")}</span><span id="out-bridging">{tt("bridging_no")}</span></div>
                            <div class="flex justify-between"><span>{tt("transfer_outcome_fee")}</span><span id="out-fee">0</span></div>
                            <div class="flex justify-between"><span>{tt("transfer_outcome_explorer")}</span>
                                <ExternalLink id="out-explorer" href="#">{tt("transfer_check_status")}</ExternalLink>
                            </div>
                        </div>
                    </div>
                </div>
            </Card>
        </div>

        <Card title={tt("transfer_history_title")} class="mt-6">
            <ul id="history-list" class="space-y-3 text-[14px]">
                <li id="history-empty" class="opacity-60">{tt("transfer_history_empty")}</li>
            </ul>
        </Card>
    </main>
</Layout>

<script id="transfer-i18n" type="application/json" set:html={safeJsonForScript(clientStrings)}></script>
<script id="transfer-locale" type="application/json" set:html={safeJsonForScript(locale)}></script>

<script>
    import {
        formatUnits, parseUnits, maxUint256, isAddress,
        type Address, erc20Abi, type Hex,
    } from "viem";
    import { getPublicClient, makeWalletClient } from "@lib/client";
    import { getOnboard } from "@lib/onboard";
    import { toast } from "@lib/toast";
    import { friendlyError } from "@lib/errors";
    import { ADDRESSES } from "@config/addresses";
    import { TRANSFER_REF_ABI } from "@abi/transferReference";
    import { CHAINS, DEFAULT_CHAIN, SUPPORTED_CHAINS, type ChainKey } from "@config/network";
    import { CCIP_SELECTORS, CCIP_EXPLORER } from "@config/ccip";

    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
    const i18n = JSON.parse($("transfer-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("transfer-locale").textContent || '"en"') as string;

    const els = {
        senderDisplay: $("sender-display"),
        amount: $<HTMLInputElement>("amount"),
        balance: $("balance"),
        recipient: $<HTMLInputElement>("recipient"),
        targetChain: $<HTMLSelectElement>("target-chain"),
        reference: $<HTMLInputElement>("reference"),
        amountError: $("amount-error"),
        btnMax: $<HTMLButtonElement>("btn-max"),
        btnOwn: $<HTMLButtonElement>("btn-own"),
        btnTransfer: $<HTMLButtonElement>("btn-transfer"),
        btnConnect: $<HTMLButtonElement>("btn-connect"),
        actionsConnected: $("actions-connected"),
        actionsDisconnected: $("actions-disconnected"),
        outSender: $<HTMLAnchorElement>("out-sender"),
        outFrom: $("out-from"),
        outRecipient: $<HTMLAnchorElement>("out-recipient"),
        outTo: $("out-to"),
        outBridging: $("out-bridging"),
        outFee: $("out-fee"),
        outExplorer: $<HTMLAnchorElement>("out-explorer"),
        historyList: $("history-list"),
        historyEmpty: $("history-empty"),
    };

    // XSS escape for any string that lands in a template-string innerHTML
    const esc = (s: unknown): string =>
    String(s).replace(/[&<>"']/g, c =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

    // Validators for data read from localStorage — a tampered entry must not
    // reach innerHTML or href. Keep these strict.
    const isHashLike = (s: unknown): s is Hex =>
    typeof s === "string" && /^0x[0-9a-fA-F]{64}$/.test(s);
    const isAddrLike = (s: unknown): s is Address =>
    typeof s === "string" && /^0x[0-9a-fA-F]{40}$/.test(s);
    const isChainKey = (s: unknown): s is ChainKey =>
    typeof s === "string" && Object.prototype.hasOwnProperty.call(CHAINS, s);

    let connected: Address | null = null;
    let walletBalRaw = 0n;

    const stored = localStorage.getItem("activeChain") as ChainKey | null;
    let chain: ChainKey = stored && SUPPORTED_CHAINS.includes(stored) ? stored : DEFAULT_CHAIN;

    const isMainnet = () => chain === "ethereum";
    const addrs = () => ADDRESSES[chain];
    const client = () => getPublicClient(chain);

    // 4-arg overloaded transfer used by BridgedFrankencoin on sidechains.
    // Same signature as TransferReference.crossTransfer but the function name is `transfer`.
    const BRIDGED_TRANSFER_ABI = [
        {
            inputs: [
                { internalType: "uint64", name: "targetChain", type: "uint64" },
                { internalType: "address", name: "recipient", type: "address" },
                { internalType: "uint256", name: "amount", type: "uint256" },
                { internalType: "string", name: "ref", type: "string" },
            ],
            name: "transfer",
            outputs: [{ internalType: "bool", name: "", type: "bool" }],
            stateMutability: "payable",
            type: "function",
        },
    ] as const;

    const numberLocale = ({ en: "en-US", de: "de-CH", fr: "fr-CH", it: "it-CH", es: "es-ES" } as Record<string, string>)[locale] ?? "en-US";

    const fmtZCHF = (v: bigint) =>
        `${Number(formatUnits(v, 18)).toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 4 })} ZCHF`;
    const fmtNative = (v: bigint, symbol: string) =>
        `${Number(formatUnits(v, 18)).toLocaleString(numberLocale, { maximumFractionDigits: 6 })} ${symbol}`;
    const shortAddr = (a: string) => `${a.slice(0, 6)}…${a.slice(-4)}`;

    const parseAmount = () => {
        try { return parseUnits(els.amount.value.trim() || "0", 18); }
        catch { return 0n; }
    };

    const getWC = () => {
        const w = getOnboard().state.get().wallets[0];
        if (!w) throw new Error(i18n.err_not_connected);
        return makeWalletClient(w.provider, chain);
    };

    const lockBtn = (btn: HTMLButtonElement, label: string) => {
        const labelEl = btn.querySelector(".btn-label") as HTMLElement;
        const original = labelEl.textContent ?? "";
        btn.dataset.loading = "1";
        btn.disabled = true;
        labelEl.textContent = label;
        return () => {
            delete btn.dataset.loading;
            btn.disabled = false;
            labelEl.textContent = original;
        };
    };

    const showError = (msg: string | null) => {
        els.amountError.classList.toggle("hidden", !msg);
        els.amountError.textContent = msg ?? "";
    };

    function populateTargetChain() {
        els.targetChain.innerHTML = "";
        SUPPORTED_CHAINS.forEach((key) => {
            const opt = document.createElement("option");
            opt.value = key;
            opt.textContent = CHAINS[key].label;
            if (key === chain) opt.selected = true;
            els.targetChain.appendChild(opt);
        });
    }

    async function loadBalance() {
        if (!connected) {
            els.balance.textContent = "—";
            walletBalRaw = 0n;
            return;
        }
        walletBalRaw = await client().readContract({
            address: addrs().zchf, abi: erc20Abi,
            functionName: "balanceOf", args: [connected],
        });
        els.balance.textContent = fmtZCHF(walletBalRaw);
    }

    /**
     * Fee read differs per chain:
     *   - Mainnet: TransferReference.getCCIPFee
     *   - Sidechain: BridgedFrankencoin.getCCIPFee
     * Same signature, different contract address. nativeToken=true → fee in chain gas (ETH/AVAX/etc).
     */
    async function getFee(targetKey: ChainKey, recipient: Address, amount: bigint): Promise<bigint> {
        const contractAddr = isMainnet()
            ? addrs().transferReference!
            : addrs().zchf; // BridgedFrankencoin lives at the ZCHF address on sidechains
        const selector = CCIP_SELECTORS[targetKey]!;
        return await client().readContract({
            address: contractAddr, abi: TRANSFER_REF_ABI,
            functionName: "getCCIPFee",
            args: [selector, recipient, amount, true],
        });
    }

    async function updateOutcome() {
        const targetKey = els.targetChain.value as ChainKey;
        const isCross = targetKey !== chain;
        const rec = els.recipient.value.trim();
        const recValid = rec && isAddress(rec);

        if (connected) {
            els.outSender.firstChild!.textContent = shortAddr(connected);
            els.outSender.href = `${CHAINS[chain].explorer}/address/${connected}`;
            els.outExplorer.href = `${CCIP_EXPLORER}/address/${connected}`;
        } else {
            els.outSender.firstChild!.textContent = "—";
            els.outSender.href = "#";
            els.outExplorer.href = "#";
        }
        els.outFrom.textContent = CHAINS[chain].label;

        if (recValid) {
            els.outRecipient.firstChild!.textContent = shortAddr(rec);
            els.outRecipient.href = `${CHAINS[targetKey].explorer}/address/${rec}`;
        } else {
            els.outRecipient.firstChild!.textContent = "—";
            els.outRecipient.href = "#";
        }
        els.outTo.textContent = CHAINS[targetKey].label;

        els.outBridging.textContent = isCross ? i18n.bridging_yes : i18n.bridging_no;

        if (isCross && connected && recValid && parseAmount() > 0n) {
            try {
                const fee = await getFee(targetKey, rec as Address, parseAmount());
                els.outFee.textContent = fmtNative(fee, CHAINS[chain].token);
            } catch {
                els.outFee.textContent = "—";
            }
        } else {
            els.outFee.textContent = `0 ${CHAINS[chain].token}`;
        }
    }

    /** Mainnet only: approve TransferReference to spend ZCHF. Sidechains don't need this. */
    async function approveIfNeeded(amount: bigint) {
        const contractAddr = addrs().transferReference!;
        const allowance = await client().readContract({
            address: addrs().zchf, abi: erc20Abi,
            functionName: "allowance", args: [connected!, contractAddr],
        });
        if (allowance >= amount) return;

        const unlock = lockBtn(els.btnTransfer, i18n.btn_approving);
        try {
            const hash = await getWC().writeContract({
                address: addrs().zchf, abi: erc20Abi, functionName: "approve",
                args: [contractAddr, maxUint256], account: connected!, chain: null,
            });
            await client().waitForTransactionReceipt({ hash });
        } finally {
            unlock();
        }
    }

    const CCIP_SEND_REQUESTED_TOPIC0 = "0xd0c3c799bf9e2639de44391e7f524d229b2b55f5b1ea94b2bf7da42f7243dddd";

    async function extractMessageId(hash: Hex): Promise<Hex | null> {
        try {
            const receipt = await client().getTransactionReceipt({ hash });
            const log = receipt.logs.find(l => l.topics[0]?.toLowerCase() === CCIP_SEND_REQUESTED_TOPIC0);
            if (!log) return null;
            const data = log.data.slice(2);
            for (let i = 0; i + 64 <= data.length; i += 64) {
                const word = data.slice(i, i + 64);
                if (word === "0".repeat(64)) continue;
                if (word.startsWith("0".repeat(24))) continue;
                if (word.startsWith("0".repeat(48))) continue;
                return ("0x" + word) as Hex;
            }
            return null;
        } catch {
            return null;
        }
    }

    async function doTransfer() {
        if (!connected) throw new Error(i18n.err_not_connected);

        const amount = parseAmount();
        if (amount <= 0n) throw new Error(i18n.err_amount);
        if (amount > walletBalRaw) throw new Error(i18n.err_balance);

        const rec = els.recipient.value.trim();
        if (!isAddress(rec)) throw new Error(i18n.err_recipient);

        const ref = els.reference.value.trim();
        const targetKey = els.targetChain.value as ChainKey;
        const isCross = targetKey !== chain;

        let txHash: Hex;

        if (isMainnet()) {
            // -------- Mainnet path --------
            const contractAddr = addrs().transferReference;
            if (!contractAddr) throw new Error(i18n.err_no_contract);
            await approveIfNeeded(amount);

            if (isCross) {
                const selector = CCIP_SELECTORS[targetKey];
                if (!selector) throw new Error(i18n.err_no_contract);
                const fee = await getFee(targetKey, rec as Address, amount);
                txHash = await getWC().writeContract({
                    address: contractAddr, abi: TRANSFER_REF_ABI,
                    functionName: "crossTransfer",
                    args: [selector, rec as Address, amount, ref],
                    account: connected!, chain: null,
                    value: (fee * 12n) / 10n, // +20% buffer; CCIP refunds the rest
                });
            } else {
                txHash = await getWC().writeContract({
                    address: contractAddr, abi: TRANSFER_REF_ABI,
                    functionName: "transfer",
                    args: [rec as Address, amount, ref],
                    account: connected!, chain: null,
                });
            }
        } else {
            // -------- Sidechain path (BridgedFrankencoin) --------
            // No approve needed: the ZCHF token IS the contract that bridges.
            const zchfAddr = addrs().zchf;

            if (isCross) {
                const selector = CCIP_SELECTORS[targetKey];
                if (!selector) throw new Error(i18n.err_no_contract);
                const fee = await getFee(targetKey, rec as Address, amount);
                txHash = await getWC().writeContract({
                    address: zchfAddr, abi: BRIDGED_TRANSFER_ABI,
                    functionName: "transfer",
                    args: [selector, rec as Address, amount, ref],
                    account: connected!, chain: null,
                    value: (fee * 12n) / 10n,
                });
            } else {
                // Same-chain transfer with reference: 3-arg overload on BridgedFrankencoin
                txHash = await getWC().writeContract({
                    address: zchfAddr, abi: TRANSFER_REF_ABI,
                    functionName: "transfer",
                    args: [rec as Address, amount, ref],
                    account: connected!, chain: null,
                });
            }
        }

        await client().waitForTransactionReceipt({ hash: txHash });

        const messageId = isCross ? await extractMessageId(txHash).catch(() => null) : null;
        addHistoryEntry({
            txHash, messageId, fromChain: chain, toChain: targetKey,
            recipient: rec as Address, amount: amount.toString(), ref, ts: Date.now(),
        });

        toast(i18n.toast_done, "success");
        els.amount.value = "";
        showError(null);
        await loadBalance();
        await updateOutcome();
    }

    async function runTransfer() {
        const unlock = lockBtn(els.btnTransfer, i18n.btn_transferring);
        try { await doTransfer(); }
        catch (e) {
            const { message, isUserCancel } = friendlyError(e);
            toast(isUserCancel ? i18n.cancelled : message, isUserCancel ? "info" : "error", isUserCancel ? 2500 : 6500);
        }
        finally { unlock(); }
    }

    // ----------- History (localStorage, last 10) -----------

    interface HistoryEntry {
        txHash: Hex;
        messageId: Hex | null;
        fromChain: ChainKey;
        toChain: ChainKey;
        recipient: Address;
        amount: string;
        ref: string;
        ts: number;
    }

    const HISTORY_KEY = "transferHistory";
    const HISTORY_MAX = 10;

    const readHistory = (): HistoryEntry[] => {
    try {
        const raw = JSON.parse(localStorage.getItem(HISTORY_KEY) || "[]");
        if (!Array.isArray(raw)) return [];
        return raw.filter((e: any): e is HistoryEntry =>
            e && typeof e === "object" &&
            isHashLike(e.txHash) &&
            (e.messageId === null || isHashLike(e.messageId)) &&
            isChainKey(e.fromChain) &&
            isChainKey(e.toChain) &&
            isAddrLike(e.recipient) &&
            typeof e.amount === "string" && /^\d+$/.test(e.amount) &&
            typeof e.ref === "string" &&
            typeof e.ts === "number" && Number.isFinite(e.ts)
        );
    } catch { return []; }
    };

    const writeHistory = (entries: HistoryEntry[]) => {
        localStorage.setItem(HISTORY_KEY, JSON.stringify(entries.slice(0, HISTORY_MAX)));
    };

    function addHistoryEntry(entry: HistoryEntry) {
        const all = readHistory();
        all.unshift(entry);
        writeHistory(all);
        renderHistory();
    }

    function renderHistory() {
        const entries = readHistory();
        if (entries.length === 0) {
            els.historyList.innerHTML = `<li class="opacity-60">${i18n.history_empty}</li>`;
            return;
        }
        els.historyList.innerHTML = entries.map(e => {
            const fromLabel = CHAINS[e.fromChain].label;
            const toLabel = CHAINS[e.toChain].label;
            const isCross = e.fromChain !== e.toChain;
            const arrow = isCross ? `${fromLabel} → ${toLabel}` : fromLabel;
            const amount = fmtZCHF(BigInt(e.amount));
            const dt = new Date(e.ts).toLocaleString(numberLocale, {
                month: "short", day: "numeric", hour: "2-digit", minute: "2-digit",
            });
            const txUrl = `${CHAINS[e.fromChain].explorer}/tx/${e.txHash}`;
            const msgUrl = e.messageId ? `${CCIP_EXPLORER}/msg/${e.messageId}` : null;
            const refStr = e.ref ? ` · <span class="opacity-70">${esc(e.ref)}</span>` : "";

            return `<li class="flex flex-wrap items-center justify-between gap-x-4 gap-y-1 border-b border-foreground/10 pb-3 last:border-0 last:pb-0">
                <div>
                    <div class="font-medium">${amount} <span class="opacity-60 text-[12px]">${arrow}</span></div>
                    <div class="text-[12px] opacity-70">${dt} · → ${shortAddr(e.recipient)}${refStr}</div>
                </div>
                <div class="flex gap-3 text-[13px]">
                    <a href="${txUrl}" target="_blank" rel="noopener" class="text-primary hover:underline">${i18n.history_view_tx}</a>
                    ${msgUrl ? `<a href="${msgUrl}" target="_blank" rel="noopener" class="text-primary hover:underline">${i18n.history_view_msg}</a>` : ""}
                </div>
            </li>`;
        }).join("");
    }

    // ----------- Wire up -----------

    function setConnectedUI(isConnected: boolean) {
        els.actionsConnected.classList.toggle("hidden", !isConnected);
        els.actionsDisconnected.classList.toggle("hidden", isConnected);
        els.amount.disabled = !isConnected;
        els.recipient.disabled = !isConnected;
        els.reference.disabled = !isConnected;
        els.targetChain.disabled = !isConnected;
        els.btnMax.disabled = !isConnected;
        els.btnOwn.disabled = !isConnected;
    }

    els.btnConnect.addEventListener("click", () => { getOnboard().connectWallet(); });
    els.btnTransfer.addEventListener("click", runTransfer);
    els.btnMax.addEventListener("click", () => { els.amount.value = formatUnits(walletBalRaw, 18); updateOutcome(); });
    els.btnOwn.addEventListener("click", () => { if (connected) { els.recipient.value = connected; updateOutcome(); }});
    els.amount.addEventListener("input", updateOutcome);
    els.recipient.addEventListener("input", updateOutcome);
    els.targetChain.addEventListener("change", updateOutcome);

    window.addEventListener("chainchange", (e) => {
        const next = (e as CustomEvent<{ chain: ChainKey }>).detail.chain;
        if (next === chain) return;
        chain = next;
        populateTargetChain();
        loadBalance().catch(() => {});
        updateOutcome();
    });

    getOnboard().state.select("wallets").subscribe((wallets) => {
        const w = wallets[0];
        if (w?.accounts[0]) {
            connected = w.accounts[0].address as Address;
            els.senderDisplay.textContent = connected;
            setConnectedUI(true);
            loadBalance().catch(() => {});
        } else {
            connected = null;
            els.senderDisplay.textContent = i18n.err_not_connected;
            walletBalRaw = 0n;
            els.balance.textContent = "—";
            setConnectedUI(false);
        }
        updateOutcome();
    });

    setConnectedUI(false);
    populateTargetChain();
    renderHistory();
    updateOutcome();
</script>