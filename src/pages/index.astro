---
import Layout from "@layouts/Layout.astro";
import Card from "@components/Card.astro";
import Button from "@components/Button.astro";
import SortIcon from "@assets/icons/arrow-down-narrow-wide.svg";
import { t, getLocale, localePath, safeJsonForScript } from "@i18n/t";

import bossIcon from "@assets/tokens/boss.svg?url";
import cbbtcIcon from "@assets/tokens/cbbtc.svg?url";
import chfauIcon from "@assets/tokens/chfau.svg?url";
import crvIcon from "@assets/tokens/crv.svg?url";
import gnoIcon from "@assets/tokens/gno.svg?url";
import lendsIcon from "@assets/tokens/lends.svg?url";
import lsethIcon from "@assets/tokens/lseth.svg?url";
import paxgIcon from "@assets/tokens/paxg.svg?url";
import realuIcon from "@assets/tokens/realu.svg?url";
import spyonIcon from "@assets/tokens/spyon.svg?url";
import wbtcIcon from "@assets/tokens/wbtc.svg?url";
import wethIcon from "@assets/tokens/weth.svg?url";
import wstethIcon from "@assets/tokens/wsteth.svg?url";
import xautIcon from "@assets/tokens/xaut.svg?url";
import ysyboldIcon from "@assets/tokens/ysybold.svg?url";
import unknownIcon from "@assets/icons/unknown.svg?url";

const TOKEN_ICONS: Record<string, string> = {
    boss: bossIcon,
    cbbtc: cbbtcIcon,
    chfau: chfauIcon,
    crv: crvIcon,
    gno: gnoIcon,
    lends: lendsIcon,
    lseth: lsethIcon,
    paxg: paxgIcon,
    realu: realuIcon,
    spyon: spyonIcon,
    wbtc: wbtcIcon,
    weth: wethIcon,
    wsteth: wstethIcon,
    xaut: xautIcon,
    ysybold: ysyboldIcon,
};

// Special key — picked up by the client when a position's symbol isn't in
// the icon map. Lives in the same dictionary so the script doesn't need a
// separate import path.
const UNKNOWN_ICON = unknownIcon;

const tt = t(Astro.url);
const locale = getLocale(Astro.url);
---

<Layout title={`Borrow ZCHF Against Crypto Collateral | Frankencoin dApp`} description="Borrow decentralized Swiss francs (ZCHF) securely with crypto collateral. Mint ZCHF stablecoins against ETH, wBTC, and more with transparent rates and no intermediaries.">
    <main class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-12">
        <header class="mb-8">
            <h1 class="text-[28px] font-bold tracking-tight">{tt("borrow_title")}</h1>
            <p class="mt-2 text-[14px] opacity-80">{tt("borrow_subtitle")}</p>
        </header>

        <div class="mb-8 grid grid-cols-1 gap-4 md:grid-cols-3">
            <div class="rounded-md border border-foreground/10 bg-background p-5">
                <div class="mb-2 flex items-center gap-3">
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-foreground/10 text-[14px] font-bold">1</span>
                    <h2 class="text-[16px] font-bold">{tt("borrow_step1_title")}</h2>
                </div>
                <p class="text-[14px] opacity-80">{tt("borrow_step1_text")}</p>
            </div>
            <div class="rounded-md border border-foreground/10 bg-background p-5">
                <div class="mb-2 flex items-center gap-3">
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-foreground/10 text-[14px] font-bold">2</span>
                    <h2 class="text-[16px] font-bold">{tt("borrow_step2_title")}</h2>
                </div>
                <p class="text-[14px] opacity-80">{tt("borrow_step2_text")}</p>
            </div>
            <div class="rounded-md border border-foreground/10 bg-background p-5">
                <div class="mb-2 flex items-center gap-3">
                    <span class="flex h-7 w-7 items-center justify-center rounded-full bg-foreground/10 text-[14px] font-bold">3</span>
                    <h2 class="text-[16px] font-bold">{tt("borrow_step3_title")}</h2>
                </div>
                <p class="text-[14px] opacity-80">{tt("borrow_step3_text")}</p>
            </div>
        </div>

        <Card title={tt("borrow_table_title")}>
            <div
                data-token-icons={JSON.stringify(TOKEN_ICONS)}
                data-unknown-icon={UNKNOWN_ICON}
                class="hidden"
            ></div>

            <div class="mb-5 flex items-center gap-3">
                <label for="search-input" class="sr-only">{tt("borrow_search_placeholder")}</label>
                <input
                    id="search-input"
                    type="text"
                    placeholder={tt("borrow_search_placeholder")}
                    class="flex-1 rounded-md border border-foreground/20 bg-background px-3 py-2 text-[14px] focus:border-foreground/40 focus:outline-none"
                />
            </div>

            <div class="hidden grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] gap-4 border-b border-foreground/10 pb-3 text-[13px] font-bold opacity-70 md:grid">
                <button type="button" data-sort="name" class="sort-btn flex items-center gap-1.5 text-left" aria-label={`Sort by ${tt("borrow_col_collateral")}`}>
                    <span>{tt("borrow_col_collateral")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="ltv" class="sort-btn flex items-center gap-1.5 text-left" aria-label="Sort by LTV">
                    <span>LTV</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="liquidation" class="sort-btn flex items-center gap-1.5 text-left" aria-label={`Sort by ${tt("borrow_col_liquidation")}`}>
                    <span>{tt("borrow_col_liquidation")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="interest" class="sort-btn flex items-center gap-1.5 text-left" aria-label={`Sort by ${tt("borrow_col_interest")}`}>
                    <span>{tt("borrow_col_interest")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="maturity" class="sort-btn flex items-center gap-1.5 text-left" aria-label={`Sort by ${tt("borrow_col_maturity")}`}>
                    <span>{tt("borrow_col_maturity")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <span class="w-24"></span>
            </div>

            <ul id="positions-list" class="divide-y divide-foreground/10">
                <li id="positions-loading" class="py-6 text-center text-[14px] opacity-60">
                    {tt("borrow_loading")}
                </li>
            </ul>

            <p id="positions-empty" class="hidden py-6 text-center text-[14px] opacity-60">
                {tt("borrow_empty")}
            </p>

            <div class="mt-6 flex justify-center border-t border-foreground/10 pt-6">
                <a href={localePath(locale, "/mint/create")} class="inline-block">
                    <Button variant="secondary">
                        {tt("borrow_propose_new")}
                    </Button>
                </a>
            </div>
        </Card>
    </main>
</Layout>

<style>
    .sort-btn {
        cursor: pointer;
        user-select: none;
    }
    .sort-icon {
        display: none;
    }
    .sort-btn[data-direction] .sort-icon {
        display: inline-block;
    }
    .sort-btn[data-direction="desc"] .sort-icon {
        transform: rotate(180deg);
    }
</style>

<script id="borrow-locale" type="application/json" set:html={safeJsonForScript(getLocale(Astro.url))}></script>
<script id="borrow-i18n" type="application/json" set:html={safeJsonForScript({
    btn_borrow: tt("borrow_btn_borrow"),
    btn_swap: tt("borrow_btn_swap") || "Swap",
    swap_row_name: tt("borrow_swap_row_name") || "AllUnity Swiss Franc",
    swap_row_liq: tt("borrow_swap_row_liq") || "Swap 1:1",
    status_active: tt("borrow_status_active"),
    status_cooldown: tt("borrow_status_cooldown"),
    status_challenged: tt("borrow_status_challenged"),
    status_closed: tt("borrow_status_closed"),
    status_expired: tt("borrow_status_expired"),
    empty: tt("borrow_empty"),
    error: tt("borrow_error"),
})}></script>

<script>
    // Boot imports — kept lean. viem / contract ABIs are loaded lazily in
    // loadBridgeHorizon() so they don't bloat the borrow-page main chunk.
    import { loadPositionsCached, liquidationPriceUnits, positionStatus, effectiveInterestPPM, type Position } from "@lib/positions";
    import { getMarketPriceCHF } from "@lib/prices";
    import { localePath } from "@i18n/t";
    import type { Locale } from "@i18n/messages";

    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

    const i18n = JSON.parse($("borrow-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("borrow-locale").textContent || '"en"') as string;

    const iconHost = document.querySelector<HTMLElement>("[data-token-icons]")!;
    const tokenIcons = JSON.parse(iconHost.dataset.tokenIcons || "{}") as Record<string, string>;
    const unknownIconUrl = iconHost.dataset.unknownIcon || "";

    // escape — collateral name/symbol come from snapshot today but flow
    // through localStorage cache, so treat them as untrusted on render.
    const esc = (s: unknown): string =>
        String(s).replace(/[&<>"']/g, c =>
            ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

    // Address validator — defense in depth against tampered cache.
    const isAddrLike = (s: unknown): s is string =>
        typeof s === "string" && /^0x[0-9a-fA-F]{40}$/.test(s);

    const numberLocale = ({ en: "en-US", de: "de-CH", fr: "fr-CH", it: "it-CH", es: "es-ES" } as Record<string, string>)[locale] ?? "en-US";

    const list = $<HTMLUListElement>("positions-list");
    const loading = $("positions-loading");
    const empty = $("positions-empty");
    const search = $<HTMLInputElement>("search-input");

    let allPositions: Position[] = [];

    // Bridge horizon — populated async after mount. We pre-render the row
    // with a placeholder so users see it instantly; the maturity column
    // updates in place once the contract read returns.
    let bridgeHorizon: number | null = null;

    const priceMap: Record<string, number | null | undefined> = {};

    type SortKey = "name" | "ltv" | "liquidation" | "interest" | "maturity";
    type SortDir = "asc" | "desc";
    let sortKey: SortKey = "name";
    let sortDir: SortDir = "asc";

    const fmtZCHF = (n: number) => n.toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 4 });
    const fmtPct = (ppm: number) => `${(ppm / 10_000).toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}%`;
    const fmtDate = (ts: number) => new Date(ts * 1000).toLocaleDateString(numberLocale, { day: "2-digit", month: "short", year: "numeric" });

    const STATUS_LABEL: Record<ReturnType<typeof positionStatus>, string> = {
        active: i18n.status_active,
        cooldown: i18n.status_cooldown,
        challenged: i18n.status_challenged,
        closed: i18n.status_closed,
        expired: i18n.status_expired,
    };

    const STATUS_CLASS: Record<ReturnType<typeof positionStatus>, string> = {
        active: "bg-foreground/10",
        cooldown: "bg-foreground/15",
        challenged: "bg-primary/15 text-primary",
        closed: "bg-foreground/15 opacity-60",
        expired: "bg-foreground/15 opacity-60",
    };

    function iconFor(symbol: string): string {
        return tokenIcons[symbol.toLowerCase()] ?? unknownIconUrl;
    }

    /**
     * Renders the CHFAU swap row that lives above the curated position list.
     * Not a real position — clicking the button routes to /swap instead of /mint.
     * Maturity comes from the bridge's `horizon` field; until that read returns
     * we show a — placeholder.
     */
    function swapRowHtml(): string {
        const icon = iconFor("chfau");
        const maturity = bridgeHorizon !== null ? fmtDate(bridgeHorizon) : "—";
        return `<li class="grid grid-cols-1 gap-3 py-4 md:grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] md:items-center md:gap-4">
            <div class="flex items-center gap-3">
                <img src="${icon}" alt="" class="h-9 w-9 shrink-0 rounded-full" />
                <div>
                    <div class="font-bold text-[15px]">${esc(i18n.swap_row_name)}</div>
                    <div class="text-[12px] opacity-70">
                        <span class="inline-block rounded px-1.5 py-0.5 text-[11px] font-medium bg-foreground/10">${STATUS_LABEL.active}</span>
                        <span class="ml-2">CHFAU</span>
                    </div>
                </div>
            </div>

            <div class="text-[14px]">
                <span class="md:hidden opacity-60">LTV: </span>
                <span class="opacity-80">N/A</span>
            </div>

            <div class="text-[14px]">
                <span class="md:hidden opacity-60">Liquidation: </span>
                <span class="opacity-80">${esc(i18n.swap_row_liq)}</span>
            </div>

            <div class="text-[14px]">
                <span class="md:hidden opacity-60">Interest: </span>
                0.00%
            </div>

            <div class="text-[14px]">
                <span class="md:hidden opacity-60">Maturity: </span>
                ${maturity}
            </div>

            <div>
                <button
                    type="button"
                    data-swap-row="1"
                    class="relative inline-flex w-full items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2 text-[14px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover dark:text-[#030303] md:w-auto"
                >
                    ${esc(i18n.btn_swap)}
                </button>
            </div>
        </li>`;
    }

    function ltvValue(p: Position): number | null {
        const sym = p.collateralSymbol.toUpperCase();
        const market = priceMap[sym];
        if (market === undefined || market === null || market === 0) return null;
        return (liquidationPriceUnits(p) / market) * 100;
    }

    function ltvCell(p: Position): string {
        const sym = p.collateralSymbol.toUpperCase();
        const market = priceMap[sym];
        if (market === undefined) return `<span class="opacity-80">…</span>`;
        if (market === null) return `<span class="opacity-80">N/A</span>`;
        const ltv = (liquidationPriceUnits(p) / market) * 100;
        return `${ltv.toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}%`;
    }

    function sortValue(p: Position, key: SortKey): number | string {
        switch (key) {
            case "name": return p.collateralName.toLowerCase();
            case "ltv": {
                const v = ltvValue(p);
                return v === null ? Number.POSITIVE_INFINITY : v;
            }
            case "liquidation": return liquidationPriceUnits(p);
            case "interest": return effectiveInterestPPM(p);
            case "maturity": return p.expiration;
        }
    }

    function sorted(positions: Position[]): Position[] {
        const out = positions.slice();
        out.sort((a, b) => {
            const va = sortValue(a, sortKey);
            const vb = sortValue(b, sortKey);
            let cmp: number;
            if (typeof va === "string" && typeof vb === "string") {
                cmp = va.localeCompare(vb);
            } else {
                cmp = (va as number) - (vb as number);
            }
            return sortDir === "asc" ? cmp : -cmp;
        });
        return out;
    }

    function syncSortIndicators() {
        document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
            if (btn.dataset.sort === sortKey) {
                btn.dataset.direction = sortDir;
            } else {
                delete btn.dataset.direction;
            }
        });
    }

    function shouldShowSwapRow(): boolean {
        const q = search.value.trim().toLowerCase();
        if (!q) return true;
        return i18n.swap_row_name.toLowerCase().includes(q) || "chfau".includes(q);
    }

    function render(positions: Position[]) {
        const showSwap = shouldShowSwapRow();

        if (positions.length === 0 && !showSwap) {
            list.innerHTML = "";
            empty.classList.remove("hidden");
            return;
        }
        empty.classList.add("hidden");

        const positionRows = positions.map(p => {
            // Defense in depth: skip rows with malformed addresses that would
            // otherwise break out of the data-position attribute.
            if (!isAddrLike(p.address)) return "";

            const status = positionStatus(p);
            const liqPrice = liquidationPriceUnits(p);
            const isActive = status === "active";
            const icon = iconFor(p.collateralSymbol);

            const iconHtml = `<img src="${icon}" alt="" class="h-9 w-9 shrink-0 rounded-full" />`;

            return `<li class="grid grid-cols-1 gap-3 py-4 md:grid-cols-[2fr_1fr_1fr_1fr_1fr_auto] md:items-center md:gap-4">
                <div class="flex items-center gap-3">
                    ${iconHtml}
                    <div>
                        <div class="font-bold text-[15px]">${esc(p.collateralName)}</div>
                        <div class="text-[12px] opacity-70">
                            <span class="inline-block rounded px-1.5 py-0.5 text-[11px] font-medium ${STATUS_CLASS[status]}">${STATUS_LABEL[status]}</span>
                            <span class="ml-2">${esc(p.collateralSymbol)}</span>
                        </div>
                    </div>
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">LTV: </span>
                    ${ltvCell(p)}
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Liquidation: </span>
                    ${fmtZCHF(liqPrice)} ZCHF
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Interest: </span>
                    ${fmtPct(effectiveInterestPPM(p))}
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Maturity: </span>
                    ${fmtDate(p.expiration)}
                </div>

                <div>
                    <button
                        type="button"
                        data-position="${p.address}"
                        ${isActive ? "" : "disabled"}
                        class="relative inline-flex w-full items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2 text-[14px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover disabled:cursor-not-allowed disabled:opacity-50 dark:text-[#030303] md:w-auto"
                    >
                        ${i18n.btn_borrow}
                    </button>
                </div>
            </li>`;
        }).join("");

        list.innerHTML = (showSwap ? swapRowHtml() : "") + positionRows;

        list.querySelectorAll<HTMLButtonElement>("[data-position]").forEach(btn => {
            btn.addEventListener("click", () => {
                const addr = btn.dataset.position;
                if (!isAddrLike(addr)) return; // belt and suspenders
                window.location.href = localePath(locale as Locale, `/mint?address=${addr}`);
            });
        });

        list.querySelectorAll<HTMLButtonElement>("[data-swap-row]").forEach(btn => {
            btn.addEventListener("click", () => {
                window.location.href = localePath(locale as Locale, "/swap");
            });
        });
    }

    function applyFilter() {
        const q = search.value.trim().toLowerCase();
        const base = q
            ? allPositions.filter(p =>
                p.collateralName.toLowerCase().includes(q) ||
                p.collateralSymbol.toLowerCase().includes(q))
            : allPositions;
        render(sorted(base));
    }

    async function loadPrices() {
        const symbols = Array.from(new Set(allPositions.map(p => p.collateralSymbol.toUpperCase())));
        await Promise.all(symbols.map(async sym => {
            try {
                priceMap[sym] = await getMarketPriceCHF(sym);
            } catch {
                priceMap[sym] = null;
            }
        }));
        applyFilter();
    }

    /**
     * Reads the CHFAU bridge `horizon()` to fill in the swap row's maturity
     * date. Dynamically imports viem + ABI so they stay out of the borrow
     * page's main chunk — the only thing on this page that needs them.
     */
    async function loadBridgeHorizon() {
        try {
            const [
                { getPublicClient },
                { STABLECOIN_BRIDGE_ABI },
                { ADDRESSES },
            ] = await Promise.all([
                import("@lib/client"),
                import("@abi/stablecoinBridge"),
                import("@config/addresses"),
            ]);
            const bridge = ADDRESSES.ethereum.chfauBridge;
            if (!bridge) return;
            const client = getPublicClient("ethereum");
            const h = await client.readContract({
                address: bridge,
                abi: STABLECOIN_BRIDGE_ABI,
                functionName: "horizon",
            }) as bigint;
            bridgeHorizon = Number(h);
            applyFilter();
        } catch (err) {
            console.warn("[index] bridge horizon read failed", err);
        }
    }

    document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const key = btn.dataset.sort as SortKey;
            if (sortKey === key) {
                sortDir = sortDir === "asc" ? "desc" : "asc";
            } else {
                sortKey = key;
                sortDir = "asc";
            }
            syncSortIndicators();
            applyFilter();
        });
    });

    search.addEventListener("input", applyFilter);

    // Defer secondary work past first paint so it doesn't compete with LCP.
    const idle = (cb: () => void) =>
        "requestIdleCallback" in window
            ? (window as any).requestIdleCallback(cb, { timeout: 2000 })
            : setTimeout(cb, 200);

    loadPositionsCached()
        .then(positions => {
            allPositions = positions;
            loading.remove();
            syncSortIndicators();
            applyFilter();
            // Secondary work — push past LCP. Prices and the bridge horizon
            // are decorative on first paint (cells show "…" / "—" until then).
            idle(() => loadPrices());
            idle(() => loadBridgeHorizon());
        })
        .catch(err => {
            console.error(err);
            loading.textContent = i18n.error;
        });
</script>