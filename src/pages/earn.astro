---
import Layout from "@layouts/Layout.astro";
import Card from "@components/Card.astro";
import Button from "@components/Button.astro";
import ChainSelector from "@components/ChainSelector.astro";
import PiggyBank from "@assets/icons/piggy-bank.svg";
import Deposit from "@assets/icons/deposit.svg";
import Withdraw from "@assets/icons/withdraw.svg";
import Compound from "@assets/icons/compound.svg";
import { t, getLocale, safeJsonForScript } from "@i18n/t";

const tt = t(Astro.url);
const locale = getLocale(Astro.url);

const clientStrings = {
    err_amount: tt("earn_err_amount"),
    err_wallet_too_low: tt("earn_err_wallet_too_low"),
    err_saved_too_low: tt("earn_err_saved_too_low"),
    err_target: tt("earn_err_target"),
    err_not_connected: tt("wallet_not_connected"),
    cancelled: tt("common_cancelled"),
    btn_depositing: tt("earn_btn_depositing"),
    btn_withdrawing: tt("earn_btn_withdrawing"),
    btn_compounding: tt("earn_btn_compounding"),
    toast_deposit_done: tt("earn_toast_deposit_done"),
    toast_withdraw_done: tt("earn_toast_withdraw_done"),
    toast_compound_done: tt("earn_toast_compound_done"),
    status_locked: tt("earn_status_locked"),
    status_withdrawable: tt("earn_status_withdrawable"),
    status_earning: tt("status_earning"),
    status_starts_in: tt("status_starts_in"),
    unit_day: tt("unit_day"),
    unit_hour: tt("unit_hour"),
    unit_min: tt("unit_min"),
    yearly_empty: tt("earn_yearly_empty"),
};
---

<Layout title={`${tt("earn_title")} | Frankencoin dApp`} description="Earn ZCHF.">
    <main class="mx-auto max-w-5xl px-4 py-10 md:px-6 md:py-12">
        <div class="mb-8 flex items-center justify-between gap-4">
            <h1 class="flex items-center gap-3 text-[28px] font-bold tracking-tight">
                <PiggyBank class="h-7 w-7" aria-hidden="true" />
                {tt("earn_title")}
            </h1>
            <p class="mt-2 text-[14px] opacity-80">
              {tt("earn_subtitle")}
            </p>
        </div>

        <div class="flex flex-col gap-6">
            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <Card title={tt("earn_rate_title")}>
                    <div class="mb-2 text-[28px] font-bold leading-none">
                        <span id="rate">—</span>
                    </div>
                    <div class="text-[14px] font-normal opacity-80">
                        {tt("earn_rate_caption")}
                    </div>
                </Card>

                <Card title={tt("earn_tvl_title")}>
                    <div class="mb-2 text-[28px] font-bold leading-none">
                        <span id="tvl">—</span>
                    </div>
                    <div class="text-[14px] font-normal opacity-80">
                        {tt("earn_tvl_caption")}
                    </div>
                </Card>
            </div>

            <Card title={tt("earn_manage_title")}>
                    <ChainSelector slot="actions" />
                <div class="grid grid-cols-1 gap-12 md:grid-cols-2">
                    <div>
                        <div class="mb-3 text-[14px] font-bold opacity-70">{tt("earn_balances_heading")}</div>
                        <div class="space-y-3">
                            <div class="flex justify-between"><span>{tt("earn_balance_wallet")}</span><span id="wallet-balance">—</span></div>
                            <div class="flex justify-between"><span>{tt("earn_balance_saved")}</span><span id="saved">—</span></div>
                            <div class="flex justify-between"><span>{tt("earn_balance_accrued")}</span><span id="accrued">—</span></div>
                            <div class="flex justify-between border-t border-foreground/10 pt-3"><span class="font-bold">{tt("earn_balance_total")}</span><span id="total" class="font-bold">—</span></div>
                            <div class="flex justify-between pt-1"><span>{tt("earn_balance_interest_status")}</span><span id="locked">—</span></div>
                        </div>
                    </div>

                    <div class="flex flex-col gap-6">
                        <div>
                            <div class="mb-2 flex items-center justify-between text-[14px]">
                                <label for="amount" class="font-bold opacity-70">{tt("earn_amount_label")}</label>
                                <div class="flex gap-3">
                                    <button id="btn-max-wallet" type="button" class="text-primary hover:underline disabled:opacity-50">{tt("earn_max_wallet")}</button>
                                    <span class="opacity-30">·</span>
                                    <button id="btn-max-saved" type="button" class="text-primary hover:underline disabled:opacity-50">{tt("earn_max_saved")}</button>
                                </div>
                            </div>
                            <div class="relative">
                                <input
                                    id="amount"
                                    type="text"
                                    placeholder="0.00"
                                    class="w-full rounded-md border border-foreground/20 bg-background px-3 py-2.5 pr-16 text-[15px] font-medium focus:border-foreground/40 focus:outline-none disabled:opacity-50"
                                />
                                <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-[14px] opacity-60">ZCHF</span>
                            </div>
                            <div id="amount-error" class="mt-2 hidden text-[13px] text-primary">—</div>
                        </div>

                        <div>
                            <label class="flex cursor-pointer items-center gap-2 text-[14px]">
                                <input id="toggle-onbehalf" type="checkbox" class="h-4 w-4" />
                                <span>{tt("earn_recipient_toggle")}</span>
                            </label>
                            <div id="onbehalf-row" class="mt-3 hidden">
                                <input
                                    id="target-address"
                                    type="text"
                                    placeholder={tt("earn_recipient_placeholder")}
                                    class="w-full rounded-md border border-foreground/20 bg-background px-3 py-2.5 text-[14px] font-medium focus:border-foreground/40 focus:outline-none"
                                />
                            </div>
                        </div>

                        <div id="actions-connected" class="hidden space-y-3">
                            <div class="flex gap-3">
                                <Button id="btn-save" fullWidth>
                                    <Deposit class="h-4 w-4" aria-hidden="true" />
                                    {tt("earn_btn_deposit")}
                                </Button>
                                <Button id="btn-withdraw" variant="secondary" fullWidth>
                                    <Withdraw class="h-4 w-4" aria-hidden="true" />
                                    {tt("earn_btn_withdraw")}
                                </Button>
                            </div>
                            <Button id="btn-compound" variant="secondary" fullWidth>
                                <Compound class="h-4 w-4" aria-hidden="true" />
                                {tt("earn_btn_compound")}
                            </Button>
                        </div>

                        <div id="actions-disconnected">
                            <Button id="btn-connect" fullWidth>
                                {tt("wallet_connect")}
                            </Button>
                        </div>

                        <p class="text-[13px] leading-relaxed opacity-70">
                            {tt("earn_footnote")}
                        </p>
                    </div>
                </div>
            </Card>

            <!-- Yearly Accounts (projected) -->
            <Card title={tt("earn_yearly_title")}>
                <p class="mb-4 text-[13px] opacity-70">{tt("earn_yearly_subtitle")}</p>

                <div class="hidden grid-cols-[1fr_1.5fr_1.5fr] gap-4 border-b border-foreground/10 pb-3 text-[13px] font-bold opacity-70 md:grid">
                    <span>{tt("earn_yearly_col_year")}</span>
                    <span class="text-right">{tt("earn_yearly_col_interest")}</span>
                    <span class="text-right">{tt("earn_yearly_col_end_balance")}</span>
                </div>

                <ul id="yearly-list" class="divide-y divide-foreground/10"></ul>

                <p id="yearly-empty" class="py-6 text-center text-[14px] opacity-60">
                    {tt("earn_yearly_empty")}
                </p>
            </Card>
        </div>
    </main>
</Layout>

<script id="earn-i18n" type="application/json" set:html={safeJsonForScript(clientStrings)}></script>
<script id="earn-locale" type="application/json" set:html={safeJsonForScript(locale)}></script>

<script>
    import { formatUnits, parseUnits, maxUint256, isAddress, type Address, erc20Abi } from "viem";
    import { getPublicClient, makeWalletClient } from "@lib/client";
    import { getOnboard } from "@lib/onboard";
    import { toast } from "@lib/toast";
    import { friendlyError } from "@lib/errors";
    import { ADDRESSES } from "@config/addresses";
    import { SAVINGS_ABI } from "@abi/savings";
    import { CHAINS, DEFAULT_CHAIN, SUPPORTED_CHAINS, type ChainKey } from "@config/network";

    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

    const i18n = JSON.parse($("earn-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("earn-locale").textContent || '"en"') as string;

    const els = {
        rate: $("rate"), tvl: $("tvl"), saved: $("saved"), accrued: $("accrued"),
        walletBalance: $("wallet-balance"), total: $("total"), locked: $("locked"),
        amount: $<HTMLInputElement>("amount"), amountError: $("amount-error"),
        toggleOnBehalf: $<HTMLInputElement>("toggle-onbehalf"),
        onBehalfRow: $("onbehalf-row"), targetAddress: $<HTMLInputElement>("target-address"),
        actionsConnected: $("actions-connected"),
        actionsDisconnected: $("actions-disconnected"),
        btnSave: $<HTMLButtonElement>("btn-save"),
        btnWithdraw: $<HTMLButtonElement>("btn-withdraw"),
        btnCompound: $<HTMLButtonElement>("btn-compound"),
        btnConnect: $<HTMLButtonElement>("btn-connect"),
        btnMaxWallet: $<HTMLButtonElement>("btn-max-wallet"),
        btnMaxSaved: $<HTMLButtonElement>("btn-max-saved"),
        yearlyList: $<HTMLUListElement>("yearly-list"),
        yearlyEmpty: $("yearly-empty"),
    };

    let connected: Address | null = null;
    let walletBalRaw = 0n, savedRaw = 0n, accruedRaw = 0n;
    let ratePPM = 0;             // Captured from loadModule; used by yearly projection.
    let lastIntent: "deposit" | "withdraw" = "deposit";

    // Active chain — initialised from localStorage (set by ChainSelector), default Ethereum
    const stored = localStorage.getItem("activeChain") as ChainKey | null;
    let chain: ChainKey =
        stored && SUPPORTED_CHAINS.includes(stored) ? stored : DEFAULT_CHAIN;

    const addrs = () => ADDRESSES[chain];
    const client = () => getPublicClient(chain);

    const numberLocale = ({ en: "en-US", de: "de-CH", fr: "fr-CH", it: "it-CH", es: "es-ES" } as Record<string, string>)[locale] ?? "en-US";

    const fmtZCHF = (v: bigint) =>
        `${Number(formatUnits(v, 18)).toLocaleString(numberLocale, { maximumFractionDigits: 2 })} ZCHF`;
    const fmtPct = (v: bigint | number) => `${(Number(v) / 10_000).toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}%`;
    const fmtZCHFPrecise = (v: bigint) =>
    `${Number(formatUnits(v, 18)).toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 4 })} ZCHF`;

    const formatDuration = (seconds: bigint): string => {
    const s = Number(seconds);
    if (s <= 0) return i18n.status_earning;
    const days = Math.floor(s / 86400);
    const hours = Math.floor((s % 86400) / 3600);
    const mins = Math.floor((s % 3600) / 60);
    if (days > 0) return i18n.status_starts_in.replace("{0}", `${days}${i18n.unit_day} ${hours}${i18n.unit_hour}`);
    if (hours > 0) return i18n.status_starts_in.replace("{0}", `${hours}${i18n.unit_hour} ${mins}${i18n.unit_min}`);
    return i18n.status_starts_in.replace("{0}", `${mins}${i18n.unit_min}`);
    };
    
    const parseAmount = () => {
        try { return parseUnits(els.amount.value.trim() || "0", 18); }
        catch { return 0n; }
    };

    const getWC = () => {
        const w = getOnboard().state.get().wallets[0];
        if (!w) throw new Error(i18n.err_not_connected);
        return makeWalletClient(w.provider, chain);
    };

    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    const tx = async (args: any) => {
        const hash = await getWC().writeContract(args);
        await client().waitForTransactionReceipt({ hash });
        return hash;
    };

    const lockBtns = (active: HTMLButtonElement, label: string) => {
        const all = [els.btnSave, els.btnWithdraw, els.btnCompound];
        const labelEl = active.querySelector(".btn-label") as HTMLElement;
        const original = labelEl.textContent ?? "";
        active.dataset.loading = "1";
        labelEl.textContent = label;
        all.forEach(b => b.disabled = true);
        return () => {
            delete active.dataset.loading;
            labelEl.textContent = original;
            all.forEach(b => b.disabled = false);
        };
    };

    const run = (btn: HTMLButtonElement, label: string, fn: () => Promise<unknown>) => async () => {
        const unlock = lockBtns(btn, label);
        try { await fn(); }
        catch (e) {
            const { message, isUserCancel } = friendlyError(e);
            toast(isUserCancel ? i18n.cancelled : message, isUserCancel ? "info" : "error", isUserCancel ? 2500 : 6500);
        }
        finally { unlock(); }
    };

    const showError = (msg: string | null) => {
        els.amountError.classList.toggle("hidden", !msg);
        els.amountError.textContent = msg ?? "";
    };

    function validate() {
        if (!connected) return showError(null);
        const amount = parseAmount();
        if (amount === 0n) return showError(null);
        if (lastIntent === "deposit" && amount > walletBalRaw) showError(i18n.err_wallet_too_low);
        else if (lastIntent === "withdraw" && amount > savedRaw) showError(i18n.err_saved_too_low);
        else showError(null);
    }

    // ------------------------------------------------------------------
    // Yearly Accounts — pure forward projection from current state.
    //
    // Compounds the current rate annually over a 5-year horizon. Uses the
    // user's current saved + accrued balance, plus the amount in the input
    // box if they're in "deposit" intent (so the table previews the result
    // of the pending action). No historical event log needed.
    // ------------------------------------------------------------------
    const PROJECTION_HORIZON_YEARS = 5;
    const SCALE = 1_000_000n;   // Match PPM precision; avoids float drift on large balances.

    function projectionStartingBalance(): bigint {
        // Current realised position.
        let base = savedRaw + accruedRaw;
        // Preview the pending deposit (if any) so the table reflects "what if I save N more".
        if (lastIntent === "deposit") {
            const pending = parseAmount();
            if (pending > 0n && pending <= walletBalRaw) base += pending;
        }
        return base;
    }

    function renderYearly() {
        const starting = projectionStartingBalance();
        if (starting === 0n || ratePPM <= 0) {
            els.yearlyList.innerHTML = "";
            els.yearlyEmpty.classList.remove("hidden");
            return;
        }
        els.yearlyEmpty.classList.add("hidden");

        const ratePPMBig = BigInt(ratePPM);
        const thisYear = new Date().getFullYear();
        let balance = starting;
        const rows: string[] = [];

        for (let i = 1; i <= PROJECTION_HORIZON_YEARS; i++) {
            const interest = (balance * ratePPMBig) / SCALE;
            const endBalance = balance + interest;
            rows.push(`<li class="grid grid-cols-1 gap-1 py-3 md:grid-cols-[1fr_1.5fr_1.5fr] md:items-center md:gap-4">
                <div class="font-medium text-[15px]">${thisYear + i}</div>
                <div class="text-[14px] md:text-right">
                    <span class="md:hidden opacity-60">${i18n.yearly_empty ? "" : ""}</span>
                    ${fmtZCHFPrecise(interest)}
                </div>
                <div class="text-[14px] font-medium md:text-right">${fmtZCHFPrecise(endBalance)}</div>
            </li>`);
            balance = endBalance;
        }

        els.yearlyList.innerHTML = rows.join("");
    }

    async function loadModule() {
        const a = addrs();
        const [rate, tvl] = await client().multicall({
            contracts: [
                { address: a.savings, abi: SAVINGS_ABI, functionName: "currentRatePPM" },
                { address: a.zchf, abi: erc20Abi, functionName: "balanceOf", args: [a.savings] },
            ],
            allowFailure: false,
        });
        ratePPM = Number(rate);
        els.rate.textContent = fmtPct(rate);
        els.tvl.textContent = fmtZCHF(tvl);
        renderYearly();
    }

    async function loadAccount(addr: Address) {
        const a = addrs();
        const [walletBal, account, accrued, currTicks, rate] = await client().multicall({
            contracts: [
                { address: a.zchf, abi: erc20Abi, functionName: "balanceOf", args: [addr] },
                { address: a.savings, abi: SAVINGS_ABI, functionName: "savings", args: [addr] },
                { address: a.savings, abi: SAVINGS_ABI, functionName: "accruedInterest", args: [addr] },
                { address: a.savings, abi: SAVINGS_ABI, functionName: "currentTicks" },
                { address: a.savings, abi: SAVINGS_ABI, functionName: "currentRatePPM" },
            ],
            allowFailure: false,
        });
        const [saved, accTicks] = account;
        walletBalRaw = walletBal; savedRaw = saved; accruedRaw = accrued;
        ratePPM = Number(rate);

        els.walletBalance.textContent = fmtZCHFPrecise(walletBal);
        els.saved.textContent = fmtZCHFPrecise(saved);
        els.accrued.textContent = fmtZCHFPrecise(accrued);
        els.total.textContent = fmtZCHFPrecise(saved + accrued);
        els.locked.textContent = accTicks > currTicks
           ? formatDuration((accTicks - currTicks) / BigInt(rate || 1))
           : i18n.status_earning;

        validate();
        renderYearly();
    }

    function clearAccount() {
        walletBalRaw = 0n; savedRaw = 0n; accruedRaw = 0n;
        els.walletBalance.textContent = "—";
        els.saved.textContent = "—";
        els.accrued.textContent = "—";
        els.total.textContent = "—";
        els.locked.textContent = "—";
        els.amount.value = "";
        showError(null);
        renderYearly();
    }

    function setConnectedUI(isConnected: boolean) {
        els.amount.disabled = !isConnected;
        els.toggleOnBehalf.disabled = !isConnected;
        els.targetAddress.disabled = !isConnected;
        els.btnMaxWallet.disabled = !isConnected;
        els.btnMaxSaved.disabled = !isConnected;
        els.actionsConnected.classList.toggle("hidden", !isConnected);
        els.actionsDisconnected.classList.toggle("hidden", isConnected);
    }

    function getTarget(): Address {
        if (els.toggleOnBehalf.checked) {
            const v = els.targetAddress.value.trim();
            if (!isAddress(v)) throw new Error(i18n.err_target);
            return v as Address;
        }
        return connected!;
    }

    async function approveIfNeeded(amount: bigint) {
        const a = addrs();
        const allowance = await client().readContract({
            address: a.zchf, abi: erc20Abi, functionName: "allowance",
            args: [connected!, a.savings],
        });
        if (allowance >= amount) return;
        await tx({
            address: a.zchf, abi: erc20Abi, functionName: "approve",
            args: [a.savings, maxUint256], account: connected!, chain: null,
        });
    }

    async function save() {
        if (!connected) throw new Error(i18n.err_not_connected);
        const amount = parseAmount();
        if (amount <= 0n) throw new Error(i18n.err_amount);
        if (amount > walletBalRaw) throw new Error(i18n.err_wallet_too_low);
        await approveIfNeeded(amount);
        await tx({
            address: addrs().savings, abi: SAVINGS_ABI, functionName: "save",
            args: [amount], account: connected, chain: null,
        });
        toast(i18n.toast_deposit_done, "success");
        els.amount.value = "";
        showError(null);
        await loadAccount(connected);
    }

    async function withdraw() {
        if (!connected) throw new Error(i18n.err_not_connected);
        const amount = parseAmount();
        if (amount <= 0n) throw new Error(i18n.err_amount);
        if (amount > savedRaw) throw new Error(i18n.err_saved_too_low);
        await tx({
            address: addrs().savings, abi: SAVINGS_ABI, functionName: "withdraw",
            args: [getTarget(), amount], account: connected, chain: null,
        });
        toast(i18n.toast_withdraw_done, "success");
        els.amount.value = "";
        showError(null);
        await loadAccount(connected);
    }

    async function compound() {
        if (!connected) throw new Error(i18n.err_not_connected);
        await tx({
            address: addrs().savings, abi: SAVINGS_ABI, functionName: "refreshBalance",
            args: [connected], account: connected, chain: null,
        });
        toast(i18n.toast_compound_done, "success");
        await loadAccount(connected);
    }

    /** Reload everything when the active chain changes. */
    async function onChainSwitched() {
        clearAccount();
        await loadModule().catch(() => {});
        if (connected) await loadAccount(connected).catch(() => {});
    }

    els.btnConnect.addEventListener("click", () => {
        getOnboard().connectWallet();
    });

    els.btnSave.addEventListener("click", () => {
        lastIntent = "deposit"; validate();
        run(els.btnSave, i18n.btn_depositing, save)();
    });
    els.btnWithdraw.addEventListener("click", () => {
        lastIntent = "withdraw"; validate();
        run(els.btnWithdraw, i18n.btn_withdrawing, withdraw)();
    });
    els.btnCompound.addEventListener("click", run(els.btnCompound, i18n.btn_compounding, compound));

    els.btnMaxWallet.addEventListener("click", () => {
        els.amount.value = formatUnits(walletBalRaw, 18); lastIntent = "deposit"; validate(); renderYearly();
    });
    els.btnMaxSaved.addEventListener("click", () => {
        els.amount.value = formatUnits(savedRaw, 18); lastIntent = "withdraw"; validate(); renderYearly();
    });

    els.amount.addEventListener("input", () => {
        // Default to "deposit" intent when the user is typing — the table
        // previews "if I save this, here's what I'd earn".
        lastIntent = "deposit";
        validate();
        renderYearly();
    });
    els.toggleOnBehalf.addEventListener("change", () => {
        els.onBehalfRow.classList.toggle("hidden", !els.toggleOnBehalf.checked);
    });

    // Listen to ChainSelector
    window.addEventListener("chainchange", (e) => {
        const next = (e as CustomEvent<{ chain: ChainKey }>).detail.chain;
        if (next === chain) return;
        chain = next;
        onChainSwitched();
    });

    getOnboard().state.select("wallets").subscribe((wallets) => {
        const w = wallets[0];
        if (w?.accounts[0]) {
            connected = w.accounts[0].address as Address;
            setConnectedUI(true);
            loadAccount(connected).catch(() => {});
        } else {
            connected = null;
            clearAccount();
            setConnectedUI(false);
        }
    });

    setConnectedUI(false);
    loadModule().catch(() => {});
</script>