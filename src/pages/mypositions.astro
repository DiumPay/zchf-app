---
import Layout from "@layouts/Layout.astro";
import WalletConnect from "@components/WalletConnect.astro";
import Card from "@components/Card.astro";
import { t, getLocale, safeJsonForScript } from "@i18n/t";

import bossIcon from "@assets/tokens/boss.svg?url";
import cbbtcIcon from "@assets/tokens/cbbtc.svg?url";
import crvIcon from "@assets/tokens/crv.svg?url";
import gnoIcon from "@assets/tokens/gno.svg?url";
import lendsIcon from "@assets/tokens/lends.svg?url";
import lsethIcon from "@assets/tokens/lseth.svg?url";
import paxgIcon from "@assets/tokens/paxg.svg?url";
import realuIcon from "@assets/tokens/realu.svg?url";
import spyonIcon from "@assets/tokens/spyon.svg?url";
import wbtcIcon from "@assets/tokens/wbtc.svg?url";
import wethIcon from "@assets/tokens/weth.svg?url";
import wstethIcon from "@assets/tokens/wsteth.svg?url";
import xautIcon from "@assets/tokens/xaut.svg?url";
import ysyboldIcon from "@assets/tokens/ysybold.svg?url";
import zchfIcon from "@assets/tokens/zchf.svg?url";

const TOKEN_ICONS: Record<string, string> = {
    boss: bossIcon, cbbtc: cbbtcIcon, crv: crvIcon, gno: gnoIcon, lends: lendsIcon,
    lseth: lsethIcon, paxg: paxgIcon, realu: realuIcon, spyon: spyonIcon, wbtc: wbtcIcon,
    weth: wethIcon, wsteth: wstethIcon, xaut: xautIcon, ysybold: ysyboldIcon, zchf: zchfIcon,
};

const tt = t(Astro.url);
const locale = getLocale(Astro.url);

const i18n = {
    pageTitle: tt("mypos_page_title"),
    pageSubtitle: tt("mypos_subtitle"),
    notConnected: tt("wallet_not_connected"),
    empty: tt("mypos_empty"),
    loading: tt("mypos_loading"),
    cardMinted: tt("mypos_card_minted"),
    cardCollateral: tt("mypos_card_collateral"),
    cardLiqPrice: tt("mypos_card_liq_price"),
    cardExpires: tt("mypos_card_expires"),
    statusActive: tt("mint_status_active"),
    statusCooldown: tt("mypos_status_cooldown_short"),
    statusClosed: tt("mypos_status_closed"),
    statusChallenged: tt("mypos_status_challenged"),
    badgeClone: tt("mint_badge_clone"),
    badgeV2: tt("mypos_badge_v2"),
    manageSubtitle: tt("mypos_manage_subtitle"),
    manageBack: tt("mypos_back"),
    sectionAdjustment: tt("mypos_section_adjustment"),
    sectionDetails: tt("mypos_section_details") || "Position Details",
    sectionWallet: tt("mypos_section_wallet"),
    sectionOutcome: tt("mypos_section_outcome"),
    labelAmount: tt("mypos_label_amount"),
    labelCollateral: tt("mypos_label_collateral"),
    labelLiqPrice: tt("mypos_label_liq_price"),
    labelMaturity: tt("mypos_label_maturity"),
    labelExpiration: tt("mypos_label_expiration"),
    labelInterest: tt("mypos_label_interest"),
    labelBalance: tt("mypos_label_balance_short"),
    labelMin: tt("mypos_label_min"),
    labelMax: tt("mypos_label_max"),
    labelReset: tt("mypos_label_reset") || "Reset",
    walletZchf: tt("mypos_wallet_zchf"),
    walletColl: tt("mypos_wallet_coll"),
    actionAdjust: tt("mypos_action_adjust"),
    actionAdjusting: tt("mypos_action_adjusting"),
    actionApprove: tt("mint_action_approve_required"),
    actionApproving: tt("mint_action_approving"),
    outcomeCurrent: tt("mypos_outcome_current_amount"),
    outcomeFuture: tt("mypos_outcome_future_amount"),
    outcomeWalletInc: tt("mypos_outcome_wallet_inc"),
    outcomeWalletDec: tt("mypos_outcome_wallet_dec"),
    outcomeReserveAdd: tt("mypos_outcome_reserve_add"),
    outcomeReserveReturn: tt("mypos_outcome_reserve_return"),
    outcomeFee: tt("mypos_outcome_fee"),
    linkDetails: tt("mypos_link_details"),
    linkContract: tt("mypos_link_contract"),
    unitYear: tt("mypos_unit_year"),
    unitDay: tt("mypos_unit_day"),
    unitMonth: tt("mypos_unit_month"),
    expired: tt("mypos_expired"),
    errCooldown: tt("mypos_err_cooldown"),
    errClosed: tt("mypos_err_closed"),
    errChallenged: tt("mypos_err_challenged"),
    errAmountLimit: tt("mypos_err_amount_limit"),
    errCollateralLow: tt("mypos_err_collateral_low"),
    errBalanceLow: tt("mypos_err_balance_low_zchf"),
    errPriceLocked: tt("mypos_err_price_locked"),
    noteCollSentBack: tt("mypos_note_coll_sent_back") || "{amount} {symbol} sent back to your wallet",
    noteCollTaken: tt("mypos_note_coll_taken") || "{amount} {symbol} taken from your wallet",
    toastApproved: tt("mypos_toast_approved"),
    toastAdjusted: tt("mypos_toast_adjusted"),
    cancelled: tt("common_cancelled"),
    notConnectedToast: tt("wallet_not_connected"),
    errRpcTitle: tt("mint_err_rpc_title"),
    errRpcBody: tt("mint_err_rpc_body"),
    errRpcHelp: tt("mint_err_rpc_help"),
    // ---- roller ----
    rollerSection: tt("mypos_roller_section") || "Renewal",
    rollerIntro: tt("mypos_roller_intro") || "Roll this position into a longer one with the same collateral. The owed amount will be increased by the upfront interest of the new position. Excess collateral is returned to your wallet.",
    rollerNone: tt("mypos_roller_none") || "No open positions available for rolling.",
    rollerColTarget: tt("mypos_roller_col_target") || "Target",
    rollerColLiqPrice: tt("mypos_roller_col_liq") || "Liquidation Price",
    rollerColInterest: tt("mypos_roller_col_interest") || "Annual Interest",
    rollerColMaturity: tt("mypos_roller_col_maturity") || "Maturity",
    rollerColMissing: tt("mypos_roller_col_missing") || "Additional Funds",
    rollerActionRoll: tt("mypos_roller_roll") || "Roll",
    rollerActionMerge: tt("mypos_roller_merge") || "Merge",
    rollerActionApprove: tt("mypos_roller_approve") || "Approve {symbol}",
    rollerActionApproving: tt("mypos_roller_approving") || "Approving…",
    rollerActionRolling: tt("mypos_roller_rolling") || "Rolling…",
    rollerActionMerging: tt("mypos_roller_merging") || "Merging…",
    rollerCooldown: tt("mypos_roller_cooldown") || "Cooldown",
    rollerLoading: tt("mypos_roller_loading") || "Looking for renewal targets…",
    rollerToastRolled: tt("mypos_roller_toast_rolled") || "Position rolled",
    rollerToastMerged: tt("mypos_roller_toast_merged") || "Position merged",
    rollerErrBalance: tt("mypos_roller_err_balance") || "Insufficient ZCHF to cover additional funds",
    // ---- public view ----
    publicBanner: tt("mypos_public_banner") || "Viewing positions of {owner}. Read-only.",
    publicClose: tt("mypos_public_close") || "Close",
    publicEmpty: tt("mypos_public_empty") || "This address has no open positions.",
    publicManageNotice: tt("mypos_public_manage_notice") || "Read-only view. Connect as the owner to manage this position.",
};
---

<Layout title={`${i18n.pageTitle} | Frankencoin dApp`} description={i18n.pageSubtitle}>
    <main class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12">
        <header id="list-header" class="mb-8">
            <h1 class="text-[28px] font-bold tracking-tight">{i18n.pageTitle}</h1>
            <p class="mt-2 text-[14px] opacity-90">{i18n.pageSubtitle}</p>
        </header>

        <section id="view-list">
            <div id="public-banner" class="hidden mb-6"></div>
            <div id="list-state-disconnected" class="hidden">
                <Card title={i18n.notConnected}>
                    <p class="mb-4 text-[14px] opacity-90">{i18n.notConnected}</p>
                    <WalletConnect />
                </Card>
            </div>
            <div id="list-state-loading" class="hidden">
                <Card title={i18n.loading}><p class="text-[14px] opacity-90">{i18n.loading}</p></Card>
            </div>
            <div id="list-state-empty" class="hidden">
                <Card title={i18n.empty}><p class="text-[14px] opacity-90">{i18n.empty}</p></Card>
            </div>

            <div data-token-icons={JSON.stringify(TOKEN_ICONS)} class="hidden"></div>
            <div id="list-grid" class="grid grid-cols-1 gap-4 md:grid-cols-2" style="display:none"></div>
        </section>

        <section id="view-manage" class="hidden">
            <div id="manage-public-banner" class="hidden mb-6"></div>
            <button id="btn-back" class="mb-6 inline-flex items-center gap-1 text-[14px] opacity-90 transition-opacity hover:opacity-100">
                ← <span>{i18n.manageBack}</span>
            </button>
            <div id="manage-content"></div>
        </section>
    </main>

    <script id="mypos-i18n" type="application/json" set:html={safeJsonForScript(i18n)}></script>
    <script id="mypos-locale" type="application/json" set:html={safeJsonForScript(locale)}></script>
</Layout>

<script>
    import { type Address, formatUnits, parseUnits, erc20Abi } from "viem";
    import { getOnboard } from "@lib/onboard";
    import { mainnet } from "viem/chains";
    import { getPublicClient, makeWalletClient } from "@lib/client";
    import { toast } from "@lib/toast";
    import { friendlyError } from "@lib/errors";
    import { findUserPositions, loadMyPositionDetails, clearAllPositionsCache, type MyPositionDetail } from "@lib/myPositions";
    import { getMarketPriceCHF } from "@lib/prices";
    import { POSITION_V2_ABI as PositionV2ABI } from "@abi/position";
    import {
        findRollTargets, previewRoll, getRollerAllowance,
        approveCollateralForRoller, executeRollFully,
        type RollTarget, type RollPreview,
    } from "@lib/positionRoller";

    // ================== utilities ==================
    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;
    const i18n = JSON.parse($("mypos-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("mypos-locale").textContent || '"en"') as string;
    const tokenIcons = JSON.parse(document.querySelector<HTMLElement>("[data-token-icons]")!.dataset.tokenIcons || "{}") as Record<string, string>;
    const iconFor = (sym: string) => tokenIcons[sym.toLowerCase()] ?? null;

    const esc = (s: unknown): string =>
        String(s).replace(/[&<>"']/g, c => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
    const isAddrLike = (s: unknown): s is Address =>
        typeof s === "string" && /^0x[0-9a-fA-F]{40}$/.test(s);

    const numberLocale = ({ en: "en-US", de: "de-CH", fr: "fr-CH", it: "it-CH", es: "es-ES" } as Record<string, string>)[locale] ?? "en-US";
    const ETH_CHAIN_ID_HEX = "0x1";
    const ONE_E18 = 10n ** 18n;
    const MAX_UINT256 = (1n << 256n) - 1n;
    const abs = (x: bigint) => x < 0n ? -x : x;

    // ================== provider/chain ==================
    const getRawProvider = (): any => {
        const eth = (window as any).ethereum;
        if (!eth) return null;
        if (Array.isArray(eth.providers) && eth.providers.length) {
            return eth.providers.find((p: any) => p.isMetaMask && !p.isBraveWallet) ?? eth.providers[0];
        }
        return eth;
    };
    const readChainId = async (): Promise<string | null> => {
        try { return (await getRawProvider()?.request({ method: "eth_chainId" }))?.toLowerCase() ?? null; }
        catch { return null; }
    };
    async function ensureMainnet(): Promise<boolean> {
        if (await readChainId() === ETH_CHAIN_ID_HEX) return true;
        const p = getRawProvider();
        if (!p?.request) { toast(i18n.notConnectedToast, "error"); return false; }
        try {
            await p.request({ method: "wallet_switchEthereumChain", params: [{ chainId: ETH_CHAIN_ID_HEX }] });
            return (await readChainId()) === ETH_CHAIN_ID_HEX;
        } catch (err: any) {
            if (err?.code === 4001 || /reject|denied/i.test(err?.message ?? "")) { toast(i18n.cancelled, "info"); return false; }
            toast(friendlyError(err).message, "error");
            return false;
        }
    }
    const isUserCancelErr = (err: any) =>
        (err?.code ?? err?.cause?.code) === 4001 || /reject|denied|cancel/i.test(err?.message ?? "");
    const isWalletRpcError = (err: any) => {
        const msg = (err?.message ?? err?.cause?.message ?? "").toString().toLowerCase();
        const code = err?.code ?? err?.cause?.code;
        return msg.includes("json-rpc") || msg.includes("json rpc") ||
               code === -32603 || code === -32000 || code === -32601 || code === -32006;
    };

    // ================== state ==================
    let connected: Address | null = null;
    let positions: MyPositionDetail[] = [];
    let activeAddress: Address | null = null;
    let lastRenderedAddress: Address | null = null;
    let marketPrice80Pct: bigint = 0n; // liquidation-price ceiling, in 36-dec units (0 = no cap available)
    let editor: { p: MyPositionDetail; mintAmount: bigint; collAmount: bigint; liqPrice: bigint } | null = null;

    // Public view: when ?owner=0x... is in the URL, the page treats that
    // address as the owner whose positions to list — read-only, write
    // buttons hidden. Set once at boot from the URL; doesn't change with
    // wallet (re)connects.
    let publicOwner: Address | null = null;
    const viewerIsOwner = (): boolean =>
        !publicOwner || (!!connected && publicOwner.toLowerCase() === connected.toLowerCase());

    // Roller state — populated lazily when the user enters manage view for a
    // position that has outstanding debt. Targets are listed, preview is computed
    // on demand per target.
    let rollerTargets: RollTarget[] = [];
    let rollerPreviews: Map<string, RollPreview> = new Map(); // key: target.address.toLowerCase()
    let rollerLoadedFor: string | null = null; // lowercased source address — gates re-fetch

    // ================== format helpers ==================
    const fmt = (n: number, max = 2) => n.toLocaleString(numberLocale, { minimumFractionDigits: 0, maximumFractionDigits: max });
    const fmtZCHF = (n: number, max = 2) => n.toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: max });
    const fromBig = (v: bigint, dec: number) => Number(v) / Math.pow(10, dec);
    const fmtDate = (ts: number) => ts > 0
        ? new Date(ts * 1000).toLocaleDateString(numberLocale, { day: "2-digit", month: "short", year: "numeric" })
        : "—";
    function fmtRelative(ts: number): string {
        if (!ts) return "—";
        const diff = ts - Math.floor(Date.now() / 1000);
        if (diff <= 0) return i18n.expired;
        const days = Math.floor(diff / 86400);
        if (days >= 365) return `${Math.floor(days / 365)} ${i18n.unitYear}`;
        if (days >= 30) return `${Math.floor(days / 30)} ${i18n.unitMonth}`;
        return `${days} ${i18n.unitDay}`;
    }

    const isCooldown = (p: MyPositionDetail) => p.cooldown * 1000 > Date.now();
    const isChallenged = (p: MyPositionDetail) => p.challengedAmount > 0n;

    const statusOf = (p: MyPositionDetail) => {
        if (p.isClosed) return { label: i18n.statusClosed, cls: "bg-foreground/15 opacity-90" };
        if (isChallenged(p)) return { label: i18n.statusChallenged, cls: "bg-primary/15 text-primary" };
        if (isCooldown(p)) return { label: i18n.statusCooldown, cls: "bg-foreground/15" };
        return { label: i18n.statusActive, cls: "bg-foreground/10" };
    };

    // ================== routing ==================
    const urlAddress = (): Address | null => {
        const a = new URLSearchParams(location.search).get("address");
        return a && isAddrLike(a) ? a : null;
    };
    function navigate(target: Address | null) {
        const url = new URL(location.href);
        target ? url.searchParams.set("address", target) : url.searchParams.delete("address");
        history.pushState({}, "", url);
        applyRoute();
    }
    function applyRoute() {
        const p = urlAddress();
        activeAddress = p;
        const isManage = !!p;
        $("view-list").classList.toggle("hidden", isManage);
        $("view-manage").classList.toggle("hidden", !isManage);
        $("list-header").classList.toggle("hidden", isManage);
        isManage ? renderManage() : renderList();
    }
    window.addEventListener("popstate", applyRoute);

    // ================== list view ==================
    function setListState(state: "disconnected" | "loading" | "empty" | "grid") {
        for (const s of ["disconnected", "loading", "empty"] as const) {
            $(`list-state-${s}`).classList.toggle("hidden", s !== state);
        }
        ($("list-grid") as HTMLElement).style.display = state === "grid" ? "" : "none";
    }

    function shortAddr(a: Address): string {
        return `${a.slice(0, 6)}…${a.slice(-4)}`;
    }

    function bannerHtml(text: string): string {
        return `
            <div class="rounded-md border border-foreground/10 bg-foreground/[0.03] px-4 py-3 flex items-center justify-between gap-3 text-[13px]">
                <span class="opacity-90">${text}</span>
                <a href="?" class="text-primary hover:underline font-medium">${i18n.publicClose}</a>
            </div>
        `;
    }

    function renderPublicBanner() {
        const el = $("public-banner");
        if (!publicOwner) { el.classList.add("hidden"); el.innerHTML = ""; return; }
        const text = i18n.publicBanner.replace("{owner}", shortAddr(publicOwner));
        el.innerHTML = bannerHtml(text);
        el.classList.remove("hidden");
    }

    function renderManagePublicBanner() {
        const el = $("manage-public-banner");
        if (!publicOwner) { el.classList.add("hidden"); el.innerHTML = ""; return; }
        const text = i18n.publicBanner.replace("{owner}", shortAddr(publicOwner));
        el.innerHTML = bannerHtml(text);
        el.classList.remove("hidden");
    }

    function renderList() {
        // In public view we never gate on wallet connection — the owner is
        // resolved from the URL and the data is always fetchable.
        if (!connected && !publicOwner) return setListState("disconnected");

        renderPublicBanner();

        if (positions.length === 0) {
            // Override the default empty copy when in public view.
            if (publicOwner) {
                const empty = $("list-state-empty");
                const card = empty.querySelector("p");
                if (card) card.textContent = i18n.publicEmpty;
            }
            return setListState("empty");
        }
        const grid = $("list-grid");
        grid.innerHTML = "";
        for (const p of positions) {
            if (!isAddrLike(p.address)) continue;
            const status = statusOf(p);
            const icon = iconFor(p.collateralSymbol);
            const iconHtml = icon
                ? `<img src="${icon}" alt="" class="h-9 w-9 shrink-0 rounded-full" />`
                : `<div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-foreground/10 text-[12px] font-bold">${esc(p.collateralSymbol.slice(0, 3))}</div>`;

            const card = document.createElement("a");
            card.href = `?address=${p.address}`;
            card.className = "block rounded-md border border-foreground/10 bg-background p-5 transition-colors hover:border-foreground/30";
            card.onclick = (ev) => { ev.preventDefault(); navigate(p.address); };
            card.innerHTML = `
                <div class="mb-4 flex items-center gap-3">
                    ${iconHtml}
                    <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-2 flex-wrap">
                            <div class="text-[15px] font-bold">${esc(p.collateralName)}</div>
                            <span class="inline-block rounded px-1.5 py-0.5 text-[11px] font-medium ${status.cls}">${status.label}</span>
                            ${p.isClone ? `<span class="inline-block rounded bg-foreground/10 px-1.5 py-0.5 text-[11px] font-medium opacity-90">${i18n.badgeClone}</span>` : ""}
                        </div>
                        <div class="text-[12px] opacity-90">${esc(p.collateralSymbol)}</div>
                    </div>
                </div>
                <div class="space-y-2 text-[14px]">
                    <div class="flex justify-between"><span class="opacity-90">${i18n.cardMinted}</span><span class="font-medium">${fmtZCHF(fromBig(p.minted, 18))} ZCHF</span></div>
                    <div class="flex justify-between"><span class="opacity-90">${i18n.cardCollateral}</span><span class="font-medium">${fmt(fromBig(p.collateralBalance, p.collateralDecimals), 4)} ${esc(p.collateralSymbol)}</span></div>
                    <div class="flex justify-between"><span class="opacity-90">${i18n.cardLiqPrice}</span><span class="font-medium">${fmtZCHF(fromBig(p.price, 36 - p.collateralDecimals))} ZCHF</span></div>
                    <div class="flex justify-between"><span class="opacity-90">${i18n.cardExpires}</span><span class="font-medium">${fmtDate(p.expiration)} <span class="opacity-90">(${fmtRelative(p.expiration)})</span></span></div>
                </div>
            `;
            grid.appendChild(card);
        }
        setListState("grid");
    }

    // ================== manage view ==================
    /**
     * input-block template: label + big input + footer (balance, optional Min/Max/Reset).
     * btns: array of {id, text} — rendered right-aligned in the footer.
     */
    function inputBlock(
        id: string, label: string, symbol: string, iconUrl: string,
        balanceId: string | null,
        btns: Array<{ id: string; text: string }>
    ): string {
        const iconHtml = iconUrl ? `<img src="${iconUrl}" alt="" class="h-5 w-5 rounded-full" />` : "";
        const btnHtml = btns.map(b => `<button type="button" id="${b.id}" class="text-primary font-semibold hover:underline">${b.text}</button>`).join(' <span class="opacity-40">·</span> ');
        return `
            <div class="rounded-md border border-foreground/10 p-4">
                <label for="${id}" class="block text-[13px] font-medium opacity-90">${label}</label>
                <div class="mt-2 flex items-center gap-3">
                    <input id="${id}" type="text" inputmode="decimal" autocomplete="off"
                        class="min-w-0 flex-1 bg-transparent text-[20px] font-bold tracking-tight focus:outline-none" />
                    <div class="flex items-center gap-2 text-[14px] opacity-90">${iconHtml}<span>${esc(symbol)}</span></div>
                </div>
                <div class="mt-2 flex items-center justify-between text-[12px]">
                    <div class="opacity-90">${balanceId ? `${i18n.labelBalance} <span id="${balanceId}">—</span>` : "<span>&nbsp;</span>"}</div>
                    <div class="flex items-center gap-2">${btnHtml}</div>
                </div>
                <div id="${id}-note" class="mt-2 hidden text-[12px] opacity-90"></div>
            </div>
        `;
    }

    function buildManage(p: MyPositionDetail) {
        if (!isAddrLike(p.address)) { $("manage-content").textContent = "Invalid position address"; return; }
        const status = statusOf(p);
        const icon = iconFor(p.collateralSymbol);
        const iconHtml = icon
            ? `<img src="${icon}" alt="" class="h-10 w-10 shrink-0 rounded-full" />`
            : `<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-foreground/10 text-[13px] font-bold">${esc(p.collateralSymbol.slice(0, 3))}</div>`;
        const zchfIconUrl = tokenIcons["zchf"] ?? "";
        const collIconUrl = icon ?? "";

        $("manage-content").innerHTML = `
            <div class="mb-8 flex items-start justify-between gap-4 flex-wrap">
                <div class="flex items-center gap-3">
                    ${iconHtml}
                    <div>
                        <div class="flex items-center gap-2 flex-wrap">
                            <h2 class="text-[24px] font-bold tracking-tight">${esc(p.collateralName)} (${esc(p.collateralSymbol)})</h2>
                            <span class="inline-block rounded px-2 py-0.5 text-[11px] font-medium ${status.cls}">${status.label}</span>
                            <span class="inline-block rounded bg-foreground/10 px-2 py-0.5 text-[11px] font-medium opacity-90">${i18n.badgeV2}</span>
                            ${p.isClone ? `<span class="inline-block rounded bg-foreground/10 px-2 py-0.5 text-[11px] font-medium opacity-90">${i18n.badgeClone}</span>` : ""}
                        </div>
                        <p class="mt-1 text-[14px] opacity-90">${i18n.manageSubtitle}</p>
                    </div>
                </div>
                <div class="flex gap-4 text-[14px]">
                    <a href="https://app.frankencoin.com/monitoring/${p.address}" target="_blank" rel="noopener" class="text-primary hover:underline">${i18n.linkDetails}</a>
                    <a href="https://etherscan.io/address/${p.address}" target="_blank" rel="noopener" class="text-primary hover:underline">${i18n.linkContract}</a>
                </div>
            </div>

            <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
                <!-- Left: Adjustment -->
                <div class="rounded-md border border-foreground/10 bg-background p-6">
                    <h3 class="mb-5 text-center text-[18px] font-bold tracking-tight">${i18n.sectionAdjustment}</h3>
                    <div class="space-y-4">
                        ${inputBlock("i-mint", i18n.labelAmount, "ZCHF", zchfIconUrl, "balance-mint",
                            [{id: "btn-min-mint", text: i18n.labelMin}, {id: "btn-max-mint", text: i18n.labelMax}, {id: "btn-reset-mint", text: i18n.labelReset}])}
                        ${inputBlock("i-coll", i18n.labelCollateral, p.collateralSymbol, collIconUrl, "balance-coll",
                            [{id: "btn-min-coll", text: i18n.labelMin}, {id: "btn-reset-coll", text: i18n.labelReset}])}
                        ${inputBlock("i-price", i18n.labelLiqPrice, "ZCHF", zchfIconUrl, null,
                            [{id: "btn-min-price", text: i18n.labelMin}, {id: "btn-max-price", text: i18n.labelMax}, {id: "btn-reset-price", text: i18n.labelReset}])}
                    </div>
                    <div id="adjust-error" class="mt-4 hidden text-[13px] text-primary"></div>
                    <button id="btn-adjust"
                        class="mt-5 inline-flex w-full items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2.5 text-[15px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover disabled:cursor-not-allowed disabled:opacity-50 dark:text-[#030303]">
                        <span class="btn-action-label">${i18n.actionAdjust}</span>
                    </button>
                </div>

                <!-- Right: Details + Wallet + Outcome -->
                <div class="space-y-6">
                    <div class="rounded-md border border-foreground/10 bg-background p-6">
                        <h3 class="mb-5 text-center text-[18px] font-bold tracking-tight">${i18n.sectionDetails}</h3>
                        <div class="space-y-3 text-[14px]">
                            <div class="flex justify-between"><span class="opacity-90">${i18n.labelInterest}</span><span id="m-interest">—</span></div>
                            <div class="flex justify-between"><span class="opacity-90">${i18n.labelMaturity}</span><span id="m-maturity">—</span></div>
                            <div class="flex justify-between"><span class="opacity-90">${i18n.labelExpiration}</span><span id="m-expiration">—</span></div>
                        </div>
                    </div>
                    <div class="rounded-md border border-foreground/10 bg-background p-6">
                        <h3 class="mb-5 text-center text-[18px] font-bold tracking-tight">${i18n.sectionWallet}</h3>
                        <div class="space-y-3 text-[14px]">
                            <div class="flex justify-between"><span class="opacity-90">${i18n.walletZchf}</span><span id="w-zchf">—</span></div>
                            <div class="flex justify-between"><span class="opacity-90">${i18n.walletColl}</span><span id="w-coll">—</span></div>
                        </div>
                    </div>
                    <div class="rounded-md border border-foreground/10 bg-background p-6">
                        <h3 class="mb-5 text-center text-[18px] font-bold tracking-tight">${i18n.sectionOutcome}</h3>
                        <div class="space-y-3 text-[14px]">
                            <div class="flex justify-between"><span class="opacity-90">${i18n.outcomeCurrent}</span><span id="o-current">—</span></div>
                            <div class="flex justify-between"><span><span id="o-wallet-label" class="opacity-90">${i18n.outcomeWalletInc}</span> <span id="o-wallet-pct" class="text-[12px] opacity-80">(0.00%)</span></span><span id="o-wallet">—</span></div>
                            <div class="flex justify-between"><span><span id="o-reserve-label" class="opacity-90">${i18n.outcomeReserveAdd}</span> <span id="o-reserve-pct" class="text-[12px] opacity-80">(0.00%)</span></span><span id="o-reserve">—</span></div>
                            <div class="flex justify-between"><span><span class="opacity-90">${i18n.outcomeFee}</span> <span id="o-fee-pct" class="text-[12px] opacity-80">(0.00%)</span></span><span id="o-fee">—</span></div>
                            <div class="flex justify-between border-t border-foreground/10 pt-3 font-bold"><span>${i18n.outcomeFuture}</span><span id="o-future">—</span></div>
                        </div>
                    </div>
                </div>
            </div>

            ${p.minted > 0n && !p.isClosed ? `
            <section id="roller-section" class="mt-10">
                <h3 class="text-[20px] font-bold tracking-tight">${i18n.rollerSection}</h3>
                <p class="mt-2 text-[14px] opacity-90">${i18n.rollerIntro}</p>
                <div id="roller-content" class="mt-6">
                    <div class="rounded-md border border-foreground/10 bg-background p-6">
                        <p class="text-center text-[14px] opacity-90">${i18n.rollerLoading}</p>
                    </div>
                </div>
            </section>
            ` : ""}
        `;

        hydrateStaticFields(p);
        // initial values
        const dec = p.collateralDecimals;
        $<HTMLInputElement>("i-mint").value = formatUnits(p.minted, 18);
        $<HTMLInputElement>("i-coll").value = formatUnits(p.collateralBalance, dec);
        $<HTMLInputElement>("i-price").value = formatUnits(p.price, 36 - dec);
    }

    function hydrateStaticFields(p: MyPositionDetail) {
        $("m-interest").textContent = `${(p.annualInterestPPM / 10000).toFixed(2)}%`;
        $("m-maturity").textContent = fmtDate(p.expiration);
        $("m-expiration").textContent = fmtRelative(p.expiration);
        $("w-zchf").textContent = `${fmtZCHF(fromBig(p.userZchfBalance, 18))} ZCHF`;
        $("w-coll").textContent = `${fmt(fromBig(p.userCollateralBalance, p.collateralDecimals), 4)} ${p.collateralSymbol}`;
        const bm = $("balance-mint"); if (bm) bm.textContent = fmtZCHF(fromBig(p.userZchfBalance, 18));
        const bc = $("balance-coll"); if (bc) bc.textContent = fmt(fromBig(p.userCollateralBalance, p.collateralDecimals), 4);
    }

    function renderManage() {
        renderManagePublicBanner();
        const root = $("manage-content");
        const p = positions.find(x => x.address.toLowerCase() === activeAddress?.toLowerCase());
        if (!p) {
            lastRenderedAddress = null;
            root.innerHTML = `<div class="rounded-md border border-foreground/10 bg-background p-6"><p class="text-center text-[14px] opacity-90">${i18n.loading}</p></div>`;
            return;
        }
        if (lastRenderedAddress?.toLowerCase() !== p.address.toLowerCase()) {
            buildManage(p);
            lastRenderedAddress = p.address;
            loadMarketPriceCap(p); // async, updates marketPrice80Pct
            loadRollerTargets(p);  // async, populates the renewal section
            // Public mode: lock down all writes after the DOM is built.
            applyPublicModeToManage();
        } else {
            hydrateStaticFields(p);
        }
        // Skip wiring write handlers when viewing someone else's position.
        if (viewerIsOwner()) attachAdjustHandlers(p);
        refresh(p);
    }

    function applyPublicModeToManage() {
        if (viewerIsOwner()) return;

        // Disable + relabel the Adjust button.
        const adjustBtn = $<HTMLButtonElement>("btn-adjust");
        if (adjustBtn) {
            adjustBtn.disabled = true;
            const label = adjustBtn.querySelector(".btn-action-label") as HTMLElement | null;
            if (label) label.textContent = i18n.publicManageNotice;
        }

        // Make all adjustment inputs read-only — keeps the layout intact
        // so the user still sees current values, just can't fiddle.
        for (const id of ["i-mint", "i-coll", "i-price"]) {
            const inp = $<HTMLInputElement>(id);
            if (inp) inp.readOnly = true;
        }

        // Roller buttons get hidden in updateRollerRow / rollerRowHtml when
        // publicOwner is set — no further work needed here.
    }

    async function loadMarketPriceCap(p: MyPositionDetail) {
        marketPrice80Pct = 0n;
        try {
            const m = await getMarketPriceCHF(p.collateralSymbol.toUpperCase());
            if (m && m > 0) {
                // 80% of market, scaled to 36 - collateralDecimals digits
                const dec = 36 - p.collateralDecimals;
                marketPrice80Pct = parseUnits(((m * 0.8).toFixed(Math.min(dec, 18))) as `${number}`, dec);
            }
        } catch {}
    }

    // ================== roller (renewal) ==================

    async function loadRollerTargets(p: MyPositionDetail) {
        // Section is only rendered when minted > 0 && !closed (see buildManage),
        // but double-check so we never fetch for nothing.
        if (p.minted === 0n || p.isClosed) return;

        const key = p.address.toLowerCase();
        rollerLoadedFor = key;
        rollerTargets = [];
        rollerPreviews = new Map();

        try {
            const targets = await findRollTargets({
                address: p.address,
                collateral: p.collateral,
                collateralSymbol: p.collateralSymbol,
                collateralDecimals: p.collateralDecimals,
                minted: p.minted,
                collateralBalance: p.collateralBalance,
                reserveContribution: p.reserveContribution,
                expiration: p.expiration,
                owner: connected ?? undefined,
            });
            // Race guard: if the user navigated to a different position while
            // this awaited, abandon the result.
            if (rollerLoadedFor !== key) return;
            rollerTargets = targets;

            // Render the empty state immediately, then compute previews per
            // target in parallel. Each preview is cheap (2 reads) and we kick
            // them all off so the user doesn't wait sequentially.
            renderRollerSection(p);
            await Promise.all(targets.map(async (t) => {
                try {
                    const preview = await previewRoll({
                        address: p.address,
                        collateral: p.collateral,
                        collateralSymbol: p.collateralSymbol,
                        collateralDecimals: p.collateralDecimals,
                        minted: p.minted,
                        collateralBalance: p.collateralBalance,
                        reserveContribution: p.reserveContribution,
                        expiration: p.expiration,
                        owner: connected ?? undefined,
                    }, t);
                    if (rollerLoadedFor !== key) return;
                    rollerPreviews.set(t.address.toLowerCase(), preview);
                    // Update the row in place — cheap, no re-render of the whole section.
                    updateRollerRow(p, t, preview);
                } catch (err) {
                    console.warn("[roller] preview failed", t.address, err);
                }
            }));
        } catch (err) {
            console.error("[roller] target fetch failed", err);
            if (rollerLoadedFor !== key) return;
            const root = $("roller-content");
            if (root) root.innerHTML = `
                <div class="rounded-md border border-foreground/10 bg-background p-6">
                    <p class="text-center text-[14px] opacity-90">${i18n.rollerNone}</p>
                </div>
            `;
        }
    }

    function renderRollerSection(p: MyPositionDetail) {
        const root = $("roller-content");
        if (!root) return;
        if (rollerTargets.length === 0) {
            root.innerHTML = `
                <div class="rounded-md border border-foreground/10 bg-background p-6">
                    <p class="text-center text-[14px] opacity-90">${i18n.rollerNone}</p>
                </div>
            `;
            return;
        }

        const headers = `
            <div class="grid grid-cols-[1.4fr_1fr_1fr_1fr_1fr_auto] gap-3 px-4 py-3 text-[12px] uppercase tracking-wide opacity-80">
                <div>${i18n.rollerColTarget}</div>
                <div>${i18n.rollerColLiqPrice}</div>
                <div>${i18n.rollerColInterest}</div>
                <div>${i18n.rollerColMaturity}</div>
                <div>${i18n.rollerColMissing}</div>
                <div></div>
            </div>
        `;

        const rows = rollerTargets.map(t => rollerRowHtml(p, t)).join("");

        root.innerHTML = `
            <div class="rounded-md border border-foreground/10 bg-background">
                ${headers}
                <div class="divide-y divide-foreground/10">
                    ${rows}
                </div>
            </div>
        `;

        for (const t of rollerTargets) {
            const btn = document.getElementById(`btn-roll-${t.address}`);
            if (btn) btn.onclick = () => doRoll(p, t);
        }
    }

    function rollerRowHtml(p: MyPositionDetail, t: RollTarget): string {
        const liqUnits = fromBig(t.price, 36 - t.collateralDecimals);
        const interest = (t.annualInterestPPM / 10_000).toFixed(2);
        const maturityStr = fmtDate(t.expiration);
        const shortAddr = `${t.address.slice(0, 6)}…${t.address.slice(-4)}`;
        // Action cell: hidden in public view (no wallet → no roll).
        const actionCell = viewerIsOwner()
            ? `<button id="btn-roll-${t.address}"
                    class="inline-flex items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-4 py-2 text-[13px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover disabled:cursor-not-allowed disabled:opacity-50 dark:text-[#030303]"
                    disabled>
                    <span class="btn-label">${t.isOwnedBySource ? i18n.rollerActionMerge : i18n.rollerActionRoll}</span>
                </button>`
            : `<span class="text-[12px] opacity-60">—</span>`;
        // Missing funds + action label resolved by updateRollerRow once preview lands.
        return `
            <div id="row-${t.address}" class="grid grid-cols-[1.4fr_1fr_1fr_1fr_1fr_auto] gap-3 items-center px-4 py-3 text-[14px]">
                <a href="https://etherscan.io/address/${t.address}" target="_blank" rel="noopener"
                   class="font-mono text-[13px] text-primary hover:underline">${shortAddr}</a>
                <div>${fmtZCHF(liqUnits)} ZCHF</div>
                <div>${interest}%</div>
                <div>${maturityStr}</div>
                <div id="missing-${t.address}" class="opacity-60">—</div>
                ${actionCell}
            </div>
        `;
    }

    function updateRollerRow(p: MyPositionDetail, t: RollTarget, preview: RollPreview) {
        const missingEl = $(`missing-${t.address}`);
        if (!missingEl) return;

        if (preview.missingFunds === 0n) {
            missingEl.textContent = "—";
            missingEl.className = "opacity-60";
        } else {
            // In public view we don't know the viewer's ZCHF balance, and it
            // wouldn't matter anyway. Show the figure plainly.
            if (!viewerIsOwner()) {
                missingEl.textContent = `${fmtZCHF(fromBig(preview.missingFunds, 18))} ZCHF`;
                missingEl.className = "";
            } else {
                const enough = preview.sufficientForRoll(p.userZchfBalance);
                missingEl.textContent = `${fmtZCHF(fromBig(preview.missingFunds, 18))} ZCHF`;
                missingEl.className = enough ? "" : "text-primary font-semibold";
            }
        }

        // Public view: no button to update.
        const btn = $<HTMLButtonElement>(`btn-roll-${t.address}`);
        if (!btn) return;

        // Cooldown wins over everything else as a label.
        const labelEl = btn.querySelector(".btn-label") as HTMLElement;
        if (preview.cooldownBlocking) {
            labelEl.textContent = i18n.rollerCooldown;
            btn.disabled = true;
            return;
        }

        labelEl.textContent = t.isOwnedBySource ? i18n.rollerActionMerge : i18n.rollerActionRoll;
        btn.disabled = !preview.sufficientForRoll(p.userZchfBalance);
    }

    async function doRoll(p: MyPositionDetail, t: RollTarget) {
        if (!connected) { toast(i18n.notConnectedToast, "error"); return; }
        if (!(await ensureMainnet())) return;

        const preview = rollerPreviews.get(t.address.toLowerCase());
        if (!preview) return;
        if (preview.cooldownBlocking) return;
        if (!preview.sufficientForRoll(p.userZchfBalance)) {
            toast(i18n.rollerErrBalance, "error");
            return;
        }

        const publicClient = getPublicClient("ethereum");
        const rawProvider = getRawProvider();
        if (!rawProvider) { toast(i18n.notConnectedToast, "error"); return; }
        const walletClient = makeWalletClient(rawProvider, "ethereum");

        const btn = $<HTMLButtonElement>(`btn-roll-${t.address}`);
        const labelEl = btn?.querySelector(".btn-label") as HTMLElement | null;
        const original = labelEl?.textContent ?? "";
        if (btn) btn.disabled = true;

        try {
            // Step 1: ensure collateral approval to the roller. We approve the
            // source collateral because the contract pulls it from msg.sender
            // during the atomic flash-mint sequence.
            const allowance = await getRollerAllowance(publicClient, p.collateral, connected);
            if (allowance < p.collateralBalance) {
                if (labelEl) labelEl.textContent = i18n.rollerActionApproving.replace("{symbol}", p.collateralSymbol);
                await approveCollateralForRoller(walletClient, publicClient, p.collateral, connected);
                toast(i18n.toastApproved.replace("{symbol}", p.collateralSymbol), "success");
            }

            // Step 2: rollFully.
            if (labelEl) labelEl.textContent = t.isOwnedBySource ? i18n.rollerActionMerging : i18n.rollerActionRolling;
            const result = await executeRollFully(walletClient, publicClient, {
                source: p.address,
                target: t.address,
                account: connected,
            });

            toast(result.merged ? i18n.rollerToastMerged : i18n.rollerToastRolled, "success");

            // Source position is now empty; the user's position list needs a refresh.
            clearAllPositionsCache();
            // Navigate to the (possibly new) target position so the user sees
            // their refinanced debt. result.target is the actual final address
            // (clone path returns a fresh address, merge returns the input).
            await refreshPositions();
            navigate(result.target);
        } catch (err) {
            if (isUserCancelErr(err)) toast(i18n.cancelled, "info");
            else toast(friendlyError(err).message, "error");
            if (labelEl) labelEl.textContent = original;
            if (btn) btn.disabled = false;
        }
    }

    // ================== editor handlers ==================
    const safeParse = (s: string, dp: number): bigint => {
        try { return parseUnits((s.trim().replace(/,/g, ".") || "0") as `${number}`, dp); }
        catch { return 0n; }
    };

    function attachAdjustHandlers(p: MyPositionDetail) {
        const dec = p.collateralDecimals;
        const priceDigits = 36 - dec;
        editor = { p, mintAmount: p.minted, collAmount: p.collateralBalance, liqPrice: p.price };

        const mintInput = $<HTMLInputElement>("i-mint");
        const collInput = $<HTMLInputElement>("i-coll");
        const priceInput = $<HTMLInputElement>("i-price");

        mintInput.oninput = () => { editor!.mintAmount = safeParse(mintInput.value, 18); refresh(p); };
        collInput.oninput = () => { editor!.collAmount = safeParse(collInput.value, dec); refresh(p); };
        priceInput.oninput = () => { editor!.liqPrice = safeParse(priceInput.value, priceDigits); refresh(p); };

        const setMint = (v: bigint) => { editor!.mintAmount = v; mintInput.value = formatUnits(v, 18); refresh(p); };
        const setColl = (v: bigint) => { editor!.collAmount = v; collInput.value = formatUnits(v, dec); refresh(p); };
        const setPrice = (v: bigint) => { editor!.liqPrice = v; priceInput.value = formatUnits(v, priceDigits); refresh(p); };

        // mint MIN = how low you could repay to, given user ZCHF balance
        $("btn-min-mint").onclick = () => {
            const denom = 1_000_000n - BigInt(p.reserveContribution);
            const repayCapacity = denom > 0n ? (p.userZchfBalance * 1_000_000n) / denom : 0n;
            setMint(p.minted > repayCapacity ? p.minted - repayCapacity : 0n);
        };
        // mint MAX = min(globalCap, liqPrice * collateral / 1e18)
        $("btn-max-mint").onclick = () => {
            const cap = p.availableForMinting + p.minted;
            const byCollat = (editor!.liqPrice * editor!.collAmount) / ONE_E18;
            setMint(byCollat < cap ? byCollat : cap);
        };
        // collateral MIN = ceil(mint * 1e18 / liqPrice)
        $("btn-min-coll").onclick = () => {
            if (editor!.liqPrice > 0n) {
                setColl((editor!.mintAmount * ONE_E18 + editor!.liqPrice - 1n) / editor!.liqPrice);
            }
        };
        // price MIN = ceil(mint * 1e18 / collateral) — minimum to support the mint
        $("btn-min-price").onclick = () => {
            if (editor!.collAmount > 0n) {
                setPrice((editor!.mintAmount * ONE_E18 + editor!.collAmount - 1n) / editor!.collAmount);
            }
        };
        // price MAX = 80% of market (if available, else no-op)
        $("btn-max-price").onclick = () => {
            if (marketPrice80Pct > 0n) setPrice(marketPrice80Pct);
        };

        // resets
        $("btn-reset-mint").onclick = () => setMint(p.minted);
        $("btn-reset-coll").onclick = () => setColl(p.collateralBalance);
        $("btn-reset-price").onclick = () => setPrice(p.price);

        $("btn-adjust").onclick = () => doAdjust(p);
    }

    function getError(p: MyPositionDetail): string | null {
        if (!editor) return null;
        const { mintAmount, collAmount, liqPrice } = editor;
        if (p.isClosed) return i18n.errClosed;
        // cooldown only blocks INCREASING mint. reducing or pure-collateral edits allowed.
        if (isCooldown(p) && mintAmount > p.minted) return i18n.errCooldown;
        if (isChallenged(p) && collAmount < p.collateralBalance) return i18n.errChallenged;
        const max = p.availableForMinting + p.minted;
        if (mintAmount > max) return i18n.errAmountLimit;
        if (liqPrice * collAmount < mintAmount * ONE_E18) return i18n.errCollateralLow;
        if (mintAmount > p.minted && liqPrice > p.price) return i18n.errPriceLocked;
        const diff = mintAmount - p.minted;
        if (diff < 0n) {
            const reserveReturn = ((-diff) * BigInt(p.reserveContribution)) / 1_000_000n;
            if (((-diff) - reserveReturn) > p.userZchfBalance) return i18n.errBalanceLow;
        }
        return null;
    }

    function refresh(p: MyPositionDetail) {
        if (!editor) return;
        const { mintAmount, collAmount, liqPrice } = editor;

        // Validation
        const err = getError(p);
        const errEl = $("adjust-error");
        if (!errEl.querySelector(".rpc-error")) {
            if (err) { errEl.textContent = err; errEl.className = "mt-4 text-[13px] text-primary"; errEl.classList.remove("hidden"); }
            else { errEl.classList.add("hidden"); errEl.textContent = ""; }
        }

        // Collateral wallet-side note
        const collNote = $("i-coll-note");
        if (collAmount === p.collateralBalance) {
            collNote.classList.add("hidden"); collNote.textContent = "";
        } else {
            const delta = abs(collAmount - p.collateralBalance);
            const amtStr = fmt(fromBig(delta, p.collateralDecimals), 4);
            const tpl = collAmount < p.collateralBalance ? i18n.noteCollSentBack : i18n.noteCollTaken;
            collNote.textContent = tpl.replace("{amount}", amtStr).replace("{symbol}", p.collateralSymbol);
            collNote.classList.remove("hidden");
        }

        // Outcome math
        const diff = mintAmount - p.minted;
        const reservePPM = BigInt(p.reserveContribution);
        const reserveDelta = (diff * reservePPM) / 1_000_000n;
        const secsLeft = BigInt(Math.max(0, p.expiration - Math.floor(Date.now() / 1000)));
        const feePPM = (secsLeft * BigInt(p.annualInterestPPM)) / BigInt(365 * 86400);
        const fee = diff > 0n ? (diff * feePPM) / 1_000_000n : 0n;
        const wallet = diff - reserveDelta - fee;
        const absDiff = abs(diff);
        const pct = (n: bigint) => absDiff > 0n
            ? ((Number(abs(n) * 10_000n / absDiff) / 100).toFixed(2))
            : "0.00";

        const isInc = diff >= 0n;
        $("o-current").textContent = `${fmtZCHF(fromBig(p.minted, 18))} ZCHF`;
        $("o-future").textContent = `${fmtZCHF(fromBig(mintAmount, 18))} ZCHF`;

        $("o-wallet-label").textContent = isInc ? i18n.outcomeWalletInc : i18n.outcomeWalletDec;
        $("o-wallet-pct").textContent = `(${pct(wallet)}%)`;
        $("o-wallet").textContent = `${wallet >= 0n ? "" : "−"}${fmtZCHF(fromBig(abs(wallet), 18))} ZCHF`;

        $("o-reserve-label").textContent = isInc ? i18n.outcomeReserveAdd : i18n.outcomeReserveReturn;
        $("o-reserve-pct").textContent = `(${pct(reserveDelta)}%)`;
        $("o-reserve").textContent = `${fmtZCHF(fromBig(abs(reserveDelta), 18))} ZCHF`;

        $("o-fee-pct").textContent = `(${pct(fee)}%)`;
        $("o-fee").textContent = `−${fmtZCHF(fromBig(fee, 18))} ZCHF`;

        // Button state
        const collDelta = collAmount > p.collateralBalance ? collAmount - p.collateralBalance : 0n;
        const needsApproval = collDelta > 0n && collDelta > p.userCollateralAllowance;
        const labelEl = document.querySelector(".btn-action-label") as HTMLElement;
        labelEl.textContent = needsApproval
            ? i18n.actionApprove.replace("{symbol}", p.collateralSymbol)
            : i18n.actionAdjust;
        const noChange = mintAmount === p.minted && collAmount === p.collateralBalance && liqPrice === p.price;
        $<HTMLButtonElement>("btn-adjust").disabled = !!err || noChange;
    }

    // ================== tx flow ==================
    async function doAdjust(p: MyPositionDetail) {
        if (!connected || !editor) return;
        const { mintAmount, collAmount, liqPrice } = editor;
        const errEl = $("adjust-error");
        if (errEl.querySelector(".rpc-error")) { errEl.classList.add("hidden"); errEl.innerHTML = ""; }

        if (!(await ensureMainnet())) return;

        const collDelta = collAmount > p.collateralBalance ? collAmount - p.collateralBalance : 0n;
        const needsApproval = collDelta > 0n && collDelta > p.userCollateralAllowance;

        const publicClient = getPublicClient("ethereum");
        const rawProvider = getRawProvider();
        if (!rawProvider) { toast(i18n.notConnectedToast, "error"); return; }
        const walletClient = makeWalletClient(rawProvider, "ethereum");

        const btn = $<HTMLButtonElement>("btn-adjust");
        const labelEl = document.querySelector(".btn-action-label") as HTMLElement;
        const orig = labelEl.textContent ?? "";
        btn.disabled = true;

        try {
            if (needsApproval) {
                labelEl.textContent = i18n.actionApproving.replace("{symbol}", p.collateralSymbol);
                const hash = await walletClient.writeContract({
                    address: p.collateral, abi: erc20Abi, functionName: "approve",
                    args: [p.address, MAX_UINT256], account: connected, chain: mainnet,
                });
                await publicClient.waitForTransactionReceipt({ hash });
                toast(i18n.toastApproved.replace("{symbol}", p.collateralSymbol), "success");
                await refreshPositions();
                return;
            }

            labelEl.textContent = i18n.actionAdjusting;
            const hash = await walletClient.writeContract({
                address: p.address, abi: PositionV2ABI, functionName: "adjust",
                args: [mintAmount, collAmount, liqPrice], account: connected, chain: mainnet,
            });
            await publicClient.waitForTransactionReceipt({ hash });
            toast(i18n.toastAdjusted, "success");
            await refreshPositions();
        } catch (err) {
            if (isUserCancelErr(err)) toast(i18n.cancelled, "info");
            else if (isWalletRpcError(err)) {
                errEl.classList.remove("hidden");
                errEl.className = "mt-4";
                errEl.innerHTML = `<div class="rpc-error">
                    <div class="rpc-error-title">${i18n.errRpcTitle}</div>
                    <div class="rpc-error-body">${i18n.errRpcBody}</div>
                    <div class="rpc-error-help">${i18n.errRpcHelp}</div>
                </div>`;
            } else {
                toast(friendlyError(err).message, "error");
            }
        } finally {
            labelEl.textContent = orig;
            btn.disabled = false;
            refresh(p);
        }
    }

    // ================== init ==================
    $("btn-back").onclick = () => navigate(null);

    // Parse ?owner=... at boot. Once set, the page stays in public mode
    // regardless of wallet state — closing public view is explicit (the
    // banner has a Close link that removes the param).
    {
        const o = new URLSearchParams(location.search).get("owner");
        if (o && isAddrLike(o)) publicOwner = o;
    }

    async function refreshPositions() {
        // Determine whose positions to list. Public view wins over connected
        // wallet so the URL is authoritative.
        const ownerAddr: Address | null = publicOwner ?? connected;
        if (!ownerAddr) {
            positions = []; lastRenderedAddress = null;
            renderList(); return;
        }
        setListState("loading");
        try {
            const addrs = await findUserPositions(ownerAddr);
            // In public view: pass null for user so balance/allowance calls
            // are skipped, and pass the owner explicitly so API rows resolve.
            positions = publicOwner
                ? await loadMyPositionDetails(addrs, null, ownerAddr)
                : await loadMyPositionDetails(addrs, connected);
        } catch (err) {
            console.error("[mypositions] refresh failed:", err);
            positions = [];
        }
        applyRoute();
    }

    getOnboard().state.select("wallets").subscribe(async (wallets) => {
        const newAddr = wallets[0]?.accounts[0]?.address as Address | null;
        if (newAddr !== connected) {
            connected = newAddr;
            lastRenderedAddress = null;
            // In public view we don't re-fetch on wallet change — the URL
            // owner stays the source of truth.
            if (!publicOwner) await refreshPositions();
            else applyRoute();
        } else {
            applyRoute();
        }
    });

    // Public view boots without waiting for a wallet — fire an initial fetch
    // right away so the list populates immediately.
    if (publicOwner) {
        refreshPositions();
    } else {
        applyRoute();
    }

    window.addEventListener("storage", (ev) => {
        if (ev.key === "frnk:invalidatePositions:v1") {
            clearAllPositionsCache();
            refreshPositions();
        }
    });
</script>