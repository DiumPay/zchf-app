---
import Layout from "@layouts/Layout.astro";
import Card from "@components/Card.astro";
import MintHeader from "@components/mint/MintHeader.astro";
import LinkedInputs from "@components/mint/LinkedInputs.astro";
import PriceSlider from "@components/mint/PriceSlider.astro";
import ExpirationPicker from "@components/mint/ExpirationPicker.astro";
import OutcomeBreakdown from "@components/mint/OutcomeBreakdown.astro";
import MintActions from "@components/mint/MintActions.astro";
import snapshot from "@data/positions-snapshot.json";
import { t, getLocale } from "@i18n/t";

import zchfIcon from "@assets/tokens/zchf.svg?url";
import bossIcon from "@assets/tokens/boss.svg?url";
import cbbtcIcon from "@assets/tokens/cbbtc.svg?url";
import crvIcon from "@assets/tokens/crv.svg?url";
import gnoIcon from "@assets/tokens/gno.svg?url";
import lendsIcon from "@assets/tokens/lends.svg?url";
import lsethIcon from "@assets/tokens/lseth.svg?url";
import paxgIcon from "@assets/tokens/paxg.svg?url";
import realuIcon from "@assets/tokens/realu.svg?url";
import spyonIcon from "@assets/tokens/spyon.svg?url";
import wbtcIcon from "@assets/tokens/wbtc.svg?url";
import wethIcon from "@assets/tokens/weth.svg?url";
import wstethIcon from "@assets/tokens/wsteth.svg?url";
import xautIcon from "@assets/tokens/xaut.svg?url";
import ysyboldIcon from "@assets/tokens/ysybold.svg?url";

const ICONS: Record<string, string> = {
    boss: bossIcon, cbbtc: cbbtcIcon, crv: crvIcon, gno: gnoIcon, lends: lendsIcon,
    lseth: lsethIcon, paxg: paxgIcon, realu: realuIcon, spyon: spyonIcon, wbtc: wbtcIcon,
    weth: wethIcon, wsteth: wstethIcon, xaut: xautIcon, ysybold: ysyboldIcon,
};

export async function getStaticPaths() {
    return snapshot.positions.map(p => ({
        params: { address: p.address },
        props: { position: p },
    }));
}

const { position } = Astro.props;
const iconUrl = ICONS[position.collateralSymbol.toLowerCase()] ?? null;
const tt = t(Astro.url);
const sym = position.collateralSymbol;

const i18n = {
    statusLabel: tt("mint_status_active"),
    cloneLabel: tt("mint_badge_clone"),
    positionContractLabel: tt("mint_meta_position"),
    tokenLabel: tt("mint_meta_token").replace("{symbol}", sym),
    cardTitle: tt("mint_card_title"),
    depositLabel: tt("mint_input_deposit"),
    mintNowLabel: tt("mint_input_mint_now"),
    maxLabel: tt("mint_input_max"),
    balanceLabel: tt("mint_input_balance"),
    mintableLabel: tt("mint_input_mintable"),
    poolCapacityLabel: tt("mint_input_pool_capacity"),
    sliderLabel: tt("mint_slider_label"),
    referenceLabel: tt("mint_slider_reference"),
    ltvLabel: tt("mint_slider_ltv"),
    cooldownWarning: tt("mint_slider_cooldown_warning"),
    fallbackTitle: tt("mint_slider_no_oracle_title"),
    fallbackText: tt("mint_slider_no_oracle_text"),
    expiryLabel: tt("mint_expiry_label"),
    expiryMaxLabel: tt("mint_expiry_max"),
    mintedLabel: tt("mint_outcome_minted"),
    reserveLabel: tt("mint_outcome_reserve"),
    repaidLabel: tt("mint_outcome_repaid"),
    interestLabel: tt("mint_outcome_interest"),
    perYearTemplate: tt("mint_outcome_per_year"),
    sentLabel: tt("mint_outcome_sent"),
    mintLabel: tt("mint_action_mint"),
    connectLabel: tt("wallet_connect"),
};

const clientI18n = {
    perYearTemplate: tt("mint_outcome_per_year"),
    expiryHintTemplate: tt("mint_expiry_hint"),
    actionMint: tt("mint_action_mint"),
    actionApproveTemplate: tt("mint_action_approve_required"),
    actionApproving: tt("mint_action_approving").replace("{symbol}", sym),
    actionMinting: tt("mint_action_minting"),
    actionSwitching: tt("mint_action_switching"),
    errAmountRequired: tt("mint_err_amount_required"),
    errMinCollateralTemplate: tt("mint_err_min_collateral"),
    errBalanceLow: tt("mint_err_balance_low").replace("{symbol}", sym),
    errExceedsPool: tt("mint_err_exceeds_pool"),
    errExceedsCollateral: tt("mint_err_exceeds_collateral"),
    errRpcTitle: tt("mint_err_rpc_title"),
    errRpcBody: tt("mint_err_rpc_body"),
    errRpcHelp: tt("mint_err_rpc_help"),
    toastApproved: tt("mint_toast_approved").replace("{symbol}", sym),
    toastMinted: tt("mint_toast_minted"),
    statusPending: tt("mint_status_pending"),
    statusCooldown: tt("mint_status_cooldown"),
    cancelled: tt("common_cancelled"),
    notConnected: tt("wallet_not_connected"),
    symbol: sym,
};
---

<Layout title={`${i18n.cardTitle} | ${sym}`} description={`${i18n.cardTitle}: ${position.collateralName}`}>
    <main class="mx-auto max-w-3xl px-4 py-10 md:px-6 md:py-12">
        <MintHeader
            name={position.collateralName} symbol={sym} iconUrl={iconUrl}
            address={position.address} collateral={position.collateral}
            isClone={!position.isOriginal}
            statusLabel={i18n.statusLabel} cloneLabel={i18n.cloneLabel}
            positionContractLabel={i18n.positionContractLabel} tokenLabel={i18n.tokenLabel}
        />
        <Card title={i18n.cardTitle}>
            <div class="space-y-5">
                <LinkedInputs
                    collateralSymbol={sym} collateralIconUrl={iconUrl} zchfIconUrl={zchfIcon}
                    depositLabel={i18n.depositLabel} mintNowLabel={i18n.mintNowLabel}
                    maxLabel={i18n.maxLabel} balanceLabel={i18n.balanceLabel}
                    mintableLabel={i18n.mintableLabel} poolCapacityLabel={i18n.poolCapacityLabel}
                />
                <PriceSlider
                    label={i18n.sliderLabel} referenceLabel={i18n.referenceLabel}
                    ltvLabel={i18n.ltvLabel} cooldownWarning={i18n.cooldownWarning}
                    fallbackTitle={i18n.fallbackTitle} fallbackText={i18n.fallbackText}
                />
                <ExpirationPicker label={i18n.expiryLabel} maxLabel={i18n.expiryMaxLabel} />
                <OutcomeBreakdown
                    mintedLabel={i18n.mintedLabel} reserveLabel={i18n.reserveLabel}
                    repaidLabel={i18n.repaidLabel} interestLabel={i18n.interestLabel}
                    sentLabel={i18n.sentLabel}
                />
                <MintActions mintLabel={i18n.mintLabel} connectLabel={i18n.connectLabel} />
            </div>
        </Card>
    </main>

    <script id="position-data" type="application/json" set:html={JSON.stringify({
        address: position.address, original: position.original, isOriginal: position.isOriginal,
        collateral: position.collateral, collateralName: position.collateralName,
        collateralSymbol: position.collateralSymbol, collateralDecimals: position.collateralDecimals,
        minimumCollateral: position.minimumCollateral, limit: position.limit,
        expiration: position.expiration, start: position.start,
        challengePeriod: position.challengePeriod, riskPremiumPPM: position.riskPremiumPPM,
        reserveContribution: position.reserveContribution,
    })}></script>
    <script id="mint-i18n" type="application/json" set:html={JSON.stringify(clientI18n)}></script>
    <script id="mint-locale" type="application/json" set:html={JSON.stringify(getLocale(Astro.url))}></script>
</Layout>

<script>
    import { type Address } from "viem";
    import { getPublicClient, makeWalletClient } from "@lib/client";
    import { getOnboard } from "@lib/onboard";
    import { toast } from "@lib/toast";
    import { friendlyError } from "@lib/errors";
    import { ADDRESSES } from "@config/addresses";
    import { getMarketPriceCHF } from "@lib/prices";
    import { findStaticPosition, loadPositionDetail, type PositionStaticDetail } from "@lib/positionDetail";
    import { getAllowance, approveCollateral, executeClone, executeCloneWithPrice } from "@lib/borrowActions";
    import { clearPositionsCache } from "@lib/positions";
    import { previewCloneWithPrice, validateCloneInputs, type CloneParentInfo } from "@lib/cloneHelper";
    import { getRawProvider, readChainId, forceMainnet, isUserCancelErr, isWalletRpcError, ETH_CHAIN_ID_HEX } from "@lib/walletProvider";
    import { fmt, fmtPlain, parseNum, toBig, fromBig, applyClamp, guardKeystrokes } from "@lib/inputFormat";
    import { localePath } from "@i18n/t";
    import type { Locale } from "@i18n/messages";

    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const data = JSON.parse($("position-data").textContent || "{}") as PositionStaticDetail & { limit: any; minimumCollateral: any };
    const i18n = JSON.parse($("mint-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("mint-locale").textContent || '"en"') as string;

    const PRICE_DIGIT = 36 - data.collateralDecimals;
    const SLIDER_RES = 1000;
    const ONE_E18 = 10n ** 18n;

    // ─── State ──────────────────────────────────────────────────────────
    let lastEdited: "coll" | "mint" = "coll";
    let linked = true;
    let maxSelected = true;
    let collAmount = BigInt(data.minimumCollateral);
    let parentPrice = 1n;
    let newPrice = parentPrice;
    let mintAmount = 0n;

    let connected: Address | null = null;
    let userBalance = 0n;
    let availableForClones = 0n;
    let annualInterestPPM = 0;
    let allowanceHub = 0n;
    let allowanceHelper = 0n;
    let isClosed = false;
    let cooldown = 0;
    let collateralPriceZchf = 0;

    const e = {
        coll: $("input-coll") as HTMLInputElement, mint: $("input-mint") as HTMLInputElement,
        balanceColl: $("balance-coll"), mintable: $("mintable-amount"), poolCapacity: $("pool-capacity"),
        maxColl: $("btn-max-coll") as HTMLButtonElement, maxMint: $("btn-max-mint") as HTMLButtonElement,
        link: $("btn-link") as HTMLButtonElement, linkWrap: $("link-wrap"),
        sliderSection: $("slider-section"), sliderFallback: $("slider-fallback"),
        slider: $("slider-price") as HTMLInputElement,
        priceValue: $("price-value"), priceValueStatic: $("price-value-static"),
        ltv: $("ltv-value"), cooldownWarn: $("cooldown-warning"),
        date: $("input-date") as HTMLInputElement, expiryHint: $("expiry-hint"),
        outMinted: $("out-minted"), outReserve: $("out-reserve"), outReservePct: $("out-reserve-pct"),
        outRepaid: $("out-repaid"), outRepaidPct: $("out-repaid-pct"),
        outFee: $("out-fee"), outRate: $("out-rate"), outNet: $("out-net"),
        actionsConnected: $("actions-connected"), actionsDisconnected: $("actions-disconnected"),
        action: $("btn-action") as HTMLButtonElement,
        actionLabel: document.querySelector(".btn-action-label") as HTMLElement,
        actionError: $("action-error"),
        connect: $("btn-connect") as HTMLButtonElement, banner: $("banner"),
    };

    // ─── Errors ─────────────────────────────────────────────────────────
    function showError(msg: string | null) {
        e.actionError.classList.toggle("hidden", !msg);
        e.actionError.textContent = msg ?? "";
    }
    function showRpcError() {
        e.actionError.classList.remove("hidden");
        e.actionError.innerHTML = "";
        const wrap = document.createElement("div");
        wrap.className = "rpc-error";
        for (const [cls, text] of [["rpc-error-title", i18n.errRpcTitle], ["rpc-error-body", i18n.errRpcBody], ["rpc-error-help", i18n.errRpcHelp]] as const) {
            const div = document.createElement("div");
            div.className = cls;
            div.textContent = text;
            wrap.append(div);
        }
        e.actionError.append(wrap);
    }
    function handleErr(err: any) {
        if (isUserCancelErr(err)) toast(i18n.cancelled, "info");
        else if (isWalletRpcError(err)) showRpcError();
        else toast(friendlyError(err).message, "error");
    }

    // ─── Slider math (price <-> %, only thing not in lib because it's UI-specific) ─
    function bounds() {
        const m = collateralPriceZchf || 1;
        return { min: m * 0.1, max: m };
    }
    function pct(priceBig: bigint): number {
        const { min, max } = bounds();
        const v = fromBig(priceBig, PRICE_DIGIT);
        const scale = Math.max(max - min, 1e-10);
        return Math.max(0, Math.min(100, ((v - min) / scale) * 100));
    }
    function sliderToPrice(slv: number): bigint {
        const { min, max } = bounds();
        return toBig(min + (slv / SLIDER_RES) * (max - min), PRICE_DIGIT);
    }
    function priceToSlider(priceBig: bigint): number {
        const { min, max } = bounds();
        const v = fromBig(priceBig, PRICE_DIGIT);
        const scale = Math.max(max - min, 1e-10);
        return Math.max(0, Math.min(SLIDER_RES, ((v - min) / scale) * SLIDER_RES));
    }

    // ─── Adapters: page state -> cloneHelper lib shapes ─────────────────
    function asParent(): CloneParentInfo {
        return {
            address: data.address as Address,
            price: parentPrice,
            minimumCollateral: BigInt(data.minimumCollateral),
            collateralDecimals: data.collateralDecimals,
            reserveContribution: data.reserveContribution,
            annualInterestPPM,
            expiration: data.expiration,
            availableForClones,
        };
    }
    function activeAllowance(): bigint {
        return newPrice === parentPrice ? allowanceHub : allowanceHelper;
    }
    function activeSpender(): Address {
        return (newPrice === parentPrice ? ADDRESSES.ethereum.mintingHubV2! : ADDRESSES.ethereum.cloneHelper!) as Address;
    }
    const TAB_DAYS: Record<string, number> = { "1M": 30, "3M": 90, "6M": 180, "1Y": 365 };
    function pickedDateTs(): number {
        if (!e.date.value || maxSelected) return data.expiration;
        const localEod = Math.floor(new Date(`${e.date.value}T23:59:59`).getTime() / 1000);
        return Math.min(localEod, data.expiration);
    }
    function applyTab(tab: string) {
        maxSelected = tab === "MAX";
        const max = new Date(data.expiration * 1000);
        const target = tab === "MAX" ? max : new Date(Math.min(Date.now() + TAB_DAYS[tab] * 86400e3, max.getTime()));
        e.date.value = target.toISOString().slice(0, 10);
        document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(b => b.classList.toggle("active", b.dataset.tab === tab));
        render();
    }

    // ─── Linked input sync ──────────────────────────────────────────────
    function effectivePrice(): bigint {
        return newPrice <= parentPrice ? newPrice : parentPrice;
    }
    function syncFromLastEdited() {
        if (!linked) return;
        const p = effectivePrice();
        if (lastEdited === "coll") mintAmount = (collAmount * p) / ONE_E18;
        else if (p > 0n) collAmount = (mintAmount * ONE_E18 + p - 1n) / p;
    }

    // ─── Render: pull preview from lib, paint DOM ──────────────────────
    function render() {
        const dec = data.collateralDecimals;
        const preview = previewCloneWithPrice(asParent(), {
            collateralAmount: collAmount, mintAmount, expiration: pickedDateTs(), newPrice,
        });

        // Slider visuals
        const priceFloat = fromBig(newPrice, PRICE_DIGIT);
        e.priceValue.textContent = fmt(priceFloat, 2, priceFloat < 1 ? 4 : 2);
        if (collateralPriceZchf > 0) {
            e.sliderSection.style.setProperty("--source", `${pct(parentPrice)}%`);
            e.sliderSection.style.setProperty("--value", `${pct(newPrice)}%`);
            e.slider.value = String(priceToSlider(newPrice));
        }
        e.ltv.textContent = collateralPriceZchf > 0 ? `${fmt((priceFloat / collateralPriceZchf) * 100, 2, 2)}%` : "—";
        e.cooldownWarn.classList.toggle("hidden", !preview.triggersCooldown);

        // Capacities + inputs
        e.mintable.textContent = fmt(fromBig(preview.mintLimitNow, 18), 0, 0);
        e.poolCapacity.textContent = `${fmt(fromBig(availableForClones, 18), 0, 0)} ZCHF`;
        if (document.activeElement !== e.coll) e.coll.value = fmtPlain(fromBig(collAmount, dec), dec);
        if (document.activeElement !== e.mint) e.mint.value = fmtPlain(fromBig(mintAmount, 18), 18);

        // Outcome breakdown — all numbers from preview
        const reservePct = data.reserveContribution / 10000;
        e.outMinted.textContent = `${fmt(fromBig(mintAmount, 18), 0, 2)} ZCHF`;
        e.outReserve.textContent = `−${fmt(fromBig(preview.reserveAmount, 18), 0, 2)} ZCHF`;
        e.outReservePct.textContent = `(${fmt(reservePct, 0, 2)}%)`;
        e.outRepaid.textContent = `${fmt(fromBig(mintAmount - preview.reserveAmount, 18), 0, 2)} ZCHF`;
        e.outRepaidPct.textContent = `(${fmt(100 - reservePct, 0, 2)}%)`;
        e.outFee.textContent = `−${fmt(fromBig(preview.upfrontInterest, 18), 0, 2)} ZCHF`;
        e.outRate.textContent = `(${i18n.perYearTemplate.replace("{rate}", fmt(preview.effectiveAnnualRate * 100, 2, 2))})`;
        e.outNet.textContent = `${fmt(fromBig(preview.netToWallet, 18), 0, 2)} ZCHF`;

        // Expiry hint
        if (e.date.value) {
            const d = new Date(pickedDateTs() * 1000);
            e.expiryHint.textContent = i18n.expiryHintTemplate
                .replace("{date}", d.toLocaleDateString(undefined, { day: "2-digit", month: "short", year: "numeric" }))
                .replace("{time}", d.toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" }));
        } else e.expiryHint.innerHTML = "&nbsp;";

        // Validation -> error panel + button state
        const issues = validateCloneInputs(asParent(), {
            collateralAmount: collAmount, mintAmount, expiration: pickedDateTs(), newPrice,
        });
        const i18nForIssue = (code: string): string => {
            switch (code) {
                case "below_minimum": return i18n.errMinCollateralTemplate
                    .replace("{amount}", fmt(fromBig(BigInt(data.minimumCollateral), dec), 0, dec))
                    .replace("{symbol}", i18n.symbol);
                case "exceeds_capacity": return mintAmount > availableForClones ? i18n.errExceedsPool : i18n.errExceedsCollateral;
                case "expiration_past": case "expiration_after_parent": return i18n.errAmountRequired;
                default: return i18n.errAmountRequired;
            }
        };
        const balanceLow = !!connected && collAmount > userBalance;
        const reason = mintAmount <= 0n ? i18n.errAmountRequired
            : balanceLow ? i18n.errBalanceLow
            : issues[0] ? i18nForIssue(issues[0].code) : null;

        if (!e.actionError.querySelector(".rpc-error")) {
            showError(connected && mintAmount > 0n ? reason : null);
        }

        // Action button
        if (connected) {
            const needsApproval = activeAllowance() < collAmount;
            e.actionLabel.textContent = needsApproval
                ? i18n.actionApproveTemplate.replace("{symbol}", i18n.symbol)
                : i18n.actionMint;
            e.action.disabled = !!reason || balanceLow || isPositionBlocked();
        }

        // Banner
        const now = Date.now();
        if (data.start * 1000 > now) {
            e.banner.textContent = i18n.statusPending;
            e.banner.classList.remove("hidden");
        } else if (cooldown * 1000 > now) {
            e.banner.textContent = i18n.statusCooldown;
            e.banner.classList.remove("hidden");
        } else e.banner.classList.add("hidden");
    }
    function isPositionBlocked(): boolean {
        if (isClosed) return true;
        const now = Date.now();
        return data.start * 1000 > now || cooldown * 1000 > now;
    }

    // ─── Input handlers ────────────────────────────────────────────────
    guardKeystrokes(e.coll, data.collateralDecimals);
    guardKeystrokes(e.mint, 18);

    e.coll.addEventListener("input", () => {
        lastEdited = "coll";
        collAmount = toBig(parseNum(applyClamp(e.coll, data.collateralDecimals)), data.collateralDecimals);
        syncFromLastEdited();
        render();
    });
    e.mint.addEventListener("input", () => {
        lastEdited = "mint";
        mintAmount = toBig(parseNum(applyClamp(e.mint, 18)), 18);
        syncFromLastEdited();
        render();
    });
    e.maxColl.addEventListener("click", () => { collAmount = userBalance; lastEdited = "coll"; syncFromLastEdited(); render(); });
    e.maxMint.addEventListener("click", () => {
        const preview = previewCloneWithPrice(asParent(), { collateralAmount: collAmount, mintAmount: 0n, expiration: pickedDateTs(), newPrice });
        mintAmount = preview.mintLimitNow;
        lastEdited = "mint";
        syncFromLastEdited();
        render();
    });
    e.link.addEventListener("click", () => {
        linked = !linked;
        e.linkWrap.classList.toggle("broken", !linked);
        if (linked && newPrice > parentPrice) newPrice = parentPrice;
        if (linked) syncFromLastEdited();
        render();
    });
    e.slider.addEventListener("input", () => {
        const proposed = sliderToPrice(Number(e.slider.value));
        newPrice = (linked && proposed > parentPrice) ? parentPrice : proposed;
        syncFromLastEdited();
        render();
    });
    e.date.addEventListener("change", () => {
        maxSelected = false;
        document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(b => b.classList.remove("active"));
        render();
    });
    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(b =>
        b.addEventListener("click", () => applyTab(b.dataset.tab!)));
    e.connect.addEventListener("click", () => getOnboard().connectWallet());

    // ─── Tx flow ───────────────────────────────────────────────────────
    function lockBtn(label: string) {
        const original = e.actionLabel.textContent ?? "";
        e.action.dataset.loading = "1";
        e.action.disabled = true;
        e.actionLabel.textContent = label;
        return () => { delete e.action.dataset.loading; e.actionLabel.textContent = original; render(); };
    }

    async function ensureMainnet(): Promise<boolean> {
        if (await readChainId() === ETH_CHAIN_ID_HEX) return true;
        const unlock = lockBtn(i18n.actionSwitching);
        try {
            await forceMainnet();
            if (await readChainId() !== ETH_CHAIN_ID_HEX) { toast(i18n.cancelled, "info"); return false; }
            return true;
        } catch (err) { handleErr(err); return false; }
        finally { unlock(); }
    }

    e.action.addEventListener("click", async () => {
        if (!connected) return;
        e.actionError.classList.add("hidden");
        e.actionError.innerHTML = "";
        if (!(await ensureMainnet())) return;

        const issues = validateCloneInputs(asParent(), {
            collateralAmount: collAmount, mintAmount, expiration: pickedDateTs(), newPrice,
        });
        if (issues.length > 0 || mintAmount <= 0n) { render(); return; }

        const publicClient = getPublicClient("ethereum");
        const rawProvider = getRawProvider();
        if (!rawProvider) { toast(i18n.notConnected, "error"); return; }
        const walletClient = makeWalletClient(rawProvider, "ethereum");
        const needsApproval = activeAllowance() < collAmount;

        if (needsApproval) {
            const unlock = lockBtn(i18n.actionApproving);
            try {
                await approveCollateral(walletClient, publicClient, data.collateral as Address, activeSpender(), connected);
                if (newPrice === parentPrice) {
                    allowanceHub = await getAllowance(publicClient, data.collateral as Address, connected, ADDRESSES.ethereum.mintingHubV2! as Address);
                } else {
                    allowanceHelper = await getAllowance(publicClient, data.collateral as Address, connected, ADDRESSES.ethereum.cloneHelper! as Address);
                }
                toast(i18n.toastApproved, "success");
            } catch (err) { handleErr(err); }
            finally { unlock(); }
            return;
        }

        const unlock = lockBtn(i18n.actionMinting);
        try {
            const args = { parent: data.address as Address, collateral: collAmount, mint: mintAmount, expiration: pickedDateTs(), account: connected };
            const result = newPrice === parentPrice
                ? await executeClone(walletClient, publicClient, args)
                : await executeCloneWithPrice(walletClient, publicClient, { ...args, newPrice });
            toast(i18n.toastMinted, "success");
            clearPositionsCache();
            window.location.href = localePath(locale as Locale, `/mypositions/${result.position}`);
        } catch (err) { handleErr(err); }
        finally { unlock(); }
    });

    // ─── Init ──────────────────────────────────────────────────────────
    function setConnectedUI(isConnected: boolean) {
        e.actionsConnected.classList.toggle("hidden", !isConnected);
        e.actionsDisconnected.classList.toggle("hidden", isConnected);
        e.maxColl.disabled = !isConnected;
    }

    e.date.max = new Date(data.expiration * 1000).toISOString().slice(0, 10);
    e.date.min = new Date().toISOString().slice(0, 10);
    applyTab("MAX");

    async function refreshPositionDetail() {
        const staticInfo = findStaticPosition(data.address);
        if (!staticInfo) return;
        const userAtFetchStart = connected;
        try {
            const detail = await loadPositionDetail(staticInfo, userAtFetchStart);
            parentPrice = detail.price;
            if (newPrice === parentPrice || newPrice === 1n) newPrice = detail.price;
            availableForClones = detail.availableForClones;
            annualInterestPPM = detail.annualInterestPPM;
            isClosed = detail.isClosed;
            cooldown = detail.cooldown;
            if (userAtFetchStart) {
                userBalance = detail.userBalance;
                allowanceHub = detail.allowanceHub;
                allowanceHelper = detail.allowanceHelper;
            } else {
                userBalance = 0n;
                allowanceHub = 0n;
                allowanceHelper = 0n;
            }
            if (mintAmount === 0n) mintAmount = (parentPrice * collAmount) / ONE_E18;
            e.balanceColl.textContent = fmt(fromBig(userBalance, data.collateralDecimals), 2, 4);
            render();
        } catch (err) {
            console.error("loadPositionDetail failed:", err);
        }
    }

    getOnboard().state.select("wallets").subscribe((wallets) => {
        const w = wallets[0];
        if (w?.accounts[0]) { connected = w.accounts[0].address as Address; setConnectedUI(true); }
        else { connected = null; setConnectedUI(false); }
        refreshPositionDetail();
    });

    (async () => {
        const market = await getMarketPriceCHF(data.collateralSymbol);
        if (market === null || market <= 0) {
            e.sliderSection.classList.add("hidden");
            e.sliderFallback.classList.remove("hidden");
            e.priceValueStatic.textContent = fmt(fromBig(parentPrice, PRICE_DIGIT), 2, 4);
            return;
        }
        collateralPriceZchf = market;
        render();
    })();

    setConnectedUI(false);
    render();
</script>