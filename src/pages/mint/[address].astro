---
import Layout from "@layouts/Layout.astro";
import Card from "@components/Card.astro";
import MintHeader from "@components/mint/MintHeader.astro";
import LinkedInputs from "@components/mint/LinkedInputs.astro";
import PriceSlider from "@components/mint/PriceSlider.astro";
import ExpirationPicker from "@components/mint/ExpirationPicker.astro";
import OutcomeBreakdown from "@components/mint/OutcomeBreakdown.astro";
import MintActions from "@components/mint/MintActions.astro";
import snapshot from "@data/positions-snapshot.json";
import { t, getLocale } from "@i18n/t";

import zchfIcon from "@assets/tokens/zchf.svg?url";
import bossIcon from "@assets/tokens/boss.svg?url";
import cbbtcIcon from "@assets/tokens/cbbtc.svg?url";
import crvIcon from "@assets/tokens/crv.svg?url";
import gnoIcon from "@assets/tokens/gno.svg?url";
import lendsIcon from "@assets/tokens/lends.svg?url";
import lsethIcon from "@assets/tokens/lseth.svg?url";
import paxgIcon from "@assets/tokens/paxg.svg?url";
import realuIcon from "@assets/tokens/realu.svg?url";
import spyonIcon from "@assets/tokens/spyon.svg?url";
import wbtcIcon from "@assets/tokens/wbtc.svg?url";
import wethIcon from "@assets/tokens/weth.svg?url";
import wstethIcon from "@assets/tokens/wsteth.svg?url";
import xautIcon from "@assets/tokens/xaut.svg?url";
import ysyboldIcon from "@assets/tokens/ysybold.svg?url";

const ICONS: Record<string, string> = {
    boss: bossIcon, cbbtc: cbbtcIcon, crv: crvIcon, gno: gnoIcon, lends: lendsIcon,
    lseth: lsethIcon, paxg: paxgIcon, realu: realuIcon, spyon: spyonIcon, wbtc: wbtcIcon,
    weth: wethIcon, wsteth: wstethIcon, xaut: xautIcon, ysybold: ysyboldIcon,
};

export async function getStaticPaths() {
    return snapshot.positions.map(p => ({
        params: { address: p.address },
        props: { position: p },
    }));
}

const { position } = Astro.props;
const iconUrl = ICONS[position.collateralSymbol.toLowerCase()] ?? null;
const tt = t(Astro.url);
const sym = position.collateralSymbol;

const i18n = {
    statusLabel: tt("mint_status_active"),
    cloneLabel: tt("mint_badge_clone"),
    positionContractLabel: tt("mint_meta_position"),
    tokenLabel: tt("mint_meta_token").replace("{symbol}", sym),
    cardTitle: tt("mint_card_title"),
    depositLabel: tt("mint_input_deposit"),
    mintNowLabel: tt("mint_input_mint_now"),
    maxLabel: tt("mint_input_max"),
    balanceLabel: tt("mint_input_balance"),
    mintableLabel: tt("mint_input_mintable"),
    poolCapacityLabel: tt("mint_input_pool_capacity"),
    sliderLabel: tt("mint_slider_label"),
    referenceLabel: tt("mint_slider_reference"),
    ltvLabel: tt("mint_slider_ltv"),
    cooldownWarning: tt("mint_slider_cooldown_warning"),
    fallbackTitle: tt("mint_slider_no_oracle_title"),
    fallbackText: tt("mint_slider_no_oracle_text"),
    expiryLabel: tt("mint_expiry_label"),
    expiryMaxLabel: tt("mint_expiry_max"),
    mintedLabel: tt("mint_outcome_minted"),
    reserveLabel: tt("mint_outcome_reserve"),
    repaidLabel: tt("mint_outcome_repaid"),
    interestLabel: tt("mint_outcome_interest"),
    perYearTemplate: tt("mint_outcome_per_year"),
    sentLabel: tt("mint_outcome_sent"),
    mintLabel: tt("mint_action_mint"),
    connectLabel: tt("wallet_connect"),
};

const clientI18n = {
    perYearTemplate: tt("mint_outcome_per_year"),
    expiryHintTemplate: tt("mint_expiry_hint"),
    actionMint: tt("mint_action_mint"),
    actionApproveTemplate: tt("mint_action_approve_required"),
    actionApproving: tt("mint_action_approving").replace("{symbol}", sym),
    actionMinting: tt("mint_action_minting"),
    actionSwitching: tt("mint_action_switching"),
    errAmountRequired: tt("mint_err_amount_required"),
    errMinCollateralTemplate: tt("mint_err_min_collateral"),
    errBalanceLow: tt("mint_err_balance_low").replace("{symbol}", sym),
    errExceedsPool: tt("mint_err_exceeds_pool"),
    errExceedsCollateral: tt("mint_err_exceeds_collateral"),
    errRpcTitle: tt("mint_err_rpc_title"),
    errRpcBody: tt("mint_err_rpc_body"),
    errRpcHelp: tt("mint_err_rpc_help"),
    toastApproved: tt("mint_toast_approved").replace("{symbol}", sym),
    toastMinted: tt("mint_toast_minted"),
    statusPending: tt("mint_status_pending"),
    statusCooldown: tt("mint_status_cooldown"),
    cancelled: tt("common_cancelled"),
    notConnected: tt("wallet_not_connected"),
    symbol: sym,
};
---

<Layout title={`${i18n.cardTitle} | ${sym}`} description={`${i18n.cardTitle}: ${position.collateralName}`}>
    <main class="mx-auto max-w-3xl px-4 py-10 md:px-6 md:py-12">
        <MintHeader
            name={position.collateralName}
            symbol={sym}
            iconUrl={iconUrl}
            address={position.address}
            collateral={position.collateral}
            isClone={!position.isOriginal}
            statusLabel={i18n.statusLabel}
            cloneLabel={i18n.cloneLabel}
            positionContractLabel={i18n.positionContractLabel}
            tokenLabel={i18n.tokenLabel}
        />

        <Card title={i18n.cardTitle}>
            <div class="space-y-5">
                <LinkedInputs
                    collateralSymbol={sym}
                    collateralIconUrl={iconUrl}
                    zchfIconUrl={zchfIcon}
                    depositLabel={i18n.depositLabel}
                    mintNowLabel={i18n.mintNowLabel}
                    maxLabel={i18n.maxLabel}
                    balanceLabel={i18n.balanceLabel}
                    mintableLabel={i18n.mintableLabel}
                    poolCapacityLabel={i18n.poolCapacityLabel}
                />
                <PriceSlider
                    label={i18n.sliderLabel}
                    referenceLabel={i18n.referenceLabel}
                    ltvLabel={i18n.ltvLabel}
                    cooldownWarning={i18n.cooldownWarning}
                    fallbackTitle={i18n.fallbackTitle}
                    fallbackText={i18n.fallbackText}
                />
                <ExpirationPicker
                    label={i18n.expiryLabel}
                    maxLabel={i18n.expiryMaxLabel}
                />
                <OutcomeBreakdown
                    mintedLabel={i18n.mintedLabel}
                    reserveLabel={i18n.reserveLabel}
                    repaidLabel={i18n.repaidLabel}
                    interestLabel={i18n.interestLabel}
                    sentLabel={i18n.sentLabel}
                />
                <MintActions
                    mintLabel={i18n.mintLabel}
                    connectLabel={i18n.connectLabel}
                />
            </div>
        </Card>
    </main>

    <script id="position-data" type="application/json" set:html={JSON.stringify({
        address: position.address,
        original: position.original,
        isOriginal: position.isOriginal,
        collateral: position.collateral,
        collateralName: position.collateralName,
        collateralSymbol: position.collateralSymbol,
        collateralDecimals: position.collateralDecimals,
        minimumCollateral: position.minimumCollateral,
        limit: position.limit,
        expiration: position.expiration,
        start: position.start,
        challengePeriod: position.challengePeriod,
        riskPremiumPPM: position.riskPremiumPPM,
        reserveContribution: position.reserveContribution,
    })}></script>
    <script id="mint-i18n" type="application/json" set:html={JSON.stringify(clientI18n)}></script>
    <script id="mint-locale" type="application/json" set:html={JSON.stringify(getLocale(Astro.url))}></script>
</Layout>

<script>
    import { type Address } from "viem";
    import { getPublicClient, makeWalletClient } from "@lib/client";
    import { getOnboard } from "@lib/onboard";
    import { toast } from "@lib/toast";
    import { friendlyError } from "@lib/errors";
    import { ADDRESSES } from "@config/addresses";
    import { getMarketPriceCHF } from "@lib/prices";
    import { findStaticPosition, loadPositionDetail, type PositionStaticDetail } from "@lib/positionDetail";
    import {
        getAllowance, approveCollateral, executeClone, executeCloneWithPrice,
    } from "@lib/borrowActions";
    import { clearPositionsCache } from "@lib/positions";
    import { localePath } from "@i18n/t";
    import type { Locale } from "@i18n/messages";

    // ==================== CONSTANTS & DATA ====================
    const $ = (id: string) => document.getElementById(id) as HTMLElement;
    const data = JSON.parse($("position-data").textContent || "{}") as PositionStaticDetail & {
        limit: any; minimumCollateral: any;
    };
    const i18n = JSON.parse($("mint-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("mint-locale").textContent || '"en"') as string;

    const PRICE_DIGIT = 36 - data.collateralDecimals;
    const SLIDER_RES = 1000;
    const ETH_CHAIN_ID_HEX = "0x1";
    const ONE_E18 = 10n ** 18n;

    // ==================== FORMAT HELPERS ====================
    const fmt = (n: number, min = 2, max = 2) =>
        n.toLocaleString("en-US", { minimumFractionDigits: min, maximumFractionDigits: max });
    const fmtPlain = (n: number, max = 8) =>
        n.toLocaleString("en-US", { useGrouping: false, maximumFractionDigits: max });
    const parseNum = (s: string) => {
        const n = parseFloat(s.trim().replace(/,/g, ""));
        return Number.isFinite(n) && n >= 0 ? n : 0;
    };
    const toBig = (n: number, dec: number): bigint => {
        if (n <= 0) return 0n;
        const [whole, frac = ""] = n.toString().split(".");
        return BigInt(whole + (frac + "0".repeat(dec)).slice(0, dec));
    };
    const fromBig = (v: bigint, dec: number) => Number(v) / Math.pow(10, dec);

    const isValidPartial = (next: string, dec: number): boolean => {
        if (next === "") return true;
        const re = dec === 0 ? /^\d*$/ : new RegExp(`^\\d*(\\.\\d{0,${dec}})?$`);
        return re.test(next);
    };
    const clampDecimals = (raw: string, dec: number): string => {
        let s = raw.replace(/,/g, ".").replace(/[^\d.]/g, "");
        const firstDot = s.indexOf(".");
        if (firstDot !== -1) {
            s = s.slice(0, firstDot + 1) + s.slice(firstDot + 1).replace(/\./g, "");
            const [whole, frac = ""] = s.split(".");
            s = dec === 0 ? whole : whole + "." + frac.slice(0, dec);
        }
        return s;
    };
    const applyClamp = (input: HTMLInputElement, dec: number): string => {
        const trimmed = clampDecimals(input.value, dec);
        if (trimmed !== input.value) {
            const pos = input.selectionStart;
            input.value = trimmed;
            if (pos !== null) {
                const caret = Math.min(pos, trimmed.length);
                input.setSelectionRange(caret, caret);
            }
        }
        return trimmed;
    };

    // ==================== RAW PROVIDER ACCESS ====================
    // Web3-onboard wraps window.ethereum with middleware that desyncs from
    // the wallet's actual chain and throws "JSON-RPC version not supported".
    // We talk to window.ethereum directly for chain ops and tx signing.
    function getRawProvider(): any {
        const eth = (window as any).ethereum;
        if (!eth) return null;
        if (Array.isArray(eth.providers) && eth.providers.length) {
            const mm = eth.providers.find((p: any) => p.isMetaMask && !p.isBraveWallet);
            return mm ?? eth.providers[0];
        }
        return eth;
    }
    async function readChainId(): Promise<string | null> {
        const p = getRawProvider();
        if (!p?.request) return null;
        try {
            const id = await p.request({ method: "eth_chainId" });
            return typeof id === "string" ? id.toLowerCase() : null;
        } catch { return null; }
    }
    async function forceMainnet(): Promise<void> {
        const p = getRawProvider();
        if (!p?.request) throw new Error("No wallet provider available");
        await p.request({
            method: "wallet_switchEthereumChain",
            params: [{ chainId: ETH_CHAIN_ID_HEX }],
        });
    }
    function isUserCancelErr(err: any): boolean {
        const code = err?.code ?? err?.cause?.code;
        if (code === 4001) return true;
        return /reject|denied|cancel/i.test(err?.message ?? "");
    }
    function isWalletRpcError(err: any): boolean {
        const msg = (err?.message ?? err?.cause?.message ?? "").toString().toLowerCase();
        const code = err?.code ?? err?.cause?.code;
        if (msg.includes("json-rpc") || msg.includes("json rpc")) return true;
        if (code === -32603 || code === -32000 || code === -32601 || code === -32006) return true;
        return false;
    }

    // ==================== STATE ====================
    let lastEdited: "coll" | "mint" = "coll";
    let linked = true;
    let maxSelected = true;
    let collAmount = BigInt(data.minimumCollateral);
    let parentPrice = 1n;
    let newPrice = parentPrice;
    let mintAmount = 0n;

    let connected: Address | null = null;
    let userBalance = 0n;
    let availableForClones = 0n;
    let annualInterestPPM = 0;
    let allowanceHub = 0n;
    let allowanceHelper = 0n;
    let isClosed = false;
    let cooldown = 0;
    let challengedAmount = 0n;
    let collateralPriceZchf = 0;

    // ==================== ELEMENT REFS ====================
    const e = {
        coll: $("input-coll") as HTMLInputElement,
        mint: $("input-mint") as HTMLInputElement,
        balanceColl: $("balance-coll"),
        mintable: $("mintable-amount"),
        poolCapacity: $("pool-capacity"),
        maxColl: $("btn-max-coll") as HTMLButtonElement,
        maxMint: $("btn-max-mint") as HTMLButtonElement,
        link: $("btn-link") as HTMLButtonElement,
        linkWrap: $("link-wrap"),
        sliderSection: $("slider-section"),
        sliderFallback: $("slider-fallback"),
        slider: $("slider-price") as HTMLInputElement,
        priceValue: $("price-value"),
        priceValueStatic: $("price-value-static"),
        ltv: $("ltv-value"),
        cooldownWarn: $("cooldown-warning"),
        date: $("input-date") as HTMLInputElement,
        expiryHint: $("expiry-hint"),
        outMinted: $("out-minted"),
        outReserve: $("out-reserve"),
        outReservePct: $("out-reserve-pct"),
        outRepaid: $("out-repaid"),
        outRepaidPct: $("out-repaid-pct"),
        outFee: $("out-fee"),
        outRate: $("out-rate"),
        outNet: $("out-net"),
        actionsConnected: $("actions-connected"),
        actionsDisconnected: $("actions-disconnected"),
        action: $("btn-action") as HTMLButtonElement,
        actionLabel: document.querySelector(".btn-action-label") as HTMLElement,
        actionError: $("action-error"),
        connect: $("btn-connect") as HTMLButtonElement,
        banner: $("banner"),
    };

    // ==================== ERROR HANDLING ====================
    function showError(msg: string | null) {
        e.actionError.classList.toggle("hidden", !msg);
        e.actionError.textContent = msg ?? "";
    }
    function showRpcError() {
        e.actionError.classList.remove("hidden");
        e.actionError.innerHTML = "";
        const wrap = document.createElement("div");
        wrap.className = "rpc-error";
        for (const [cls, text] of [
            ["rpc-error-title", i18n.errRpcTitle],
            ["rpc-error-body", i18n.errRpcBody],
            ["rpc-error-help", i18n.errRpcHelp],
        ] as const) {
            const div = document.createElement("div");
            div.className = cls;
            div.textContent = text;
            wrap.append(div);
        }
        e.actionError.append(wrap);
    }
    /** Centralized handler for tx click failures: cancel → toast, RPC → inline panel, else → toast */
    function handleErr(err: any) {
        if (isUserCancelErr(err)) {
            toast(i18n.cancelled, "info");
        } else if (isWalletRpcError(err)) {
            showRpcError();
        } else {
            const { message } = friendlyError(err);
            toast(message, "error");
        }
    }

    // ==================== SLIDER & PRICE MATH ====================
    function bounds() {
        const m = collateralPriceZchf || 1;
        return { min: m * 0.1, max: m };
    }
    function pct(priceBig: bigint): number {
        const { min, max } = bounds();
        const v = fromBig(priceBig, PRICE_DIGIT);
        const scale = Math.max(max - min, 1e-10);
        return Math.max(0, Math.min(100, ((v - min) / scale) * 100));
    }
    function sliderToPrice(slv: number): bigint {
        const { min, max } = bounds();
        return toBig(min + (slv / SLIDER_RES) * (max - min), PRICE_DIGIT);
    }
    function priceToSlider(priceBig: bigint): number {
        const { min, max } = bounds();
        const v = fromBig(priceBig, PRICE_DIGIT);
        const scale = Math.max(max - min, 1e-10);
        return Math.max(0, Math.min(SLIDER_RES, ((v - min) / scale) * SLIDER_RES));
    }
    function effectiveMintPrice(): bigint {
        return newPrice <= parentPrice ? newPrice : parentPrice;
    }
    function borrowingLimit(): bigint {
        const p = effectiveMintPrice();
        if (p === 0n) return 0n;
        const byCollateral = (collAmount * p) / ONE_E18;
        return availableForClones < byCollateral ? availableForClones : byCollateral;
    }
    function activeAllowance(): bigint {
        return newPrice === parentPrice ? allowanceHub : allowanceHelper;
    }
    function activeSpender(): Address {
        return (newPrice === parentPrice
            ? ADDRESSES.ethereum.mintingHubV2!
            : ADDRESSES.ethereum.cloneHelper!) as Address;
    }

    // ==================== LINKED INPUT SYNC ====================
    function syncMintFromColl() {
        if (!linked) return;
        mintAmount = (collAmount * effectiveMintPrice()) / ONE_E18;
    }
    function syncCollFromMint() {
        if (!linked) return;
        const p = effectiveMintPrice();
        if (p > 0n) collAmount = (mintAmount * ONE_E18 + p - 1n) / p;
    }
    function syncFromLastEdited() {
        if (lastEdited === "coll") syncMintFromColl();
        else syncCollFromMint();
    }

    // ==================== DATE TABS ====================
    const TAB_DAYS: Record<string, number> = { "1M": 30, "3M": 90, "6M": 180, "1Y": 365 };
    function applyTab(tab: string) {
        maxSelected = tab === "MAX";
        const max = new Date(data.expiration * 1000);
        const target = tab === "MAX"
            ? max
            : new Date(Math.min(Date.now() + TAB_DAYS[tab] * 86400e3, max.getTime()));
        e.date.value = target.toISOString().slice(0, 10);
        document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(b =>
            b.classList.toggle("active", b.dataset.tab === tab));
        render();
    }
    function pickedDateTs(dateStr: string): number {
        if (!dateStr || maxSelected) return data.expiration;
        const localEod = Math.floor(new Date(`${dateStr}T23:59:59`).getTime() / 1000);
        return Math.min(localEod, data.expiration);
    }

    // ==================== VALIDATION ====================
    function validate(): { ok: boolean; reason: string | null } {
        if (mintAmount <= 0n) return { ok: false, reason: i18n.errAmountRequired };
        const minColl = BigInt(data.minimumCollateral);
        if (collAmount < minColl) {
            const niceMin = fmt(fromBig(minColl, data.collateralDecimals), 0, data.collateralDecimals);
            return {
                ok: false,
                reason: i18n.errMinCollateralTemplate
                    .replace("{amount}", niceMin)
                    .replace("{symbol}", i18n.symbol),
            };
        }
        if (connected && collAmount > userBalance) return { ok: false, reason: i18n.errBalanceLow };
        if (mintAmount > availableForClones) return { ok: false, reason: i18n.errExceedsPool };
        if (mintAmount > borrowingLimit()) return { ok: false, reason: i18n.errExceedsCollateral };
        return { ok: true, reason: null };
    }
    function isPositionBlocked(): boolean {
        if (isClosed) return true;
        const now = Date.now();
        return data.start * 1000 > now || cooldown * 1000 > now;
    }

    // ==================== RENDER ====================
    function syncActionButton() {
        if (!connected) return;
        const v = validate();
        const needsApproval = activeAllowance() < collAmount;
        const label = needsApproval
            ? i18n.actionApproveTemplate.replace("{symbol}", i18n.symbol)
            : i18n.actionMint;
        e.actionLabel.textContent = label;
        e.action.disabled = !v.ok || isPositionBlocked();
    }
    function syncBanner() {
        const now = Date.now();
        if (data.start * 1000 > now) {
            e.banner.textContent = i18n.statusPending;
            e.banner.classList.remove("hidden");
        } else if (cooldown * 1000 > now) {
            e.banner.textContent = i18n.statusCooldown;
            e.banner.classList.remove("hidden");
        } else {
            e.banner.classList.add("hidden");
        }
    }
    function render() {
        const dec = data.collateralDecimals;
        const priceFloat = fromBig(newPrice, PRICE_DIGIT);
        e.priceValue.textContent = fmt(priceFloat, 2, priceFloat < 1 ? 4 : 2);

        if (collateralPriceZchf > 0) {
            e.sliderSection.style.setProperty("--source", `${pct(parentPrice)}%`);
            e.sliderSection.style.setProperty("--value", `${pct(newPrice)}%`);
            e.slider.value = String(priceToSlider(newPrice));
        }

        e.ltv.textContent = collateralPriceZchf > 0
            ? `${fmt((priceFloat / collateralPriceZchf) * 100, 2, 2)}%` : "—";
        e.cooldownWarn.classList.toggle("hidden", newPrice <= parentPrice);
        e.mintable.textContent = fmt(fromBig(borrowingLimit(), 18), 0, 0);
        e.poolCapacity.textContent = `${fmt(fromBig(availableForClones, 18), 0, 0)} ZCHF`;

        if (document.activeElement !== e.coll) e.coll.value = fmtPlain(fromBig(collAmount, dec), dec);
        if (document.activeElement !== e.mint) e.mint.value = fmtPlain(fromBig(mintAmount, 18), 18);

        const reservePct = data.reserveContribution / 10000;
        const repaidPct = 100 - reservePct;
        const reserveRatio = data.reserveContribution / 1_000_000;
        const nominalRate = annualInterestPPM / 1_000_000;
        const effectiveRate = reserveRatio < 1 ? nominalRate / (1 - reserveRatio) : nominalRate;
        const reserveAmt = (mintAmount * BigInt(data.reserveContribution)) / 1_000_000n;
        const repaidAmt = mintAmount - reserveAmt;
        const dateTs = pickedDateTs(e.date.value);
        const secs = Math.max(0, dateTs - Math.floor(Date.now() / 1000));
        const fee = (mintAmount * BigInt(secs) * BigInt(annualInterestPPM)) / (BigInt(365 * 86400) * 1_000_000n);
        const net = mintAmount > reserveAmt + fee ? mintAmount - reserveAmt - fee : 0n;

        if (e.date.value) {
            const expiryDate = new Date(dateTs * 1000);
            const dateStr = expiryDate.toLocaleDateString(undefined, { day: "2-digit", month: "short", year: "numeric" });
            const timeStr = expiryDate.toLocaleTimeString(undefined, { hour: "2-digit", minute: "2-digit" });
            e.expiryHint.textContent = i18n.expiryHintTemplate
                .replace("{date}", dateStr).replace("{time}", timeStr);
        } else {
            e.expiryHint.innerHTML = "&nbsp;";
        }

        e.outMinted.textContent = `${fmt(fromBig(mintAmount, 18), 0, 2)} ZCHF`;
        e.outReserve.textContent = `−${fmt(fromBig(reserveAmt, 18), 0, 2)} ZCHF`;
        e.outReservePct.textContent = `(${fmt(reservePct, 0, 2)}%)`;
        e.outRepaid.textContent = `${fmt(fromBig(repaidAmt, 18), 0, 2)} ZCHF`;
        e.outRepaidPct.textContent = `(${fmt(repaidPct, 0, 2)}%)`;
        e.outFee.textContent = `−${fmt(fromBig(fee, 18), 0, 2)} ZCHF`;
        e.outRate.textContent = `(${i18n.perYearTemplate.replace("{rate}", fmt(effectiveRate * 100, 2, 2))})`;
        e.outNet.textContent = `${fmt(fromBig(net, 18), 0, 2)} ZCHF`;

        // Don't overwrite RPC error panel with a validation message
        const v = validate();
        if (!e.actionError.querySelector(".rpc-error")) {
            showError(connected && mintAmount > 0n ? v.reason : null);
        }
        syncActionButton();
        syncBanner();
    }

    // ==================== INPUT HANDLERS ====================
    const guardKeystrokes = (input: HTMLInputElement, dec: number) => {
        input.addEventListener("beforeinput", (ev) => {
            const ie = ev as InputEvent;
            if (!ie.data) return;
            const start = input.selectionStart ?? input.value.length;
            const end = input.selectionEnd ?? input.value.length;
            const insert = ie.data.replace(/,/g, ".");
            const next = input.value.slice(0, start) + insert + input.value.slice(end);
            if (!isValidPartial(next, dec)) ie.preventDefault();
        });
    };
    guardKeystrokes(e.coll, data.collateralDecimals);
    guardKeystrokes(e.mint, 18);

    e.coll.addEventListener("input", () => {
        lastEdited = "coll";
        collAmount = toBig(parseNum(applyClamp(e.coll, data.collateralDecimals)), data.collateralDecimals);
        syncMintFromColl();
        render();
    });
    e.mint.addEventListener("input", () => {
        lastEdited = "mint";
        mintAmount = toBig(parseNum(applyClamp(e.mint, 18)), 18);
        syncCollFromMint();
        render();
    });
    e.maxColl.addEventListener("click", () => {
        collAmount = userBalance;
        syncMintFromColl();
        render();
    });
    e.maxMint.addEventListener("click", () => {
        mintAmount = borrowingLimit();
        syncCollFromMint();
        render();
    });
    e.link.addEventListener("click", () => {
        linked = !linked;
        e.linkWrap.classList.toggle("broken", !linked);
        if (linked && newPrice > parentPrice) newPrice = parentPrice;
        if (linked) syncFromLastEdited();
        render();
    });
    e.slider.addEventListener("input", () => {
        const proposed = sliderToPrice(Number(e.slider.value));
        newPrice = (linked && proposed > parentPrice) ? parentPrice : proposed;
        syncFromLastEdited();
        render();
    });
    e.date.addEventListener("change", () => {
        maxSelected = false;
        document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(b => b.classList.remove("active"));
        render();
    });
    document.querySelectorAll<HTMLButtonElement>(".tab-btn").forEach(b =>
        b.addEventListener("click", () => applyTab(b.dataset.tab!)));

    e.connect.addEventListener("click", () => getOnboard().connectWallet());

    // ==================== TX FLOW ====================
    const lockBtn = (label: string) => {
        const original = e.actionLabel.textContent ?? "";
        e.action.dataset.loading = "1";
        e.action.disabled = true;
        e.actionLabel.textContent = label;
        return () => {
            delete e.action.dataset.loading;
            e.actionLabel.textContent = original;
            syncActionButton();
        };
    };

    /** Returns true if we end up on mainnet, false otherwise (and surfaces the error). */
    async function ensureMainnet(): Promise<boolean> {
        const before = await readChainId();
        if (before === ETH_CHAIN_ID_HEX) return true;
        const unlock = lockBtn(i18n.actionSwitching);
        try {
            await forceMainnet();
            const after = await readChainId();
            if (after !== ETH_CHAIN_ID_HEX) {
                toast(i18n.cancelled, "info");
                return false;
            }
            return true;
        } catch (err) {
            handleErr(err);
            return false;
        } finally {
            unlock();
        }
    }

    e.action.addEventListener("click", async () => {
        if (!connected) return;

        // Clear any prior RPC error panel before starting
        e.actionError.classList.add("hidden");
        e.actionError.innerHTML = "";

        if (!(await ensureMainnet())) return;

        const v = validate();
        if (!v.ok) { showError(v.reason); return; }

        const publicClient = getPublicClient("ethereum");
        const rawProvider = getRawProvider();
        if (!rawProvider) { toast(i18n.notConnected, "error"); return; }
        const walletClient = makeWalletClient(rawProvider, "ethereum");
        const needsApproval = activeAllowance() < collAmount;

        if (needsApproval) {
            const unlock = lockBtn(i18n.actionApproving);
            try {
                await approveCollateral(walletClient, publicClient,
                    data.collateral as Address, activeSpender(), connected);
                if (newPrice === parentPrice) {
                    allowanceHub = await getAllowance(publicClient, data.collateral as Address,
                        connected, ADDRESSES.ethereum.mintingHubV2! as Address);
                } else {
                    allowanceHelper = await getAllowance(publicClient, data.collateral as Address,
                        connected, ADDRESSES.ethereum.cloneHelper! as Address);
                }
                toast(i18n.toastApproved, "success");
            } catch (err) {
                handleErr(err);
            } finally {
                unlock();
            }
            return;
        }

        const unlock = lockBtn(i18n.actionMinting);
        try {
            const expirationTs = pickedDateTs(e.date.value);
            const args = {
                parent: data.address as Address,
                collateral: collAmount,
                mint: mintAmount,
                expiration: expirationTs,
                account: connected,
            };
            const result = newPrice === parentPrice
                ? await executeClone(walletClient, publicClient, args)
                : await executeCloneWithPrice(walletClient, publicClient, { ...args, newPrice });
            toast(i18n.toastMinted, "success");
            clearPositionsCache();
            window.location.href = localePath(locale as Locale, `/mypositions/${result.position}`);
        } catch (err) {
            handleErr(err);
        } finally {
            unlock();
        }
    });

    // ==================== INIT ====================
    function setConnectedUI(isConnected: boolean) {
        e.actionsConnected.classList.toggle("hidden", !isConnected);
        e.actionsDisconnected.classList.toggle("hidden", isConnected);
        e.maxColl.disabled = !isConnected;
    }

    e.date.max = new Date(data.expiration * 1000).toISOString().slice(0, 10);
    e.date.min = new Date().toISOString().slice(0, 10);
    applyTab("MAX");

    async function refreshPositionDetail() {
        const staticInfo = findStaticPosition(data.address);
        if (!staticInfo) return;
        const userAtFetchStart = connected;
        try {
            const detail = await loadPositionDetail(staticInfo, userAtFetchStart);
            parentPrice = detail.price;
            if (newPrice === parentPrice || newPrice === 1n) newPrice = detail.price;
            availableForClones = detail.availableForClones;
            annualInterestPPM = detail.annualInterestPPM;
            isClosed = detail.isClosed;
            cooldown = detail.cooldown;
            challengedAmount = detail.challengedAmount;
            if (userAtFetchStart) {
                userBalance = detail.userBalance;
                allowanceHub = detail.allowanceHub;
                allowanceHelper = detail.allowanceHelper;
            } else {
                userBalance = 0n;
                allowanceHub = 0n;
                allowanceHelper = 0n;
            }
            if (mintAmount === 0n) mintAmount = (parentPrice * collAmount) / ONE_E18;
            e.balanceColl.textContent = fmt(fromBig(userBalance, data.collateralDecimals), 2, 4);
            render();
        } catch (err) {
            console.error("loadPositionDetail failed:", err);
        }
    }

    getOnboard().state.select("wallets").subscribe((wallets) => {
        const w = wallets[0];
        if (w?.accounts[0]) {
            connected = w.accounts[0].address as Address;
            setConnectedUI(true);
        } else {
            connected = null;
            setConnectedUI(false);
        }
        refreshPositionDetail();
    });

    (async () => {
        const market = await getMarketPriceCHF(data.collateralSymbol);
        if (market === null || market <= 0) {
            e.sliderSection.classList.add("hidden");
            e.sliderFallback.classList.remove("hidden");
            e.priceValueStatic.textContent = fmt(fromBig(parentPrice, PRICE_DIGIT), 2, 4);
            return;
        }
        collateralPriceZchf = market;
        render();
    })();

    setConnectedUI(false);
    render();
</script>