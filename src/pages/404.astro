---
import Layout from "@layouts/Layout.astro";
import { t, getLocale, localePath } from "@i18n/t";
import type { Locale } from "@i18n/messages";

const tt = t(Astro.url);
const locale = getLocale(Astro.url);
const homeHref = localePath(locale as Locale, "/");
---

<Layout title={`${tt("notfound_title")} | Frankencoin dApp`} description={tt("notfound_meta")}>
    <main class="mx-auto flex min-h-[60vh] max-w-xl flex-col items-center justify-center px-4 py-16 text-center md:px-6">
        <p class="text-[64px] font-bold leading-none tracking-tight">404</p>
        <h1 class="mt-4 text-[24px] font-bold tracking-tight">{tt("notfound_title")}</h1>
        <p class="mt-3 text-[14px]">{tt("notfound_text")}</p>
        <a
            href={homeHref}
            class="mt-8 inline-flex items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2.5 text-[15px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover dark:text-[#030303]"
        >
            ← {tt("notfound_back")}
        </a>
    </main>
</Layout>