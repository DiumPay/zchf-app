---
import Layout from "@layouts/Layout.astro";
import Card from "@components/Card.astro";
import SortIcon from "@assets/icons/arrow-down-narrow-wide.svg";
import { t, getLocale, localePath, safeJsonForScript } from "@i18n/t";

import bossIcon from "@assets/tokens/boss.svg?url";
import cbbtcIcon from "@assets/tokens/cbbtc.svg?url";
import crvIcon from "@assets/tokens/crv.svg?url";
import gnoIcon from "@assets/tokens/gno.svg?url";
import lendsIcon from "@assets/tokens/lends.svg?url";
import lsethIcon from "@assets/tokens/lseth.svg?url";
import paxgIcon from "@assets/tokens/paxg.svg?url";
import realuIcon from "@assets/tokens/realu.svg?url";
import spyonIcon from "@assets/tokens/spyon.svg?url";
import wbtcIcon from "@assets/tokens/wbtc.svg?url";
import wethIcon from "@assets/tokens/weth.svg?url";
import wstethIcon from "@assets/tokens/wsteth.svg?url";
import xautIcon from "@assets/tokens/xaut.svg?url";
import ysyboldIcon from "@assets/tokens/ysybold.svg?url";
import unknownIcon from "@assets/icons/unknown.svg?url";

const TOKEN_ICONS: Record<string, string> = {
    boss: bossIcon,
    cbbtc: cbbtcIcon,
    crv: crvIcon,
    gno: gnoIcon,
    lends: lendsIcon,
    lseth: lsethIcon,
    paxg: paxgIcon,
    realu: realuIcon,
    spyon: spyonIcon,
    wbtc: wbtcIcon,
    weth: wethIcon,
    wsteth: wstethIcon,
    xaut: xautIcon,
    ysybold: ysyboldIcon,
};
const UNKNOWN_ICON = unknownIcon;

const tt = t(Astro.url);
const locale = getLocale(Astro.url);
---

<Layout title={`Monitoring | Frankencoin dApp`} description="Monitor the health of the Frankencoin protocol. Spot undercollateralized positions and earn a 2% reward by challenging them.">
    <main class="mx-auto max-w-6xl px-4 py-10 md:px-6 md:py-12">
        <header class="mb-6">
            <h1 class="text-[28px] font-bold tracking-tight">{tt("mon_title")}</h1>
            <p class="mt-2 text-[14px] opacity-80">{tt("mon_subtitle")}</p>
        </header>

        <section class="mb-6 rounded-md border border-foreground/10 bg-background p-5">
            <h2 class="text-[16px] font-bold">{tt("mon_intro_title")}</h2>
            <p class="mt-2 text-[14px] opacity-80">{tt("mon_intro_text")}</p>
        </section>

        <section class="mb-6 rounded-md border border-foreground/10 bg-background p-5">
            <h2 class="text-[16px] font-bold">{tt("mon_auctions_intro_title")}</h2>
            <p class="mt-2 text-[14px] opacity-80">{tt("mon_auctions_intro_text")}</p>
        </section>

        <Card title={tt("mon_auctions_table_title")}>
            <div class="hidden grid-cols-[2.2fr_1.2fr_1fr_1fr_auto] gap-4 border-b border-foreground/10 pb-3 text-[13px] font-bold opacity-70 md:grid">
                <span>{tt("mon_auc_col_available")}</span>
                <span>{tt("mon_auc_col_price")}</span>
                <span>{tt("mon_auc_col_phase")}</span>
                <span>{tt("mon_auc_col_ends_in")}</span>
                <span class="w-24"></span>
            </div>

            <ul id="auc-list" class="divide-y divide-foreground/10">
                <li id="auc-loading" class="py-6 text-center text-[14px] opacity-60">
                    {tt("mon_loading")}
                </li>
            </ul>

            <p id="auc-empty" class="hidden py-6 text-center text-[14px] opacity-60">
                {tt("mon_auc_empty")}
            </p>
        </Card>

        <div class="mt-6"></div>

        <Card title={tt("mon_table_title")}>
            <div
                data-token-icons={JSON.stringify(TOKEN_ICONS)}
                data-unknown-icon={UNKNOWN_ICON}
                class="hidden"
            ></div>

            <div class="mb-5 flex items-center justify-between gap-3">
                <span id="mon-count" class="text-[14px] opacity-70"></span>
                <div class="flex-1 max-w-md">
                    <label for="mon-search" class="sr-only">{tt("mon_search_placeholder")}</label>
                    <input
                        id="mon-search"
                        type="text"
                        placeholder={tt("mon_search_placeholder")}
                        class="w-full rounded-md border border-foreground/20 bg-background px-3 py-2 text-[14px] focus:border-foreground/40 focus:outline-none"
                    />
                </div>
            </div>

            <div class="hidden grid-cols-[2.2fr_1.4fr_1fr_1fr_1fr_auto] gap-4 border-b border-foreground/10 pb-3 text-[13px] font-bold opacity-70 md:grid">
                <button type="button" data-sort="name" class="sort-btn flex items-center gap-1.5 text-left">
                    <span>{tt("mon_col_collateral")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="price" class="sort-btn flex items-center gap-1.5 text-left">
                    <span>{tt("mon_col_price")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="health" class="sort-btn flex items-center gap-1.5 text-left">
                    <span>{tt("mon_col_health")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="challenged" class="sort-btn flex items-center gap-1.5 text-left">
                    <span>{tt("mon_col_challenged")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <button type="button" data-sort="expiration" class="sort-btn flex items-center gap-1.5 text-left">
                    <span>{tt("mon_col_expiration")}</span>
                    <SortIcon class="sort-icon h-3.5 w-3.5 transition-transform" aria-hidden="true" />
                </button>
                <span class="w-24"></span>
            </div>

            <ul id="mon-list" class="divide-y divide-foreground/10">
                <li id="mon-loading" class="py-6 text-center text-[14px] opacity-60">
                    {tt("mon_loading")}
                </li>
            </ul>

            <p id="mon-empty" class="hidden py-6 text-center text-[14px] opacity-60">
                {tt("mon_empty")}
            </p>
        </Card>
    </main>
</Layout>

<style>
    .sort-btn { cursor: pointer; user-select: none; }
    .sort-icon { display: none; }
    .sort-btn[data-direction] .sort-icon { display: inline-block; }
    .sort-btn[data-direction="desc"] .sort-icon { transform: rotate(180deg); }
</style>

<script id="mon-locale" type="application/json" set:html={safeJsonForScript(getLocale(Astro.url))}></script>
<script id="mon-i18n" type="application/json" set:html={safeJsonForScript({
    btn_challenge: tt("mon_btn_challenge"),
    health_loading: tt("mon_health_loading"),
    health_no_price: tt("mon_health_no_price"),
    per: tt("mon_per"),
    count_fmt: tt("mon_count_fmt"),
    empty: tt("mon_empty"),
    error: tt("mon_error"),
    days_short: tt("mon_days_short"),
    expired: tt("mon_expired"),
    auc_empty: tt("mon_auc_empty"),
    auc_btn_buy: tt("mon_auc_btn_buy"),
    auc_phase_fixed: tt("mon_auc_phase_fixed"),
    auc_phase_declining: tt("mon_auc_phase_declining"),
    auc_phase_zero: tt("mon_auc_phase_zero"),
})}></script>

<script>
    import { loadMonitoredCached, type MonitoredPosition } from "@lib/positions";
    import { getMarketPriceCHF } from "@lib/prices";
    import { loadActiveChallengesCached, auctionState, fmtDuration, type ActiveChallenge } from "@lib/challenges";
    import { localePath } from "@i18n/t";
    import type { Locale } from "@i18n/messages";

    const $ = <T extends HTMLElement = HTMLElement>(id: string) => document.getElementById(id) as T;

    const i18n = JSON.parse($("mon-i18n").textContent || "{}") as Record<string, string>;
    const locale = JSON.parse($("mon-locale").textContent || '"en"') as string;

    const iconHost = document.querySelector<HTMLElement>("[data-token-icons]")!;
    const tokenIcons = JSON.parse(iconHost.dataset.tokenIcons || "{}") as Record<string, string>;
    const unknownIconUrl = iconHost.dataset.unknownIcon || "";

    const esc = (s: unknown): string =>
        String(s).replace(/[&<>"']/g, c =>
            ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));

    const isAddrLike = (s: unknown): s is string =>
        typeof s === "string" && /^0x[0-9a-fA-F]{40}$/.test(s);

    const numberLocale = ({ en: "en-US", de: "de-CH", fr: "fr-CH", it: "it-CH", es: "es-ES" } as Record<string, string>)[locale] ?? "en-US";

    const list = $<HTMLUListElement>("mon-list");
    const loading = $("mon-loading");
    const empty = $("mon-empty");
    const search = $<HTMLInputElement>("mon-search");
    const count = $("mon-count");

    const aucList = $<HTMLUListElement>("auc-list");
    const aucLoading = $("auc-loading");
    const aucEmpty = $("auc-empty");

    let allPositions: MonitoredPosition[] = [];
    let activeChallenges: ActiveChallenge[] = [];
    const priceMap: Record<string, number | null | undefined> = {};

    type SortKey = "name" | "price" | "health" | "challenged" | "expiration";
    type SortDir = "asc" | "desc";
    let sortKey: SortKey = "health";
    let sortDir: SortDir = "asc";

    function iconFor(symbol: string): string {
        return tokenIcons[symbol.toLowerCase()] ?? unknownIconUrl;
    }

    function units(raw: bigint, decimals: number): number {
        if (decimals === 0) return Number(raw);
        const scale = 10n ** BigInt(decimals);
        const whole = raw / scale;
        const frac = raw % scale;
        return Number(whole) + Number(frac) / Number(scale);
    }

    function fmtAmount(raw: bigint, decimals: number): string {
        const n = units(raw, decimals);
        if (decimals === 0 || n >= 1000) {
            return n.toLocaleString(numberLocale, { maximumFractionDigits: 0 });
        }
        return n.toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function liquidationPriceZchf(p: MonitoredPosition): number {
        return Number(p.price) / Math.pow(10, 36 - p.collateralDecimals);
    }

    function fmtZchfPrice(n: number): string {
        if (n >= 100) return n.toLocaleString(numberLocale, { maximumFractionDigits: 0 });
        return n.toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    function fmtDate(ts: number): string {
        return new Date(ts * 1000).toLocaleDateString(numberLocale, { day: "2-digit", month: "short", year: "numeric" });
    }

    function daysFromNow(ts: number): number {
        return Math.round((ts * 1000 - Date.now()) / 86_400_000);
    }

    /**
     * Health = market price / liquidation price × 100. Mirrors frankencoin.com
     * monitoring: the position-level risk metric that determines challenge-
     * ability, independent of how much was minted.
     */
    function healthFor(p: MonitoredPosition): number | "loading" | "no-price" {
        const sym = p.collateralSymbol.toUpperCase();
        const market = priceMap[sym];
        if (market === undefined) return "loading";
        if (market === null || market <= 0) return "no-price";
        const liqPrice = liquidationPriceZchf(p);
        if (liqPrice <= 0) return "no-price";
        return (market / liqPrice) * 100;
    }

    function healthCellHtml(p: MonitoredPosition): string {
        const h = healthFor(p);
        if (h === "loading") return `<span class="opacity-50">${esc(i18n.health_loading)}</span>`;
        if (h === "no-price") return `<span class="opacity-60">${esc(i18n.health_no_price)}</span>`;
        let cls = "";
        if (h < 110) cls = "text-primary font-semibold";
        else if (h <= 120) cls = "text-amber-600 dark:text-amber-500";
        return `<span class="${cls}">${h.toLocaleString(numberLocale, { minimumFractionDigits: 2, maximumFractionDigits: 2 })}%</span>`;
    }

    function challengedCellHtml(p: MonitoredPosition): string {
        if (p.challengedCollateral === 0n) return `<span class="opacity-60">-</span>`;
        return `<span class="text-primary font-medium">${fmtAmount(p.challengedCollateral, p.collateralDecimals)} ${esc(p.collateralSymbol)}</span>`;
    }

    function expirationCellHtml(p: MonitoredPosition): string {
        const days = daysFromNow(p.expiration);
        const dateLine = fmtDate(p.expiration);
        if (days < 0) {
            return `<div>${dateLine}</div><div class="text-[12px] opacity-60">${esc(i18n.expired)}</div>`;
        }
        return `<div>${dateLine}</div><div class="text-[12px] opacity-60">${days}${esc(i18n.days_short)}</div>`;
    }

    function sortValue(p: MonitoredPosition, key: SortKey): number | string {
        switch (key) {
            case "name": return p.collateralName.toLowerCase();
            case "price": return liquidationPriceZchf(p);
            case "health": {
                const h = healthFor(p);
                if (h === "no-price" || h === "loading") return Number.POSITIVE_INFINITY;
                return h;
            }
            case "challenged":
                return units(p.challengedCollateral, p.collateralDecimals);
            case "expiration": return p.expiration;
        }
    }

    function sorted(positions: MonitoredPosition[]): MonitoredPosition[] {
        const out = positions.slice();
        out.sort((a, b) => {
            const va = sortValue(a, sortKey);
            const vb = sortValue(b, sortKey);
            let cmp: number;
            if (typeof va === "string" && typeof vb === "string") cmp = va.localeCompare(vb);
            else cmp = (va as number) - (vb as number);
            return sortDir === "asc" ? cmp : -cmp;
        });
        return out;
    }

    function syncSortIndicators() {
        document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
            if (btn.dataset.sort === sortKey) btn.dataset.direction = sortDir;
            else delete btn.dataset.direction;
        });
    }

    function render(positions: MonitoredPosition[]) {
        if (positions.length === 0) {
            list.innerHTML = "";
            empty.classList.remove("hidden");
            return;
        }
        empty.classList.add("hidden");

        list.innerHTML = positions.map(p => {
            if (!isAddrLike(p.address)) return "";
            const icon = iconFor(p.collateralSymbol);
            const collatAmount = fmtAmount(p.collateralBalance, p.collateralDecimals);
            const liqPrice = liquidationPriceZchf(p);

            return `<li class="grid grid-cols-1 gap-3 py-4 md:grid-cols-[2.2fr_1.4fr_1fr_1fr_1fr_auto] md:items-center md:gap-4">
                <div class="flex items-center gap-3">
                    <img src="${icon}" alt="" class="h-9 w-9 shrink-0 rounded-full" />
                    <div>
                        <div class="font-bold text-[15px]">${collatAmount} ${esc(p.collateralSymbol)}</div>
                        <div class="text-[12px] opacity-70">${esc(p.collateralName)}</div>
                    </div>
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Price: </span>
                    <div>${fmtZchfPrice(liqPrice)} ZCHF</div>
                    <div class="text-[12px] opacity-60">${esc(i18n.per)} ${esc(p.collateralSymbol)}</div>
                </div>

                <div class="text-[14px]" data-health-cell="${p.address}">
                    <span class="md:hidden opacity-60">Health: </span>
                    ${healthCellHtml(p)}
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Challenged: </span>
                    ${challengedCellHtml(p)}
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Expiration: </span>
                    ${expirationCellHtml(p)}
                </div>

                <div>
                    <button
                        type="button"
                        data-position="${p.address}"
                        class="relative inline-flex w-full items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2 text-[14px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover dark:text-[#030303] md:w-auto"
                    >
                        ${esc(i18n.btn_challenge)}
                    </button>
                </div>
            </li>`;
        }).join("");

        list.querySelectorAll<HTMLButtonElement>("[data-position]").forEach(btn => {
            btn.addEventListener("click", () => {
                const addr = btn.dataset.position;
                if (!isAddrLike(addr)) return;
                window.location.href = localePath(locale as Locale, `/challenge?address=${addr}`);
            });
        });
    }

    function applyFilter() {
        const q = search.value.trim().toLowerCase();
        const base = q
            ? allPositions.filter(p =>
                p.collateralName.toLowerCase().includes(q) ||
                p.collateralSymbol.toLowerCase().includes(q) ||
                p.address.toLowerCase().includes(q) ||
                p.owner.toLowerCase().includes(q))
            : allPositions;
        const final = sorted(base);
        count.textContent = (i18n.count_fmt || "{n} positions").replace("{n}", String(final.length));
        render(final);
    }

    // ------------------------------------------------------------
    // Auctions section
    // ------------------------------------------------------------

    function phaseLabel(phase: "fixed" | "declining" | "zero"): string {
        if (phase === "fixed") return i18n.auc_phase_fixed;
        if (phase === "declining") return i18n.auc_phase_declining;
        return i18n.auc_phase_zero;
    }

    function renderAuctions() {
        // Cross-reference each challenge with its position to get
        // symbol/decimals/expiration. Skip if the position didn't come back
        // from /positions/monitored.
        const byAddr = new Map<string, MonitoredPosition>();
        for (const p of allPositions) byAddr.set(p.address.toLowerCase(), p);

        const rows: { c: ActiveChallenge; p: MonitoredPosition }[] = [];
        for (const c of activeChallenges) {
            const p = byAddr.get(c.position.toLowerCase());
            if (!p) continue;
            if (c.size <= c.filledSize) continue;
            rows.push({ c, p });
        }

        // Sort by remaining collateral size descending — biggest auctions first.
        rows.sort((a, b) => {
            const aRem = units(a.c.size - a.c.filledSize, a.p.collateralDecimals);
            const bRem = units(b.c.size - b.c.filledSize, b.p.collateralDecimals);
            return bRem - aRem;
        });

        if (rows.length === 0) {
            aucList.innerHTML = "";
            aucEmpty.classList.remove("hidden");
            return;
        }
        aucEmpty.classList.add("hidden");

        const now = Date.now();
        aucList.innerHTML = rows.map(({ c, p }) => {
            const remaining = c.size - c.filledSize;
            const state = auctionState(c.start, c.duration, c.liqPrice, p.expiration, p.collateralDecimals, now);
            const icon = iconFor(p.collateralSymbol);
            return `<li class="grid grid-cols-1 gap-3 py-4 md:grid-cols-[2.2fr_1.2fr_1fr_1fr_auto] md:items-center md:gap-4">
                <div class="flex items-center gap-3">
                    <img src="${icon}" alt="" class="h-9 w-9 shrink-0 rounded-full" />
                    <div>
                        <div class="font-bold text-[15px]">${fmtAmount(remaining, p.collateralDecimals)} ${esc(p.collateralSymbol)}</div>
                        <div class="text-[12px] opacity-70">${esc(p.collateralName)}</div>
                    </div>
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Price: </span>
                    <div>${fmtZchfPrice(state.priceZchf)} ZCHF</div>
                    <div class="text-[12px] opacity-60">${esc(i18n.per)} ${esc(p.collateralSymbol)}</div>
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Phase: </span>
                    ${esc(phaseLabel(state.phase))}
                </div>

                <div class="text-[14px]">
                    <span class="md:hidden opacity-60">Ends in: </span>
                    ${esc(fmtDuration(state.msUntilNextPhase))}
                </div>

                <div>
                    <button
                        type="button"
                        data-challenge-position="${c.position}"
                        data-challenge-number="${c.number}"
                        class="relative inline-flex w-full items-center justify-center gap-2 rounded-md border border-transparent bg-primary px-5 py-2 text-[14px] font-semibold text-[#FAF7F2] transition-colors hover:bg-primary-hover dark:text-[#030303] md:w-auto"
                    >
                        ${esc(i18n.auc_btn_buy)}
                    </button>
                </div>
            </li>`;
        }).join("");

        aucList.querySelectorAll<HTMLButtonElement>("[data-challenge-position]").forEach(btn => {
            btn.addEventListener("click", () => {
                const addr = btn.dataset.challengePosition;
                const num = btn.dataset.challengeNumber;
                if (!isAddrLike(addr) || !num) return;
                window.location.href = localePath(locale as Locale, `/monitoring/${addr}/auction/${num}`);
            });
        });
    }

    // ------------------------------------------------------------
    // Async loads
    // ------------------------------------------------------------

    async function loadPrices() {
        const symbols = Array.from(new Set(allPositions.map(p => p.collateralSymbol.toUpperCase())));
        await Promise.all(symbols.map(async sym => {
            try {
                priceMap[sym] = await getMarketPriceCHF(sym);
            } catch {
                priceMap[sym] = null;
            }
            applyFilter();
        }));
    }

    async function loadAuctions() {
        try {
            activeChallenges = await loadActiveChallengesCached();
        } catch (err) {
            console.error("[monitoring] challenges load failed", err);
            activeChallenges = [];
        }
        aucLoading.remove();
        renderAuctions();
    }

    document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach(btn => {
        btn.addEventListener("click", () => {
            const key = btn.dataset.sort as SortKey;
            if (sortKey === key) sortDir = sortDir === "asc" ? "desc" : "asc";
            else { sortKey = key; sortDir = "asc"; }
            syncSortIndicators();
            applyFilter();
        });
    });

    search.addEventListener("input", applyFilter);

    loadMonitoredCached()
        .then(positions => {
            allPositions = positions;
            loading.remove();
            syncSortIndicators();
            applyFilter();
            loadPrices();
            loadAuctions();
        })
        .catch(err => {
            console.error("[monitoring] load failed", err);
            loading.textContent = i18n.error;
            loadAuctions();
        });

    // Re-render auctions every 30s so "Ends in" and declining price stay live.
    setInterval(() => {
        if (activeChallenges.length > 0) renderAuctions();
    }, 30_000);
</script>