{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@assets/*": ["./src/assets/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@lib/*": ["./src/lib/*"],
      "@config/*": ["./src/lib/*"],
      "@pages/*": ["./src/pages/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*", "src"],
  "exclude": ["dist"]
}